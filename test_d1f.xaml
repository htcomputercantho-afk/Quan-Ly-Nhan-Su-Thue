                                            </Grid>
                                        </StackPanel>

                                        <!-- Add Button -->
                                        <Button x:Name="btnAddLeave" Grid.Column="4" Click="btnAddLeave_Click" 
                                                Height="35" Padding="20 0" VerticalAlignment="Bottom"
                                                Background="{DynamicResource PrimaryHueMidBrush}" BorderThickness="0">
                                            <StackPanel Orientation="Horizontal">
                                                <materialDesign:PackIcon Kind="ArrowDownBold" Margin="0 0 5 0"/>
                                                <TextBlock Text="Thêm vào bảng"/>
                                            </StackPanel>
                                        </Button>
                                    </Grid>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- History List Header -->
                        <StackPanel Orientation="Horizontal" Margin="0 0 0 10">
                            <materialDesign:PackIcon Kind="History" Foreground="{DynamicResource PrimaryHueMidBrush}" VerticalAlignment="Center" Margin="0 0 5 0"/>
                            <TextBlock Text="Lịch sử các đợt nghỉ chi tiết" FontWeight="Bold" Foreground="{DynamicResource PrimaryHueMidBrush}"/>
                        </StackPanel>

                        <!-- DataGrid -->
                        <Border Margin="0 5 0 0" Padding="0" CornerRadius="4" BorderThickness="1" BorderBrush="#E0E0E0" Background="White">
                            <DataGrid x:Name="dgLeaveHistory" AutoGenerateColumns="False" CanUserAddRows="False" 
                                      HeadersVisibility="Column" SelectionMode="Single"
                                      SelectionChanged="dgLeaveHistory_SelectionChanged"
                                      BorderThickness="0" Background="White"
                                      AlternatingRowBackground="#FAFAFA"
                                      GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#EEEEEE"
                                      VerticalGridLinesBrush="Transparent"
                                      MinRowHeight="52"
                                      ColumnHeaderHeight="55"
                                      ScrollViewer.CanContentScroll="False">
                                <DataGrid.Resources>
                                    <BooleanToVisibilityConverter x:Key="BoolToVis"/>
                                    
                                    <!-- Base Cell Style (Moved to Top) -->
                                    <Style TargetType="DataGridCell">
                                        <Setter Property="Padding" Value="12 4"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                        <Setter Property="VerticalContentAlignment" Value="Center"/>
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="DataGridCell">
                                                    <Border Padding="{TemplateBinding Padding}" 
                                                            BorderBrush="{TemplateBinding BorderBrush}" 
                                                            BorderThickness="{TemplateBinding BorderThickness}" 
                                                            Background="{TemplateBinding Background}" 
                                                            SnapsToDevicePixels="True">
                                                        <ContentPresenter SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" 
                                                                          VerticalAlignment="Center" 
                                                                          HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                        <Style.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Background" Value="#E3F2FD"/>
                                                <Setter Property="Foreground" Value="Black"/>
                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>

                                    <Style TargetType="DataGridCell" x:Key="CenterAlignedCellStyle" BasedOn="{StaticResource {x:Type DataGridCell}}">
                                        <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                    </Style>
                                    
                                    <Style TargetType="TextBlock" x:Key="CenterAlignedWrapCell">
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="HorizontalAlignment" Value="Center"/>
                                        <Setter Property="TextAlignment" Value="Center"/>
                                        <Setter Property="TextWrapping" Value="Wrap"/>
                                        <Setter Property="Padding" Value="10 5"/>
                                    </Style>
                                    
                                    <Style TargetType="DataGridColumnHeader">
                                        <Setter Property="Background" Value="{DynamicResource PrimaryHueMidBrush}"/>
                                        <Setter Property="Foreground" Value="White"/>
                                        <Setter Property="FontWeight" Value="Bold"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                        <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                        <Setter Property="VerticalContentAlignment" Value="Center"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="DataGridColumnHeader">
                                                    <Border Background="{TemplateBinding Background}" 
                                                            Padding="8 6" 
                                                            BorderBrush="{TemplateBinding BorderBrush}" 
                                                            BorderThickness="{TemplateBinding BorderThickness}">
                                                        <TextBlock Text="{TemplateBinding Content}" 
                                                                   TextWrapping="Wrap" 
                                                                   TextAlignment="Center" 
                                                                   VerticalAlignment="Center" 
                                                                   HorizontalAlignment="Center"
                                                                   Foreground="{TemplateBinding Foreground}"
                                                                   FontWeight="{TemplateBinding FontWeight}"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                    <Style TargetType="DataGridRow">
                                         <Setter Property="Margin" Value="0"/>
                                         <!-- Ensure Row renders on top of subsequent rows if it's a Group Head -->
                                         <Setter Property="Panel.ZIndex" Value="0"/> 
                                         <Style.Triggers>
                                             <Trigger Property="IsMouseOver" Value="True">
                                                 <Setter Property="Background" Value="#F5F5F5"/>
                                             </Trigger>
                                             <DataTrigger Binding="{Binding IsLinkedGroupHead}" Value="True">
                                                 <Setter Property="Panel.ZIndex" Value="100"/>
                                             </DataTrigger>
                                         </Style.Triggers>
                                    </Style>
                                </DataGrid.Resources>
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="STT" Binding="{Binding STT}" Width="50" IsReadOnly="True" CellStyle="{StaticResource CenterAlignedCellStyle}">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="TextWrapping" Value="Wrap"/>
                                                <Setter Property="TextAlignment" Value="Center"/>
                                                <Setter Property="VerticalAlignment" Value="Center"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="Loại nghỉ" Binding="{Binding LeaveType}" Width="*" MinWidth="80" IsReadOnly="True" CellStyle="{StaticResource CenterAlignedCellStyle}">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="TextWrapping" Value="Wrap"/>
                                                <Setter Property="TextAlignment" Value="Center"/>
                                                <Setter Property="VerticalAlignment" Value="Center"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="Từ ngày" Binding="{Binding StartDate, StringFormat=dd/MM/yyyy}" Width="*" MinWidth="85" IsReadOnly="True" CellStyle="{StaticResource CenterAlignedCellStyle}">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="TextWrapping" Value="Wrap"/>
                                                <Setter Property="TextAlignment" Value="Center"/>
                                                <Setter Property="VerticalAlignment" Value="Center"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="Đến ngày" Binding="{Binding EndDate, StringFormat=dd/MM/yyyy}" Width="*" MinWidth="85" IsReadOnly="True" CellStyle="{StaticResource CenterAlignedCellStyle}">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="TextWrapping" Value="Wrap"/>
                                                <Setter Property="TextAlignment" Value="Center"/>
                                                <Setter Property="VerticalAlignment" Value="Center"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="Số ngày" Binding="{Binding DurationDays}" Width="85" IsReadOnly="True" CellStyle="{StaticResource CenterAlignedCellStyle}">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="TextWrapping" Value="Wrap"/>
                                                <Setter Property="TextAlignment" Value="Center"/>
                                                <Setter Property="VerticalAlignment" Value="Center"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTemplateColumn Header="Lý do" Width="*">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding UserReasonDisplay}" 
                                                           TextWrapping="Wrap" 
                                                           TextAlignment="Center" 
                                                           VerticalAlignment="Center" 
                                                           HorizontalAlignment="Center" 
                                                           Padding="10 5" 
                                                           ToolTip="{Binding UserReasonDisplay}"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="Ghi chú hệ thống" Width="*" MinWidth="140">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding SystemMessageDisplay}" 
                                                           TextWrapping="Wrap" 
                                                           TextAlignment="Center" 
                                                           VerticalAlignment="Center" 
                                                           HorizontalAlignment="Center" 
                                                           Padding="10 5" 
                                                           Foreground="#E53E3E" 
                                                           FontStyle="Italic" 
                                                           ToolTip="{Binding SystemMessageDisplay}"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="Hành động" Width="90">
                                        <DataGridTemplateColumn.CellStyle>
                                            <Style TargetType="DataGridCell" BasedOn="{StaticResource {x:Type DataGridCell}}">
                                                <Setter Property="ClipToBounds" Value="False"/>
                                                <Setter Property="Panel.ZIndex" Value="100"/>
                                            </Style>
                                        </DataGridTemplateColumn.CellStyle>
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Button x:Name="btnDeleteLeave" Click="btnDeleteLeave_Click" Tag="{Binding Id}"
                                                        Style="{DynamicResource LeaveHistoryDeleteButtonStyle}">
                                                    <Button.Visibility>
                                                        <Binding Path="ShowDeleteButton">
                                                            <Binding.Converter>
                                                                <BooleanToVisibilityConverter/>
                                                            </Binding.Converter>
                                                        </Binding>
                                                    </Button.Visibility>
                                                    <materialDesign:PackIcon Kind="Delete" Width="20" Height="20"/>
                                                </Button>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Tab 6: Salary -->
            <TabItem Header="6. Thông tin lương">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Grid Margin="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/> <!-- Row 1: Step, Coeff -->
                            <RowDefinition Height="Auto"/> <!-- Row 2: Exceed, Allowance, Reservation -->
                            <RowDefinition Height="Auto"/> <!-- Row 3: Next Date, Delay, Expected -->
                            <RowDefinition Height="Auto"/> <!-- Row 4: History Label -->
                            <RowDefinition Height="Auto"/>    <!-- Row 5: History Content -->
                        </Grid.RowDefinitions>

                        <!-- Row 1 -->
                        <Grid Grid.Row="0" Margin="0 0 0 15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Step -->
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Bậc lương" Style="{StaticResource ModernLabel}"/>
                                <ComboBox x:Name="cboSalaryStep" Style="{StaticResource ModernComboBox}"
                                          SelectionChanged="cboSalaryStep_SelectionChanged"/>
                            </StackPanel>

                            <!-- Coefficient -->
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Hệ số lương" Style="{StaticResource ModernLabel}"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="txtSalaryCoefficient" Style="{StaticResource ModernTextBox}" IsReadOnly="True" Background="#F5F5F5"/>
                                    <Button Grid.Column="1" Margin="5 0 0 0" Width="30" Height="30" Padding="0"
                                            Style="{DynamicResource MaterialDesignFloatingActionMiniButton}"
                                            Background="{DynamicResource PrimaryHueMidBrush}"
                                            BorderBrush="{DynamicResource PrimaryHueMidBrush}"
                                            ToolTip="Cấu hình bảng lương" 
                                            Click="btnConfigSalary_Click">
                                        <materialDesign:PackIcon Kind="Cog" Width="18" Height="18" Foreground="White"/>
                                    </Button>
                                </Grid>
                            </StackPanel>
                        </Grid>

                        <!-- Row 2 -->
                        <Grid Grid.Row="1" Margin="0 0 0 15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Exceed Frame -->
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="% Vượt khung" Style="{StaticResource ModernLabel}"/>
                                <TextBox x:Name="txtExceedFrame" Style="{StaticResource ModernTextBox}" TextChanged="OnSalaryStructureChanged"/>
                            </StackPanel>

                            <!-- Position Allowance -->
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="PC Chức vụ" Style="{StaticResource ModernLabel}"/>
                                <TextBox x:Name="txtPositionAllowance" Style="{StaticResource ModernTextBox}"/>
                            </StackPanel>

                            <!-- Reservation Deadline -->
                            <StackPanel Grid.Column="4">
                                <TextBlock Text="Thời hạn bảo lưu" Style="{StaticResource ModernLabel}"/>
                                <DatePicker x:Name="dpSalaryReservation" Style="{StaticResource ModernDatePicker}" PreviewKeyUp="DatePicker_PreviewKeyUp"/>
                            </StackPanel>
                        </Grid>

                        <!-- Row 3 -->
                        <!-- Row 3 -->
                        <Grid Grid.Row="2" Margin="0 0 0 10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Next Calc Date -->
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Thời điểm tính bậc lương lần sau" Style="{StaticResource ModernLabel}"/>
                                <DatePicker x:Name="dpNextSalaryStepDate" Style="{StaticResource ModernDatePicker}" Foreground="{DynamicResource PrimaryHueMidBrush}" PreviewKeyUp="DatePicker_PreviewKeyUp" SelectedDateChanged="OnSalaryStructureChanged"/>
                            </StackPanel>

                            <!-- Delay -->
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Lùi thời gian nâng lương" Style="{StaticResource ModernLabel}"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <ComboBox x:Name="cboSalaryDelay" Style="{StaticResource ModernComboBox}" Text="-- Không lùi --" Foreground="#E53E3E" FontWeight="Bold" SelectionChanged="OnSalaryStructureChanged">
                                        <ComboBoxItem Content="-- Không lùi --"/>
                                        <ComboBoxItem Content="Lùi 3 tháng (Khiển trách)"/>
                                        <ComboBoxItem Content="Lùi 6 tháng (Cảnh cáo)"/>
                                        <ComboBoxItem Content="Lùi 12 tháng (Giáng chức/Cách chức)"/>
                                    </ComboBox>
                                    <Button Grid.Column="1" Click="btnSalaryDelayConfig_Click" Margin="5 0 0 0" Width="32" Height="32" Padding="0"
                                            Style="{DynamicResource MaterialDesignFloatingActionMiniButton}" 
                                            Background="{DynamicResource PrimaryHueMidBrush}" 
                                            BorderBrush="{DynamicResource PrimaryHueMidBrush}"
                                            ToolTip="Cấu hình lùi thời gian">
                                        <materialDesign:PackIcon Kind="Plus" Width="20" Height="20" Foreground="White"/>
                                    </Button>
                                </Grid>
                            </StackPanel>

                            <!-- Expected Date -->
                            <StackPanel Grid.Column="4">
                                <TextBlock Text="Dự kiến lên lương" Style="{StaticResource ModernLabel}"/>
                                <DatePicker x:Name="dpExpectedSalaryIncrease" Style="{StaticResource ModernDatePicker}" Foreground="#388E3C" FontWeight="Bold" PreviewKeyUp="DatePicker_PreviewKeyUp" DateValidationError="dpExpectedSalaryIncrease_DateValidationError"/>
                            </StackPanel>
                        </Grid>

                        <!-- Row 4: History Label -->
                        <StackPanel Grid.Row="3" Margin="0 0 0 5">
                            <TextBlock Text="Diễn biến quá trình lương" FontWeight="Bold" Foreground="{DynamicResource PrimaryHueMidBrush}"/>
                            <TextBlock Text="(Định dạng: Ngày tháng năm, hệ số, bậc)" Foreground="Gray" FontStyle="Italic" FontSize="11" Margin="0 2 0 0"/>
                        </StackPanel>

                        <Grid Grid.Row="4">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <!-- Inputs -->
                                <RowDefinition Height="Auto"/>
                                <!-- Label -->
                                <RowDefinition Height="*"/>
                                <!-- DataGrid -->
                            </Grid.RowDefinitions>

                            <!-- Input Section -->
                            <materialDesign:Card Padding="10" Margin="0 0 0 10" UniformCornerRadius="4">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="0.7*"/>
                                        <ColumnDefinition Width="0.7*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0" Margin="2">
                                        <TextBlock Text="Thời gian bắt đầu" FontSize="11" Foreground="Gray"/>
                                        <DatePicker x:Name="dpSalaryHistStart" Style="{StaticResource ModernDatePicker}" PreviewKeyUp="DatePicker_PreviewKeyUp"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Margin="2">
                                        <TextBlock Text="Thời gian kết thúc" FontSize="11" Foreground="Gray"/>
                                        <DatePicker x:Name="dpSalaryHistEnd" Style="{StaticResource ModernDatePicker}" PreviewKeyUp="DatePicker_PreviewKeyUp"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2" Margin="2">
                                        <TextBlock Text="Mốc xét lương từ" FontSize="11" Foreground="Gray"/>
                                        <DatePicker x:Name="dpSalaryHistCalc" Style="{StaticResource ModernDatePicker}" PreviewKeyUp="DatePicker_PreviewKeyUp"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="3" Margin="2">
                                        <TextBlock Text="Hệ số" FontSize="11" Foreground="Gray"/>
                                        <TextBox x:Name="txtSalaryHistCoeff" Style="{StaticResource ModernTextBox}" IsReadOnly="True" Background="#F5F5F5"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="4" Margin="2">
                                        <TextBlock Text="Phần trăm được hưởng" FontSize="11" Foreground="Gray"/>
                                        <TextBox x:Name="txtSalaryHistPercent" Style="{StaticResource ModernTextBox}" Text="100"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="5" Margin="2">
                                        <TextBlock Text="Số VB/QĐ" FontSize="11" Foreground="Gray"/>
                                        <TextBox x:Name="txtSalaryHistDecisionNo" Style="{StaticResource ModernTextBox}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="6" Margin="2">
                                        <TextBlock Text="Ngày ký QĐ" FontSize="11" Foreground="Gray"/>
                                        <DatePicker x:Name="dpSalaryHistDecisionDate" Style="{StaticResource ModernDatePicker}" PreviewKeyUp="DatePicker_PreviewKeyUp"/>
                                    </StackPanel>

                                    <Button Grid.Column="7" x:Name="btnAddSalaryHistory" Click="btnAddSalaryHistory_Click" 
                                            VerticalAlignment="Bottom" Margin="5 0 0 0" Padding="8 0" Height="32"
                                            Background="{DynamicResource PrimaryHueMidBrush}" BorderThickness="0">
                                        <materialDesign:PackIcon Kind="ArrowDownBold" Width="18" Height="18"/>
                                    </Button>
                                </Grid>
                            </materialDesign:Card>

                            <!-- DataGrid -->
                            <Border Grid.Row="2" CornerRadius="4" BorderThickness="1" BorderBrush="#E0E0E0" Background="White">
                                <DataGrid x:Name="dgSalaryHistory" AutoGenerateColumns="False" CanUserAddRows="False" 
                                          MaxHeight="300" MinHeight="150" VerticalScrollBarVisibility="Auto" 
                                          HeadersVisibility="Column" SelectionMode="Single"
                                          BorderThickness="0" Background="White"
                                          AlternatingRowBackground="#FAFAFA"
                                          GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#EEEEEE"
                                          VerticalGridLinesBrush="Transparent"
                                          PreviewMouseLeftButtonUp="dgSalaryHistory_PreviewMouseLeftButtonUp">
                                    
                                    <DataGrid.ColumnHeaderStyle>
                                        <Style TargetType="DataGridColumnHeader">
                                            <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                            <Setter Property="Padding" Value="10,5"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                            <Setter Property="Background" Value="#F8F9FA"/>
                                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                            <Setter Property="BorderBrush" Value="#E0E0E0"/>
                                            <Setter Property="ContentTemplate">
                                                <Setter.Value>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding}" TextWrapping="Wrap" TextAlignment="Center"/>
                                                    </DataTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </DataGrid.ColumnHeaderStyle>

                                    <DataGrid.RowStyle>
                                        <Style TargetType="DataGridRow" BasedOn="{StaticResource {x:Type DataGridRow}}">
                                            <Setter Property="Cursor" Value="Hand"/>
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#F5F5F5"/>
                                                </Trigger>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter Property="Background" Value="#E3F2FD"/>
                                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </DataGrid.RowStyle>

                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Thời gian bắt đầu" Binding="{Binding StartDate, StringFormat=dd/MM/yyyy}" Width="*">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                                    <Setter Property="TextWrapping" Value="Wrap"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Header="Thời gian kết thúc" Binding="{Binding EndDate, StringFormat=dd/MM/yyyy}" Width="*">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                                    <Setter Property="TextWrapping" Value="Wrap"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Header="Mốc xét lương từ" Binding="{Binding SalaryCalculationDate, StringFormat=dd/MM/yyyy}" Width="*">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                                    <Setter Property="TextWrapping" Value="Wrap"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Header="Hệ số" Binding="{Binding Coefficient}" Width="80">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                                    <Setter Property="TextWrapping" Value="Wrap"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Header="Phần trăm được hưởng" Binding="{Binding Percentage, StringFormat={}{0}%}" Width="150">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                                    <Setter Property="TextWrapping" Value="Wrap"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Header="Số VB/QĐ" Binding="{Binding DecisionNumber}" Width="*">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                                    <Setter Property="TextWrapping" Value="Wrap"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Header="Ngày ký QĐ" Binding="{Binding DecisionDate, StringFormat=dd/MM/yyyy}" Width="*">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                                    <Setter Property="TextWrapping" Value="Wrap"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>

                                        <!-- Delete Button Column -->
                                        <DataGridTemplateColumn Header="Xóa" Width="50">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <Button Click="btnDeleteSalaryHistory_Click"
                                                            ToolTip="Xóa dòng này"
                                                            Background="Transparent" BorderThickness="0"
                                                            Padding="2" Cursor="Hand">
                                                        <materialDesign:PackIcon Kind="DeleteOutline" Foreground="#E53935" Width="16" Height="16"/>
                                                    </Button>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Border>
                        </Grid>
                    </Grid>
                </ScrollViewer>
            </TabItem>


            <!-- Tab 7: Rewards -->
            <TabItem Header="7. Thông tin khen thưởng">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Grid Margin="20">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="30"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- 1. Emulation Titles -->
                        <StackPanel Grid.Row="0" Margin="0 0 0 5">
                            <TextBlock Text="1. Danh hiệu thi đua" FontWeight="Bold" Foreground="{DynamicResource PrimaryHueMidBrush}"/>
                            <TextBlock Text="(Nhập chi tiết các năm đạt danh hiệu...)" Foreground="Gray" FontStyle="Italic" FontSize="11" Margin="0 2 0 0"/>
                        </StackPanel>

                        <TextBox Grid.Row="1" x:Name="txtEmulationTitles" 
                                 Height="120" TextWrapping="Wrap" AcceptsReturn="True" VerticalContentAlignment="Top" Padding="10"
                                 BorderThickness="1" BorderBrush="#E2E8F0" Background="White"
                                 materialDesign:TextFieldAssist.DecorationVisibility="Hidden"/>

                        <!-- 2. Reward Forms -->
                        <StackPanel Grid.Row="3" Margin="0 0 0 5">
                            <TextBlock Text="2. Hình thức khen thưởng" FontWeight="Bold" Foreground="{DynamicResource PrimaryHueMidBrush}"/>
                            <TextBlock Text="(Nhập chi tiết các loại giấy khen, bằng khen...)" Foreground="Gray" FontStyle="Italic" FontSize="11" Margin="0 2 0 0"/>
                        </StackPanel>

                        <TextBox Grid.Row="4" x:Name="txtRewardForms" 
                                 Height="120" TextWrapping="Wrap" AcceptsReturn="True" VerticalContentAlignment="Top" Padding="10"
                                 BorderThickness="1" BorderBrush="#E2E8F0" Background="White"
                                 materialDesign:TextFieldAssist.DecorationVisibility="Hidden"/>
                    </Grid>
                </ScrollViewer>
            </TabItem>

            <!-- Tab 8: Discipline -->
            <TabItem Header="8. Kỷ luật">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Grid Margin="20">
                         <!-- Card Style Container -->
                        <Border Background="White" BorderBrush="#FFC107" BorderThickness="1" CornerRadius="4">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/> <!-- Header -->
                                    <RowDefinition Height="Auto"/> <!-- Inputs -->
                                    <RowDefinition Height="Auto"/> <!-- Content -->
                                    <RowDefinition Height="Auto"/> <!-- Note -->
                                </Grid.RowDefinitions>

                                <!-- Header -->
                                <Border Grid.Row="0" Background="#FFF8E1" CornerRadius="4 4 0 0" Padding="15 10">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="Gavel" Foreground="#D32F2F" Width="24" Height="24" VerticalAlignment="Center" Margin="0 0 10 0"/>
                                        <TextBlock Text="QUYẾT ĐỊNH KỶ LUẬT" Foreground="#D32F2F" FontWeight="Bold" FontSize="14" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>

                                <!-- Inputs Row 1 -->
                                <Grid Grid.Row="1" Margin="15 15 15 5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Discipline Type -->
                                    <StackPanel Grid.Column="0" Margin="0 0 10 0">
                                        <TextBlock Text="Hình thức kỷ luật" Foreground="Gray" FontSize="11" Margin="2 0 0 2"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <ComboBox x:Name="cboDisciplineType" Style="{StaticResource ModernComboBox}" 
                                                      materialDesign:HintAssist.Hint="-- Không có --" Foreground="#D32F2F" FontWeight="Bold"/>
                                            <Button Grid.Column="1" Click="btnAddDisciplineType_Click" Margin="5 0 0 0" Width="30" Height="30" Padding="0"
                                                    Style="{DynamicResource MaterialDesignToolButton}" Background="Transparent" BorderThickness="0"
                                                    Foreground="{DynamicResource PrimaryHueMidBrush}"
                                                    ToolTip="Quản lý Hình thức kỷ luật">
                                                <materialDesign:PackIcon Kind="Cog" Width="20" Height="20"/>
                                            </Button>
                                        </Grid>
                                    </StackPanel>

                                    <!-- Decision Number -->
                                    <StackPanel Grid.Column="2" Margin="10 0 10 0">
                                        <TextBlock Text="Số quyết định" Foreground="Gray" FontSize="11" Margin="2 0 0 2"/>
                                        <TextBox x:Name="txtDisciplineNumber" Padding="5"/>
                                    </StackPanel>

                                    <!-- Decision Date -->
                                    <StackPanel Grid.Column="3" Margin="0 0 0 0">
                                        <TextBlock Text="Ngày ký QĐ" Foreground="Gray" FontSize="11" Margin="2 0 0 2"/>
                                        <DatePicker x:Name="dpDisciplineDate" materialDesign:HintAssist.Hint="dd/mm/yyyy" Style="{StaticResource ModernDatePicker}"
                                                    PreviewKeyUp="DatePicker_PreviewKeyUp"/>
                                    </StackPanel>
                                </Grid>

                                <!-- Content Row 2 -->
                                <StackPanel Grid.Row="2" Margin="15 10 15 15">
                                    <TextBox x:Name="txtDisciplineReason" 
                                             materialDesign:HintAssist.Hint="Nội dung / Lý do kỷ luật"
                                             Height="100" TextWrapping="Wrap" AcceptsReturn="True" VerticalContentAlignment="Top" Padding="10"
                                             BorderThickness="1" BorderBrush="#2196F3" Background="White"
                                             materialDesign:TextFieldAssist.DecorationVisibility="Hidden"/>
                                </StackPanel>

                                <!-- Note Row 3 -->
                                <StackPanel Grid.Row="3" Margin="15 0 15 15" Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="Information" Width="16" Height="16" Foreground="#555" VerticalAlignment="Center" Margin="0 0 5 0"/>
                                    <TextBlock Text="Lưu ý: Nhập chính xác số quyết định để phục vụ công tác tra cứu hồ sơ gốc." FontStyle="Italic" FontSize="11" Foreground="#555" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>
                </ScrollViewer>
            </TabItem>
        </TabControl>

        <!-- Actions -->
        <Border Grid.Row="2" Background="White" BorderBrush="#E0E0E0" BorderThickness="0 1 0 0" Padding="20 15" Margin="-20 0 -20 -20">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="btnSave" Click="btnSave_Click" Height="40" Width="140"
                        Background="{DynamicResource PrimaryHueMidBrush}" BorderThickness="0" Foreground="White"
                        materialDesign:ButtonAssist.CornerRadius="6" Margin="0 0 15 0"
                        ToolTip="Lưu thông tin hồ sơ">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <materialDesign:PackIcon Kind="ContentSave" Width="20" Height="20" Margin="0 0 8 0"/>
                        <TextBlock x:Name="lblSaveText" Text="Lưu Hồ Sơ" VerticalAlignment="Center" FontWeight="Bold" FontSize="14"/>
                    </StackPanel>
                </Button>
                
                <Button x:Name="btnRefresh" Click="btnRefresh_Click" Height="40" Width="130"
                        Background="White" BorderBrush="#D0D0D0" BorderThickness="1" Foreground="#555"
                        materialDesign:ButtonAssist.CornerRadius="6"
                        ToolTip="Làm mới dữ liệu">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <materialDesign:PackIcon Kind="Refresh" Width="20" Height="20" Margin="0 0 8 0"/>
                        <TextBlock Text="Làm mới" VerticalAlignment="Center" FontWeight="SemiBold"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
