<Window x:Class="TaxPersonnelManagement.Views.UserEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Quản lý tài khoản" Height="560" Width="450"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        FontFamily="{DynamicResource MaterialDesignFont}"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        TextElement.FontSize="14" TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        UseLayoutRounding="True" SnapsToDevicePixels="True">

    <Border Background="White" CornerRadius="12" BorderThickness="1" BorderBrush="#E0E0E0">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="5" Opacity="0.2"/>
        </Border.Effect>
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0 0 0 20">
                <materialDesign:PackIcon Kind="AccountEdit" Width="28" Height="28" Foreground="{DynamicResource PrimaryHueMidBrush}" VerticalAlignment="Center"/>
                <TextBlock x:Name="txtTitle" Text="THÊM MỚI TÀI KHOẢN" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource PrimaryHueMidBrush}" Margin="10 0 0 0" VerticalAlignment="Center"/>
            </StackPanel>
            
            <Separator Grid.Row="1" Margin="-20 0 -20 20" Background="#EEEEEE"/>

            <!-- Form -->
            <StackPanel Grid.Row="2" VerticalAlignment="Center">
                <TextBlock Style="{StaticResource ModernLabel}" Text="Tên đăng nhập" />
                <TextBox x:Name="txtUsername" Style="{StaticResource ModernTextBox}" Margin="0 0 0 15" />

                <TextBlock Style="{StaticResource ModernLabel}" Text="Họ tên hiển thị" />
                <TextBox x:Name="txtFullName" Style="{StaticResource ModernTextBox}" Margin="0 0 0 15" />

                <TextBlock Style="{StaticResource ModernLabel}" Text="Phân quyền" />
                <ComboBox x:Name="cboRole" Style="{StaticResource ModernComboBox}" Margin="0 0 0 15"
                          TextSearch.TextPath="Value" DisplayMemberPath="Value" SelectedValuePath="Key">
                </ComboBox>

                <TextBlock x:Name="txtPasswordLabel" Style="{StaticResource ModernLabel}" Text="Mật khẩu" />
                <PasswordBox x:Name="pwdPassword" Style="{StaticResource ModernPasswordBox}" Margin="0 0 0 5"
                             x:FieldModifier="public"/>
                             
                <TextBlock x:Name="txtPasswordHint" Text="Để trống nếu không đổi mật khẩu" 
                           FontSize="12" Foreground="Gray" FontStyle="Italic" Visibility="Collapsed" Margin="5 0 0 0"/>
            </StackPanel>

            <!-- Action Buttons -->
            <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0 25 0 0">
                <Button Content="Hủy" Width="100" Margin="0 0 10 0" Click="BtnCancel_Click"
                        Background="White" Foreground="#424242" BorderBrush="#B0BEC5" BorderThickness="1" materialDesign:ButtonAssist.CornerRadius="18"/>
                <Button x:Name="btnSave" Content="Lưu" Width="100" Click="BtnSave_Click"
                        Background="#1976D2" Foreground="White" BorderBrush="#1976D2" BorderThickness="1" materialDesign:ButtonAssist.CornerRadius="18"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
