<UserControl x:Class="TaxPersonnelManagement.Views.EvaluationListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:converters="clr-namespace:TaxPersonnelManagement.Converters"
             xmlns:helpers="clr-namespace:TaxPersonnelManagement.Helpers"
             Language="vi-VN"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="1200">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesignTheme.Defaults.xaml" />
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesignTheme.ComboBox.xaml" />
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesignTheme.Shadows.xaml" />
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesignTheme.Button.xaml" />
            </ResourceDictionary.MergedDictionaries>
            
            <converters:DateFormatterConverter x:Key="DateFormatterConverter"/>
            <converters:Base64ToImageConverter x:Key="Base64ToImageConverter"/>
            <converters:NameToInitialsConverter x:Key="NameToInitialsConverter"/>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/> <!-- KPIs -->
            <RowDefinition Height="Auto"/> <!-- Filters -->
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Loading Overlay -->
        <Grid x:Name="LoadingOverlay" Grid.RowSpan="4" Visibility="Collapsed" Panel.ZIndex="1000">
            <Border Background="Black" Opacity="0.15"/>
            <materialDesign:Card UniformCornerRadius="10" Width="220" Height="140" materialDesign:ElevationAssist.Elevation="Dp6" VerticalAlignment="Center" HorizontalAlignment="Center">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <ProgressBar Style="{StaticResource MaterialDesignCircularProgressBar}" 
                                 Value="0" IsIndeterminate="True" 
                                 Width="40" Height="40" 
                                 Foreground="#2563EB" Margin="0 0 0 15"/>
                    <TextBlock Text="Đang xử lý dữ liệu..." FontSize="14" FontWeight="SemiBold" Foreground="#0F172A" HorizontalAlignment="Center"/>
                    <TextBlock Text="Vui lòng chờ trong giây lát" FontSize="11.5" Foreground="#64748B" HorizontalAlignment="Center" Margin="0 5 0 0"/>
                </StackPanel>
            </materialDesign:Card>
        </Grid>

        <StackPanel Orientation="Horizontal" Margin="0 0 0 24">
            <Border Background="#EFF6FF" CornerRadius="8" Padding="10" Margin="0 0 16 0">
                <materialDesign:PackIcon Kind="Certificate" Width="26" Height="26" Foreground="#2563EB" VerticalAlignment="Center"/>
            </Border>
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="THEO DÕI XẾP LOẠI CÔNG CHỨC" FontSize="20" FontWeight="Bold" Foreground="#0F172A"/>
                <TextBlock Text="Quản lý, tìm kiếm và xuất báo cáo lịch sử xếp loại thi đua cán bộ hàng năm" FontSize="12.5" Foreground="#64748B" Margin="0 4 0 0"/>
            </StackPanel>
        </StackPanel>

        <!-- KPIs Section -->
        <WrapPanel x:Name="wpKPIRow" Grid.Row="1" Margin="0 0 0 10" Orientation="Horizontal" HorizontalAlignment="Left">
            <!-- Card 1: Total Cán bộ -->
            <materialDesign:Card x:Name="cardTotal" MinWidth="220" MaxWidth="300" Width="260" Height="100" Margin="0 0 15 15" UniformCornerRadius="12" materialDesign:ElevationAssist.Elevation="Dp3" Cursor="Hand" MouseLeftButtonUp="cardTotal_Click">
                <Grid>
                    <Grid.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#0078D4" Offset="0.0"/>
                            <GradientStop Color="#00B7C3" Offset="1.0"/>
                        </LinearGradientBrush>
                    </Grid.Background>
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <materialDesign:PackIcon x:Name="iconTotal" Kind="AccountGroup" Width="30" Height="30" Foreground="White" HorizontalAlignment="Center" Margin="0 0 0 5"/>
                        <TextBlock x:Name="lblTotal" Text="TỔNG SỐ CÁN BỘ" FontSize="13" FontWeight="SemiBold" Foreground="White" HorizontalAlignment="Center" Opacity="0.9"/>
                        <TextBlock x:Name="txtTotalCount" Text="0" FontSize="26" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Grid>
                <materialDesign:Card.Style>
                    <Style TargetType="materialDesign:Card">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsCompact, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="True">
                                <Setter Property="Height" Value="65"/>
                                <Setter Property="Width" Value="200"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </materialDesign:Card.Style>
            </materialDesign:Card>

            <!-- Card 2: Xuất sắc -->
            <materialDesign:Card x:Name="cardExcellent" MinWidth="220" MaxWidth="300" Width="260" Height="100" Margin="0 0 15 15" UniformCornerRadius="12" materialDesign:ElevationAssist.Elevation="Dp3" Cursor="Hand" MouseLeftButtonUp="cardExcellent_Click">
                <Grid>
                    <Grid.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#D4AF37" Offset="0.0"/>
                            <GradientStop Color="#F4D03F" Offset="1.0"/>
                        </LinearGradientBrush>
                    </Grid.Background>
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <StackPanel x:Name="iconExcellent" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0 0 0 5">
                            <materialDesign:PackIcon Kind="Star" Width="20" Height="20" Foreground="White"/>
                            <materialDesign:PackIcon Kind="Star" Width="24" Height="24" Foreground="White" Margin="2 -4 2 0"/>
                            <materialDesign:PackIcon Kind="Star" Width="20" Height="20" Foreground="White"/>
                        </StackPanel>
                        <TextBlock x:Name="lblExcellent" Text="XUẤT SẮC" FontSize="13" FontWeight="SemiBold" Foreground="White" HorizontalAlignment="Center" Opacity="0.9"/>
                        <TextBlock x:Name="txtExcellentCount" Text="0 (0%)" FontSize="26" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Grid>
                <materialDesign:Card.Style>
                    <Style TargetType="materialDesign:Card">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsCompact, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="True">
                                <Setter Property="Height" Value="65"/>
                                <Setter Property="Width" Value="200"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </materialDesign:Card.Style>
            </materialDesign:Card>

            <!-- Card 3: Hoàn thành tốt nhiệm vụ -->
            <materialDesign:Card x:Name="cardGood" MinWidth="220" MaxWidth="300" Width="260" Height="100" Margin="0 0 15 15" UniformCornerRadius="12" materialDesign:ElevationAssist.Elevation="Dp3" Cursor="Hand" MouseLeftButtonUp="cardGood_Click">
                <Grid>
                    <Grid.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#2E7D32" Offset="0.0"/>
                            <GradientStop Color="#4CAF50" Offset="1.0"/>
                        </LinearGradientBrush>
                    </Grid.Background>
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <StackPanel x:Name="iconGood" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0 0 0 5">
                            <materialDesign:PackIcon Kind="Circle" Width="12" Height="12" Foreground="White" Margin="2 0"/>
                            <materialDesign:PackIcon Kind="Circle" Width="12" Height="12" Foreground="White" Margin="2 0"/>
                            <materialDesign:PackIcon Kind="Circle" Width="12" Height="12" Foreground="White" Margin="2 0"/>
                        </StackPanel>
                        <TextBlock x:Name="lblGood" Text="HOÀN THÀNH TỐT NHIỆM VỤ" FontSize="13" FontWeight="SemiBold" Foreground="White" HorizontalAlignment="Center" Opacity="0.9"/>
                        <TextBlock x:Name="txtGoodCount" Text="0 (0%)" FontSize="26" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Grid>
                <materialDesign:Card.Style>
                    <Style TargetType="materialDesign:Card">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsCompact, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="True">
                                <Setter Property="Height" Value="65"/>
                                <Setter Property="Width" Value="200"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </materialDesign:Card.Style>
            </materialDesign:Card>

            <!-- Card 4: Hoàn thành nhiệm vụ -->
            <materialDesign:Card x:Name="cardSatisfactory" MinWidth="220" MaxWidth="300" Width="260" Height="100" Margin="0 0 15 15" UniformCornerRadius="12" materialDesign:ElevationAssist.Elevation="Dp3" Cursor="Hand" MouseLeftButtonUp="cardSatisfactory_Click">
                <Grid>
                    <Grid.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#D84315" Offset="0.0"/>
                            <GradientStop Color="#FF8A65" Offset="1.0"/>
                        </LinearGradientBrush>
                    </Grid.Background>
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <StackPanel x:Name="iconSatisfactory" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0 0 0 5">
                            <materialDesign:PackIcon Kind="Circle" Width="12" Height="12" Foreground="White" Margin="2 0" Opacity="1.0"/>
                            <materialDesign:PackIcon Kind="Circle" Width="12" Height="12" Foreground="White" Margin="2 0" Opacity="0.6"/>
                            <materialDesign:PackIcon Kind="Circle" Width="12" Height="12" Foreground="White" Margin="2 0" Opacity="0.3"/>
                        </StackPanel>
                        <TextBlock x:Name="lblSatisfactory" Text="HOÀN THÀNH NHIỆM VỤ" FontSize="13" FontWeight="SemiBold" Foreground="White" HorizontalAlignment="Center" Opacity="0.9"/>
                        <TextBlock x:Name="txtSatisfactoryCount" Text="0 (0%)" FontSize="26" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Grid>
                <materialDesign:Card.Style>
                    <Style TargetType="materialDesign:Card">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsCompact, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="True">
                                <Setter Property="Height" Value="65"/>
                                <Setter Property="Width" Value="200"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </materialDesign:Card.Style>
            </materialDesign:Card>

            <!-- Card 5: Không hoàn thành nhiệm vụ -->
            <materialDesign:Card x:Name="cardUnsatisfactory" MinWidth="220" MaxWidth="300" Width="260" Height="100" Margin="0 0 15 15" UniformCornerRadius="12" materialDesign:ElevationAssist.Elevation="Dp3" Cursor="Hand" MouseLeftButtonUp="cardUnsatisfactory_Click">
                <Grid>
                    <Grid.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#D32F2F" Offset="0.0"/>
                            <GradientStop Color="#EF5350" Offset="1.0"/>
                        </LinearGradientBrush>
                    </Grid.Background>
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <materialDesign:PackIcon x:Name="iconUnsatisfactory" Kind="AlertCircle" Width="30" Height="30" Foreground="White" HorizontalAlignment="Center" Margin="0 0 0 5"/>
                        <TextBlock x:Name="lblUnsatisfactory" Text="KHÔNG HOÀN THÀNH NHIỆM VỤ" FontSize="13" FontWeight="SemiBold" Foreground="White" HorizontalAlignment="Center" Opacity="0.9"/>
                        <TextBlock x:Name="txtUnsatisfactoryCount" Text="0 (0%)" FontSize="26" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Grid>
                <materialDesign:Card.Style>
                    <Style TargetType="materialDesign:Card">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsCompact, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="True">
                                <Setter Property="Height" Value="65"/>
                                <Setter Property="Width" Value="200"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </materialDesign:Card.Style>
            </materialDesign:Card>
        </WrapPanel>

        <!-- Filter Toolbar Card -->
        <materialDesign:Card Grid.Row="2" Margin="0 0 0 20" Padding="16" UniformCornerRadius="12" Background="White" BorderBrush="#E2E8F0" BorderThickness="1" Effect="{x:Null}">
            <WrapPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0">
                <!-- Group 1: Filters -->
                <StackPanel Orientation="Horizontal" Margin="0 0 16 10" VerticalAlignment="Center">
                    <!-- Search Box -->
                    <Border Background="#F8FAFC" CornerRadius="8" BorderBrush="#E2E8F0" BorderThickness="1" Width="240" Height="40" Margin="0 0 12 0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <materialDesign:PackIcon Kind="Magnify" Width="20" Height="20" Foreground="#64748B" VerticalAlignment="Center" Margin="12 0 8 0" Grid.Column="0"/>
                            <TextBox x:Name="txtSearch" Grid.Column="1"
                                     materialDesign:HintAssist.Hint="Tìm kiếm họ tên, CCCD..." 
                                     materialDesign:HintAssist.Foreground="#94A3B8"
                                     materialDesign:TextFieldAssist.DecorationVisibility="Hidden"
                                     BorderThickness="0" Background="Transparent"
                                     VerticalContentAlignment="Center" Padding="0 0 8 0"
                                     FontSize="13" Foreground="#0F172A"
                                     TextChanged="txtSearch_TextChanged"/>
                        </Grid>
                    </Border>

                    <!-- Department Filter -->
                    <Border Background="#F8FAFC" CornerRadius="8" BorderBrush="#E2E8F0" BorderThickness="1" Width="300" Height="40" Margin="0 0 12 0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <materialDesign:PackIcon Kind="Domain" Width="20" Height="20" Foreground="#64748B" VerticalAlignment="Center" Margin="12 0 4 0"/>
                            <ComboBox x:Name="cbDepartment" Grid.Column="1"
                                      materialDesign:HintAssist.Hint="Tất cả bộ phận"
                                      Style="{DynamicResource MaterialDesignComboBox}"
                                      materialDesign:TextFieldAssist.DecorationVisibility="Hidden"
                                      BorderThickness="0" Background="Transparent"
                                      VerticalAlignment="Center"
                                      VerticalContentAlignment="Center"
                                      Padding="6 0 24 0"
                                      FontSize="13" Foreground="#0F172A"
                                      SelectionChanged="cbFilter_SelectionChanged">
                            </ComboBox>
                        </Grid>
                    </Border>

                    <!-- Year Filter -->
                    <Border Background="#F8FAFC" CornerRadius="8" BorderBrush="#E2E8F0" BorderThickness="1" Width="200" Height="40" Margin="0 0 12 0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <materialDesign:PackIcon Kind="CalendarRange" Width="20" Height="20" Foreground="#64748B" VerticalAlignment="Center" Margin="12 0 4 0"/>
                            <ComboBox x:Name="cbYear" Grid.Column="1"
                                       materialDesign:HintAssist.Hint="Tất cả các năm"
                                       Style="{DynamicResource MaterialDesignComboBox}"
                                       materialDesign:TextFieldAssist.DecorationVisibility="Hidden"
                                       BorderThickness="0" Background="Transparent"
                                       VerticalAlignment="Center"
                                       VerticalContentAlignment="Center"
                                       Padding="6 0 24 0"
                                       FontSize="13" Foreground="#0F172A"
                                       SelectionChanged="cbFilter_SelectionChanged">
                            </ComboBox>
                        </Grid>
                    </Border>

                    <!-- Rating Filter -->
                    <Border Background="#F8FAFC" CornerRadius="8" BorderBrush="#E2E8F0" BorderThickness="1" Width="240" Height="40">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <materialDesign:PackIcon Kind="StarOutline" Width="20" Height="20" Foreground="#64748B" VerticalAlignment="Center" Margin="12 0 4 0"/>
                            <ComboBox x:Name="cbRating" Grid.Column="1"
                                       materialDesign:HintAssist.Hint="Tất cả xếp loại"
                                       Style="{DynamicResource MaterialDesignComboBox}"
                                       materialDesign:TextFieldAssist.DecorationVisibility="Hidden"
                                       BorderThickness="0" Background="Transparent"
                                       VerticalAlignment="Center"
                                       VerticalContentAlignment="Center"
                                       Padding="6 0 24 0"
                                       FontSize="13" Foreground="#0F172A"
                                       SelectionChanged="cbFilter_SelectionChanged">
                            </ComboBox>
                        </Grid>
                    </Border>
                </StackPanel>

                <!-- Group 2: Actions -->
                <StackPanel Orientation="Horizontal" Margin="0 0 0 10" VerticalAlignment="Center">
                    <!-- Import Button -->
                    <Button Height="40" Margin="0 0 8 0"
                            Style="{DynamicResource MaterialDesignRaisedButton}"
                            materialDesign:ButtonAssist.CornerRadius="8"
                            Background="#2563EB" BorderThickness="0" Foreground="White"
                            ToolTip="Nhập danh sách xếp loại từ file Excel"
                            Click="btnImport_Click"
                            VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Upload" VerticalAlignment="Center" Margin="0 0 8 0" Width="18" Height="18"/>
                            <TextBlock Text="Nhập Excel" VerticalAlignment="Center" FontWeight="SemiBold" FontSize="13"/>
                        </StackPanel>
                    </Button>

                    <!-- Bulk Decision Button -->
                    <Button Height="40" Margin="0 0 8 0"
                            Style="{DynamicResource MaterialDesignRaisedButton}"
                            materialDesign:ButtonAssist.CornerRadius="8"
                            Background="#7B1FA2" BorderThickness="0" Foreground="White"
                            ToolTip="Cập nhật quyết định khen thưởng xếp loại hàng loạt cho các nhân sự trong năm"
                            Click="btnBulkDecision_Click"
                            VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="ClipboardEditOutline" VerticalAlignment="Center" Margin="0 0 8 0" Width="18" Height="18"/>
                            <TextBlock Text="Quyết định hàng loạt" VerticalAlignment="Center" FontWeight="SemiBold" FontSize="13"/>
                        </StackPanel>
                    </Button>

                    <!-- Export Button -->
                    <Button Height="40" Margin="0 0 0 0"
                            Style="{DynamicResource MaterialDesignRaisedButton}"
                            materialDesign:ButtonAssist.CornerRadius="8"
                            Background="#107C41" BorderThickness="0" Foreground="White"
                            ToolTip="Xuất danh sách xếp loại ra file Excel"
                            Click="btnExport_Click"
                            VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="FileExcel" VerticalAlignment="Center" Margin="0 0 8 0" Width="18" Height="18"/>
                            <TextBlock Text="Xuất Excel" VerticalAlignment="Center" FontWeight="SemiBold" FontSize="13"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </WrapPanel>
        </materialDesign:Card>

        <!-- Data Grid Card -->
        <materialDesign:Card Grid.Row="3" UniformCornerRadius="12" Background="White" BorderBrush="#E2E8F0" BorderThickness="1" Effect="{x:Null}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <DataGrid x:Name="dgEvaluation" Grid.Row="0" AutoGenerateColumns="False" IsReadOnly="False" 
                          CellEditEnding="dgEvaluation_CellEditEnding"
                          CanUserAddRows="False" HeadersVisibility="Column"
                          BorderThickness="0" VerticalGridLinesBrush="Transparent" HorizontalGridLinesBrush="#F1F5F9"
                          GridLinesVisibility="Horizontal" 
                          AlternationCount="2" AlternatingRowBackground="#F8FAFC"
                          MinRowHeight="56" VerticalContentAlignment="Center"
                          SelectionMode="Single"
                          ScrollViewer.HorizontalScrollBarVisibility="Auto">
                    <DataGrid.Resources>
                        <!-- Column Header Style -->
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="FontSize" Value="13"/>
                            <Setter Property="Foreground" Value="#475569"/>
                            <Setter Property="HorizontalContentAlignment" Value="Center"/>
                            <Setter Property="VerticalContentAlignment" Value="Center"/>
                            <Setter Property="Padding" Value="8 12"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="DataGridColumnHeader">
                                        <Border Background="#F1F5F9" BorderBrush="#E2E8F0" BorderThickness="0 0 0 1" Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" 
                                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                                              RecognizesAccessKey="True"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>

                        <!-- Cell Style -->
                        <Style TargetType="DataGridCell">
                            <Setter Property="TextBlock.TextAlignment" Value="Center"/>
                            <Setter Property="FontSize" Value="13"/>
                            <Setter Property="Padding" Value="8 6"/>
                            <Setter Property="Foreground" Value="#1E293B"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="{x:Type DataGridCell}">
                                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" SnapsToDevicePixels="True" Padding="{TemplateBinding Padding}">
                                            <ContentPresenter SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <EventSetter Event="PreviewMouseLeftButtonDown" Handler="DataGridCell_PreviewMouseLeftButtonDown"/>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#EFF6FF"/>
                                    <Setter Property="Foreground" Value="#1D4ED8"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>

                        <!-- Grid Row Style -->
                        <Style TargetType="DataGridRow">
                            <Setter Property="Background" Value="Transparent"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#F1F5F9"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>

                        <Style x:Key="CenterAlignedColumn" TargetType="TextBlock">
                             <Setter Property="HorizontalAlignment" Value="Center"/>
                             <Setter Property="VerticalAlignment" Value="Center"/>
                             <Setter Property="TextWrapping" Value="Wrap"/>
                             <Setter Property="FontSize" Value="13"/>
                             <Setter Property="Foreground" Value="#334155"/>
                        </Style>

                        <Style x:Key="WrappedHeaderStyle" TargetType="DataGridColumnHeader" BasedOn="{StaticResource {x:Type DataGridColumnHeader}}">
                             <Setter Property="MinHeight" Value="54"/>
                             <Setter Property="ContentTemplate">
                                 <Setter.Value>
                                     <DataTemplate>
                                         <TextBlock Text="{Binding}" TextWrapping="Wrap" TextAlignment="Center" HorizontalAlignment="Center" Padding="2"/>
                                     </DataTemplate>
                                 </Setter.Value>
                             </Setter>
                        </Style>
                    </DataGrid.Resources>
                    
                    <DataGrid.Columns>
                        <!-- STT -->
                        <DataGridTemplateColumn Header="STT" IsReadOnly="True" Width="60" HeaderStyle="{StaticResource WrappedHeaderStyle}">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding STT}" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="#64748B"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        
                        <!-- Năm áp dụng -->
                        <DataGridTemplateColumn Header="NĂM" IsReadOnly="True" Width="90" HeaderStyle="{StaticResource WrappedHeaderStyle}">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Year}" Style="{StaticResource CenterAlignedColumn}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- Họ và Tên -->
                        <DataGridTemplateColumn Header="HỌ VÀ TÊN" IsReadOnly="True" Width="220" HeaderStyle="{StaticResource WrappedHeaderStyle}">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="8 0">
                                        <!-- Avatar circle -->
                                        <Grid Width="34" Height="34" Margin="0 0 10 0" VerticalAlignment="Center">
                                            <Ellipse Fill="#DBEAFE"/>
                                            <TextBlock Text="{Binding Personnel.FullName, Converter={StaticResource NameToInitialsConverter}}"
                                                       Foreground="#1E40AF" FontWeight="Bold" FontSize="12.5"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            <Ellipse>
                                                <Ellipse.Fill>
                                                    <ImageBrush ImageSource="{Binding Personnel.AvatarBase64, Converter={StaticResource Base64ToImageConverter}}" Stretch="UniformToFill"/>
                                                </Ellipse.Fill>
                                                <Ellipse.Style>
                                                    <Style TargetType="Ellipse">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Personnel.AvatarBase64}" Value="{x:Null}">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Personnel.AvatarBase64}" Value="">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Ellipse.Style>
                                            </Ellipse>
                                        </Grid>
                                        <TextBlock Text="{Binding Personnel.FullName}" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="#0F172A" TextWrapping="Wrap" FontSize="13"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- Số CCCD -->
                        <DataGridTextColumn Header="SỐ CCCD" IsReadOnly="True" Binding="{Binding Personnel.IdentityCardNumber}" Width="130" ElementStyle="{StaticResource CenterAlignedColumn}" HeaderStyle="{StaticResource WrappedHeaderStyle}"/>

                        <!-- Bộ phận -->
                        <DataGridTemplateColumn Header="BỘ PHẬN" IsReadOnly="True" Width="180" HeaderStyle="{StaticResource WrappedHeaderStyle}">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0 4">
                                        <Border Background="#E3F2FD" CornerRadius="5" Padding="8 3" HorizontalAlignment="Center" Margin="0 0 0 4">
                                            <TextBlock Text="{Binding Personnel.Department}" FontSize="13" FontWeight="SemiBold" Foreground="#1565C0" TextWrapping="Wrap" TextAlignment="Center"/>
                                        </Border>
                                        <TextBlock Text="{Binding Personnel.Position}" FontSize="12.5" Foreground="#37474F" TextWrapping="Wrap" TextAlignment="Center"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- Xếp loại -->
                        <DataGridTemplateColumn Header="XẾP LOẠI" IsReadOnly="True" Width="240" HeaderStyle="{StaticResource WrappedHeaderStyle}">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border x:Name="brdRating" Background="#F1F5F9" CornerRadius="6" Padding="10 6" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0 4">
                                        <TextBlock x:Name="txtRatingText" Text="{Binding Rating}" Foreground="#475569" FontWeight="SemiBold" TextWrapping="Wrap" TextAlignment="Center" FontSize="12.5"/>
                                    </Border>
                                    <DataTemplate.Triggers>
                                        <DataTrigger Binding="{Binding Rating}" Value="Hoàn thành xuất sắc nhiệm vụ">
                                            <Setter TargetName="brdRating" Property="Background" Value="#DCFCE7"/>
                                            <Setter TargetName="txtRatingText" Property="Foreground" Value="#15803D"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Rating}" Value="Hoàn thành tốt nhiệm vụ">
                                            <Setter TargetName="brdRating" Property="Background" Value="#DBEAFE"/>
                                            <Setter TargetName="txtRatingText" Property="Foreground" Value="#1D4ED8"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Rating}" Value="Hoàn thành nhiệm vụ">
                                            <Setter TargetName="brdRating" Property="Background" Value="#FEF3C7"/>
                                            <Setter TargetName="txtRatingText" Property="Foreground" Value="#D97706"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Rating}" Value="Không hoàn thành nhiệm vụ">
                                            <Setter TargetName="brdRating" Property="Background" Value="#FEE2E2"/>
                                            <Setter TargetName="txtRatingText" Property="Foreground" Value="#DC2626"/>
                                        </DataTrigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- Số QĐ -->
                        <DataGridTextColumn Header="SỐ QĐ" Binding="{Binding DecisionNumber}" Width="120" ElementStyle="{StaticResource CenterAlignedColumn}" HeaderStyle="{StaticResource WrappedHeaderStyle}"/>

                        <!-- Ngày ký QĐ -->
                        <DataGridTemplateColumn Header="NGÀY KÝ QĐ" Width="150" HeaderStyle="{StaticResource WrappedHeaderStyle}">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding DecisionDate, Converter={StaticResource DateFormatterConverter}}" Style="{StaticResource CenterAlignedColumn}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                            <DataGridTemplateColumn.CellEditingTemplate>
                                <DataTemplate>
                                    <DatePicker SelectedDate="{Binding DecisionDate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                Style="{DynamicResource MaterialDesignOutlinedDatePicker}"
                                                helpers:DatePickerHelper.FixCalendarLocale="True"
                                                helpers:DatePickerHelper.EnableSmartDateEntry="True"
                                                Loaded="DatePicker_Loaded"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellEditingTemplate>
                        </DataGridTemplateColumn>

                        <!-- Đơn vị ra QĐ -->
                        <DataGridTextColumn Header="ĐƠN VỊ RA QĐ" Binding="{Binding DecisionAgency}" Width="*" MinWidth="180" ElementStyle="{StaticResource CenterAlignedColumn}" HeaderStyle="{StaticResource WrappedHeaderStyle}"/>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Pagination Footer -->
                <Grid Grid.Row="1" Margin="16 12">
                    <TextBlock x:Name="txtPagingInfo" Text="Hiển thị 0 bản ghi xếp loại" VerticalAlignment="Center" Foreground="#64748B" FontSize="12.5" FontWeight="Medium"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button x:Name="btnPrevPage" Click="BtnPrevPage_Click" 
                                Style="{DynamicResource MaterialDesignOutlinedButton}" Width="36" Height="36" Margin="0 0 8 0" Padding="0" BorderBrush="#E2E8F0" Background="White">
                            <materialDesign:PackIcon Kind="ChevronLeft" Foreground="#64748B" Width="20" Height="20"/>
                        </Button>
                        <Border BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="6" Height="36" Background="#F8FAFC" Padding="12 0" Margin="0 0 8 0">
                            <TextBlock x:Name="txtPageInfo" Text="1 / 1" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="#0F172A" FontSize="12.5"/>
                        </Border>
                        <Button x:Name="btnNextPage" Click="BtnNextPage_Click" 
                                Style="{DynamicResource MaterialDesignOutlinedButton}" Width="36" Height="36" Padding="0" BorderBrush="#E2E8F0" Background="White">
                            <materialDesign:PackIcon Kind="ChevronRight" Foreground="#64748B" Width="20" Height="20"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Grid>
        </materialDesign:Card>
    </Grid>
</UserControl>
