<Window x:Class="TaxPersonnelManagement.Views.AddRankDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Quản lý Mã ngạch" Height="500" Width="550" WindowStartupLocation="CenterScreen" ResizeMode="NoResize" WindowStyle="None" Background="Transparent" AllowsTransparency="True">

    <Border Background="White" CornerRadius="16" BorderThickness="0">
        <Border.Effect>
            <DropShadowEffect BlurRadius="30" ShadowDepth="10" Opacity="0.15" Color="#000"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- Header -->
                <RowDefinition Height="Auto"/> <!-- Input -->
                <RowDefinition Height="*"/>    <!-- List -->
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0" Margin="25 25 25 15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="5" Height="24" CornerRadius="2.5" Background="{DynamicResource PrimaryHueMidBrush}" Margin="0 0 12 0"/>
                    <TextBlock Text="Quản lý Mã ngạch" FontSize="22" FontWeight="Bold" Foreground="#2D3748" VerticalAlignment="Center"/>
                </StackPanel>
                
                <Button Grid.Column="1" Click="btnClose_Click" Style="{DynamicResource MaterialDesignIconForegroundButton}" Width="32" Height="32" Foreground="#A0AEC0" ToolTip="Đóng">
                    <materialDesign:PackIcon Kind="Close" Width="20" Height="20"/>
                </Button>
            </Grid>
            
            <!-- Input Section -->
            <Grid Grid.Row="1" Margin="25 5 25 20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                     <RowDefinition Height="Auto"/>
                     <RowDefinition Height="15"/>
                     <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <!-- Inputs -->
                <Border Grid.Row="0" Grid.Column="0" CornerRadius="8" Background="#F7FAFC" BorderThickness="1" BorderBrush="#E2E8F0" Height="42">
                    <Grid>
                        <TextBox x:Name="txtCode" 
                                 materialDesign:TextFieldAssist.DecorationVisibility="Hidden"
                                 BorderThickness="0" 
                                 VerticalAlignment="Center"
                                 Padding="10 0"
                                 FontSize="14"
                                 Foreground="#4A5568"
                                 Background="Transparent"/>
                        <TextBlock Text="Mã (01.003)" IsHitTestVisible="False" VerticalAlignment="Center" Margin="12 0" Foreground="#A0AEC0">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Text, ElementName=txtCode}" Value="">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Text, ElementName=txtCode}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                </Border>

                <Border Grid.Row="0" Grid.Column="2" CornerRadius="8" Background="#F7FAFC" BorderThickness="1" BorderBrush="#E2E8F0" Height="42">
                    <Grid>
                        <TextBox x:Name="txtName" 
                                 materialDesign:TextFieldAssist.DecorationVisibility="Hidden"
                                 BorderThickness="0" 
                                 VerticalAlignment="Center"
                                 Padding="10 0"
                                 FontSize="14"
                                 Foreground="#4A5568"
                                 Background="Transparent"/>
                        <TextBlock Text="Tên ngạch..." IsHitTestVisible="False" VerticalAlignment="Center" Margin="12 0" Foreground="#A0AEC0">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Text, ElementName=txtName}" Value="">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Text, ElementName=txtName}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                </Border>

                <!-- Add Button -->
                <Button Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3" x:Name="btnAdd" Click="btnAdd_Click" Height="42" 
                        Background="{DynamicResource PrimaryHueMidBrush}" BorderThickness="0" 
                        materialDesign:ButtonAssist.CornerRadius="8" FontSize="14" FontWeight="SemiBold">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Floppy" Margin="0 0 8 0" VerticalAlignment="Center"/>
                        <TextBlock Text="Thêm mới" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </Grid>

            <!-- List Section -->
            <Border Grid.Row="2" BorderThickness="0 1 0 0" BorderBrush="#EDF2F7" Background="#FAFAFA" CornerRadius="0 0 16 16" ClipToBounds="True">
                <ScrollViewer Margin="0" VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="lstRanks">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="White" BorderThickness="0 0 0 1" BorderBrush="#EDF2F7" Padding="20 15">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Code}" FontWeight="Bold" Foreground="{DynamicResource PrimaryHueMidBrush}" FontSize="15" Margin="0 0 0 4"/>
                                            <TextBlock Text="{Binding Name}" Foreground="#718096" FontSize="13" TextWrapping="Wrap"/>
                                        </StackPanel>
                                        
                                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                            <Button Tag="{Binding}" Click="btnEdit_Click" 
                                                    Width="32" Height="32" Padding="0" Margin="0 0 4 0" ToolTip="Sửa"
                                                    Background="Transparent" BorderThickness="0">
                                                <materialDesign:PackIcon Kind="Pencil" Foreground="#1976D2" Width="20" Height="20"/>
                                            </Button>
                                            <Button Tag="{Binding}" Click="btnDelete_Click" 
                                                    Width="32" Height="32" Padding="0" ToolTip="Xóa"
                                                    Background="Transparent" BorderThickness="0">
                                                <materialDesign:PackIcon Kind="TrashCan" Foreground="#D32F2F" Width="20" Height="20"/>
                                            </Button>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>
        </Grid>
    </Border>
</Window>
