<UserControl x:Class="TaxPersonnelManagement.Views.BackupRestoreView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             d:DesignHeight="600" d:DesignWidth="900"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesignTheme.Defaults.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="30">

            <!-- Page Header -->
            <StackPanel Orientation="Horizontal" Margin="0 0 0 25">
                <materialDesign:PackIcon Kind="DatabaseCog" Width="32" Height="32" Foreground="#1976D2" VerticalAlignment="Center" Margin="0 0 12 0"/>
                <StackPanel>
                    <TextBlock Text="Sao lưu &amp; Phục hồi CSDL" FontSize="24" FontWeight="Bold" Foreground="#1976D2"/>
                    <TextBlock Text="Quản lý sao lưu và phục hồi cơ sở dữ liệu hệ thống" FontSize="13" Foreground="#78909C" Margin="0 3 0 0"/>
                </StackPanel>
            </StackPanel>

            <!-- Cards Container -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" MinWidth="350"/>
                    <ColumnDefinition Width="30"/>
                    <ColumnDefinition Width="*" MinWidth="350"/>
                </Grid.ColumnDefinitions>

                <!-- Backup Card -->
                <materialDesign:Card Grid.Column="0" UniformCornerRadius="12" materialDesign:ElevationAssist.Elevation="Dp3" Padding="0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Card Header -->
                        <Border Grid.Row="0" CornerRadius="12 12 0 0" Padding="25 20">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#2E7D32" Offset="0.0"/>
                                    <GradientStop Color="#43A047" Offset="1.0"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="DatabaseExport" Width="28" Height="28" Foreground="White" VerticalAlignment="Center" Margin="0 0 12 0"/>
                                <TextBlock Text="SAO LƯU DỮ LIỆU" FontSize="18" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <!-- Card Body -->
                        <StackPanel Grid.Row="1" Margin="25">
                            <TextBlock TextWrapping="Wrap" FontSize="14" Foreground="#546E7A" Margin="0 0 0 15">
                                Tạo bản sao lưu cơ sở dữ liệu hiện tại vào một file <Bold>.db</Bold>. 
                                Bản sao lưu sẽ chứa toàn bộ dữ liệu nhân sự, lương, nghỉ phép và tài khoản người dùng.
                            </TextBlock>

                            <Border Background="#E8F5E9" CornerRadius="8" Padding="12" Margin="0 0 0 15">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="InformationOutline" Width="20" Height="20" Foreground="#2E7D32" VerticalAlignment="Top" Margin="0 0 10 0"/>
                                    <TextBlock TextWrapping="Wrap" FontSize="13" Foreground="#2E7D32">
                                        Khuyến nghị sao lưu định kỳ để phòng tránh mất dữ liệu. File sao lưu sẽ được đặt tên tự động kèm ngày giờ.
                                    </TextBlock>
                                </StackPanel>
                            </Border>

                            <!-- Last Backup Info -->
                            <Border Background="#F5F5F5" CornerRadius="8" Padding="15" Margin="0 0 0 20">
                                <StackPanel>
                                    <TextBlock Text="Thông tin CSDL hiện tại:" FontWeight="SemiBold" FontSize="14" Foreground="#37474F" Margin="0 0 0 8"/>
                                    <StackPanel Orientation="Horizontal" Margin="0 0 0 4">
                                        <materialDesign:PackIcon Kind="File" Width="16" Height="16" Foreground="#78909C" VerticalAlignment="Center" Margin="0 0 6 0"/>
                                        <TextBlock x:Name="txtDbPath" Text="..." FontSize="13" Foreground="#546E7A" TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="HarddiskPlus" Width="16" Height="16" Foreground="#78909C" VerticalAlignment="Center" Margin="0 0 6 0"/>
                                        <TextBlock x:Name="txtDbSize" Text="..." FontSize="13" Foreground="#546E7A"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <Button x:Name="btnBackup" Click="btnBackup_Click"
                                    Height="45" FontSize="15" FontWeight="Bold"
                                    Background="#2E7D32" Foreground="White" BorderThickness="0"
                                    Style="{DynamicResource MaterialDesignRaisedButton}"
                                    materialDesign:ButtonAssist.CornerRadius="10"
                                    HorizontalAlignment="Stretch">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="ContentSave" Width="22" Height="22" Margin="0 0 10 0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Sao lưu ngay" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Grid>
                </materialDesign:Card>

                <!-- Restore Card -->
                <materialDesign:Card Grid.Column="2" UniformCornerRadius="12" materialDesign:ElevationAssist.Elevation="Dp3" Padding="0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Card Header -->
                        <Border Grid.Row="0" CornerRadius="12 12 0 0" Padding="25 20">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#E65100" Offset="0.0"/>
                                    <GradientStop Color="#FB8C00" Offset="1.0"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="DatabaseImport" Width="28" Height="28" Foreground="White" VerticalAlignment="Center" Margin="0 0 12 0"/>
                                <TextBlock Text="PHỤC HỒI DỮ LIỆU" FontSize="18" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <!-- Card Body -->
                        <StackPanel Grid.Row="1" Margin="25">
                            <TextBlock TextWrapping="Wrap" FontSize="14" Foreground="#546E7A" Margin="0 0 0 15">
                                Khôi phục cơ sở dữ liệu từ một bản sao lưu <Bold>.db</Bold> trước đó. 
                                Toàn bộ dữ liệu hiện tại sẽ bị thay thế bằng dữ liệu từ file sao lưu.
                            </TextBlock>

                            <Border Background="#FFF3E0" CornerRadius="8" Padding="12" Margin="0 0 0 15">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="AlertOutline" Width="20" Height="20" Foreground="#E65100" VerticalAlignment="Top" Margin="0 0 10 0"/>
                                    <TextBlock TextWrapping="Wrap" FontSize="13" Foreground="#BF360C">
                                        <Bold>Cảnh báo:</Bold> Phục hồi sẽ ghi đè toàn bộ CSDL hiện tại. 
                                        Hệ thống sẽ tự động sao lưu CSDL hiện tại trước khi phục hồi.
                                        Sau khi phục hồi, ứng dụng sẽ khởi động lại.
                                    </TextBlock>
                                </StackPanel>
                            </Border>

                            <!-- Selected File Info -->
                            <Border Background="#F5F5F5" CornerRadius="8" Padding="15" Margin="0 0 0 20">
                                <StackPanel>
                                    <TextBlock Text="File sao lưu đã chọn:" FontWeight="SemiBold" FontSize="14" Foreground="#37474F" Margin="0 0 0 8"/>
                                    <TextBlock x:Name="txtSelectedFile" Text="Chưa chọn file nào" FontSize="13" Foreground="#9E9E9E" FontStyle="Italic" TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                            </Border>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Button x:Name="btnSelectFile" Click="btnSelectFile_Click"
                                        Grid.Column="0" Height="45" FontSize="14" FontWeight="Bold"
                                        Background="#78909C" Foreground="White" BorderThickness="0"
                                        Style="{DynamicResource MaterialDesignRaisedButton}"
                                        materialDesign:ButtonAssist.CornerRadius="10">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="FolderOpen" Width="20" Height="20" Margin="0 0 8 0" VerticalAlignment="Center"/>
                                        <TextBlock Text="Chọn file" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>

                                <Button x:Name="btnRestore" Click="btnRestore_Click"
                                        Grid.Column="2" Height="45" FontSize="14" FontWeight="Bold"
                                        Background="#E65100" Foreground="White" BorderThickness="0"
                                        Style="{DynamicResource MaterialDesignRaisedButton}"
                                        materialDesign:ButtonAssist.CornerRadius="10"
                                        IsEnabled="False">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="DatabaseRefresh" Width="20" Height="20" Margin="0 0 8 0" VerticalAlignment="Center"/>
                                        <TextBlock Text="Phục hồi" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </Grid>
                        </StackPanel>
                    </Grid>
                </materialDesign:Card>
            </Grid>

        </StackPanel>
    </ScrollViewer>
</UserControl>
