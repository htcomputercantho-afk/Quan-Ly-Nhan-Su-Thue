<UserControl x:Class="TaxPersonnelManagement.Views.PersonnelListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:converters="clr-namespace:TaxPersonnelManagement.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesignTheme.Defaults.xaml" />
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesignTheme.Shadows.xaml" />
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesignTheme.Button.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <converters:NameToInitialsConverter x:Key="NameToInitialsConverter"/>
            <converters:Base64ToImageConverter x:Key="Base64ToImageConverter"/>
            <converters:PhoneFormatterConverter x:Key="PhoneFormatterConverter"/>

            <!-- ===== STYLE: ContextMenu action đẹp ===== -->
            <Style x:Key="ActionContextMenuStyle" TargetType="ContextMenu">
                <Setter Property="Padding" Value="4"/>
                <Setter Property="Background" Value="White"/>
                <Setter Property="BorderBrush" Value="#E0E7FF"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Effect">
                    <Setter.Value>
                        <DropShadowEffect Color="#90A4AE" BlurRadius="16" ShadowDepth="4" Opacity="0.25" Direction="270"/>
                    </Setter.Value>
                </Setter>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ContextMenu">
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="10"
                                    Padding="{TemplateBinding Padding}">
                                <Border.Effect>
                                    <DropShadowEffect Color="#90A4AE" BlurRadius="18" ShadowDepth="4" Opacity="0.22" Direction="270"/>
                                </Border.Effect>
                                <StackPanel IsItemsHost="True"/>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- STYLE: từng dòng menu item đẹp -->
            <Style x:Key="ActionMenuItemStyle" TargetType="MenuItem">
                <Setter Property="Height" Value="38"/>
                <Setter Property="Padding" Value="10,0"/>
                <Setter Property="Margin" Value="0,2"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="MenuItem">
                            <Border x:Name="brd" CornerRadius="6" Background="Transparent" Padding="10,0">
                                <Grid VerticalAlignment="Center">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="28"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <ContentPresenter Grid.Column="0" ContentSource="Icon"
                                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    <ContentPresenter Grid.Column="1" ContentSource="Header"
                                                      VerticalAlignment="Center" Margin="6,0,0,0"/>
                                </Grid>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsHighlighted" Value="True">
                                    <Setter TargetName="brd" Property="Background" Value="#EEF2FF"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Opacity" Value="0.4"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- STYLE: Separator trong menu -->
            <Style x:Key="ActionSeparatorStyle" TargetType="Separator">
                <Setter Property="Margin" Value="8,2"/>
                <Setter Property="Background" Value="#EDE9FE"/>
            </Style>

            <!-- STYLE: 3 nút icon (Xem/Sửa/Xóa) hiển trên Full HD -->
            <Style x:Key="ActionBtnView" TargetType="Button" BasedOn="{StaticResource MaterialDesignIconForegroundButton}">
                <Setter Property="Width" Value="32"/>
                <Setter Property="Height" Value="32"/>
                <Setter Property="Padding" Value="2"/>
                <Setter Property="Margin" Value="1,0"/>
                <Setter Property="ToolTipService.InitialShowDelay" Value="300"/>
            </Style>

        </ResourceDictionary>
    </UserControl.Resources>
    
    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Loading Overlay -->
        <Grid x:Name="LoadingOverlay" Grid.RowSpan="3" Visibility="Collapsed" Panel.ZIndex="1000">
            <Border Background="Black" Opacity="0.15"/>
            <materialDesign:Card UniformCornerRadius="10" Width="220" Height="140" materialDesign:ElevationAssist.Elevation="Dp6" VerticalAlignment="Center" HorizontalAlignment="Center">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <ProgressBar Style="{StaticResource MaterialDesignCircularProgressBar}" 
                                 Value="0" IsIndeterminate="True" 
                                 Width="40" Height="40" 
                                 Foreground="#1976D2" Margin="0 0 0 15"/>
                    <TextBlock Text="Đang xừ lý dữ liệu..." FontSize="14" FontWeight="SemiBold" Foreground="#455A64" HorizontalAlignment="Center"/>
                    <TextBlock Text="Vui lòng chờ trong giây lát" FontSize="11" Foreground="#78909C" HorizontalAlignment="Center" Margin="0 5 0 0"/>
                </StackPanel>
            </materialDesign:Card>
        </Grid>

        <!-- Top Section (Card bao phần header + KPIs + toolbar) -->
        <materialDesign:Card Grid.Row="0" UniformCornerRadius="8" materialDesign:ElevationAssist.Elevation="Dp1" Margin="0 0 0 10">
            <StackPanel x:Name="spTopContent" Margin="15 18 15 10">
                <!-- Dashboard / KPIs -->
                <WrapPanel x:Name="wpKPIRow" Margin="0 0 0 10">
                    <!-- Filter Section -->
                    <StackPanel VerticalAlignment="Top" Margin="0 0 20 15">
                        <ComboBox x:Name="cbDepartmentFilter" 
                                  MinWidth="200" MaxWidth="300"
                                  Height="40"
                                  materialDesign:HintAssist.Hint="Lọc theo bộ phận"
                                  Style="{DynamicResource MaterialDesignOutlinedComboBox}"
                                  Background="White"
                                  VerticalContentAlignment="Center"
                                  Padding="10 0"
                                  FontSize="14"
                                  Foreground="#455A64"
                                  SelectionChanged="cbDepartmentFilter_SelectionChanged">
                            <ComboBox.ItemContainerStyle>
                                <Style TargetType="ComboBoxItem" BasedOn="{StaticResource {x:Type ComboBoxItem}}">
                                    <Setter Property="Padding" Value="10"/>
                                    <Setter Property="MinHeight" Value="35"/>
                                </Style>
                            </ComboBox.ItemContainerStyle>
                        </ComboBox>
                    </StackPanel>

                    <!-- KPIs Section -->
                    <WrapPanel Orientation="Horizontal" HorizontalAlignment="Left">
                        <!-- Card 1: Total -->
                        <materialDesign:Card x:Name="cardTotal" MinWidth="220" MaxWidth="300" Width="260" Height="100" Margin="0 0 15 15" UniformCornerRadius="12" materialDesign:ElevationAssist.Elevation="Dp3" Cursor="Hand" MouseLeftButtonUp="cardTotal_Click">
                            <Grid>
                                <Grid.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#0078D4" Offset="0.0"/>
                                        <GradientStop Color="#00B7C3" Offset="1.0"/>
                                    </LinearGradientBrush>
                                </Grid.Background>
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <materialDesign:PackIcon x:Name="iconTotal" Kind="AccountGroup" Width="30" Height="30" Foreground="White" HorizontalAlignment="Center" Margin="0 0 0 5"/>
                                    <TextBlock x:Name="lblTotal" Text="TỔNG NHÂN SỰ" FontSize="13" FontWeight="SemiBold" Foreground="White" HorizontalAlignment="Center" Opacity="0.9"/>
                                    <TextBlock x:Name="txtTotalCount" Text="0" FontSize="26" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Grid>
                            <materialDesign:Card.Style>
                                <Style TargetType="materialDesign:Card">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsCompact, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="True">
                                            <Setter Property="Height" Value="65"/>
                                            <Setter Property="Width" Value="200"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </materialDesign:Card.Style>
                        </materialDesign:Card>

                        <!-- Card 2: Maternity -->
                        <materialDesign:Card x:Name="cardMaternity" MinWidth="220" MaxWidth="300" Width="260" Height="100" Margin="0 0 15 15" UniformCornerRadius="12" materialDesign:ElevationAssist.Elevation="Dp3" Cursor="Hand" MouseLeftButtonUp="cardMaternity_Click">
                            <Grid>
                                <Grid.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#FF8C00" Offset="0.0"/>
                                        <GradientStop Color="#FFC107" Offset="1.0"/>
                                    </LinearGradientBrush>
                                </Grid.Background>
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <materialDesign:PackIcon x:Name="iconMaternity" Kind="BabyCarriage" Width="30" Height="30" Foreground="White" HorizontalAlignment="Center" Margin="0 0 0 5"/>
                                    <TextBlock x:Name="lblMaternity" Text="NGHỈ THAI SẢN" FontSize="13" FontWeight="SemiBold" Foreground="White" HorizontalAlignment="Center" Opacity="0.9"/>
                                    <TextBlock x:Name="txtMaternityCount" Text="0" FontSize="26" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Grid>
                            <materialDesign:Card.Style>
                                <Style TargetType="materialDesign:Card">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsCompact, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="True">
                                            <Setter Property="Height" Value="65"/>
                                            <Setter Property="Width" Value="200"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </materialDesign:Card.Style>
                        </materialDesign:Card>

                        <!-- Card 3: Sick -->
                        <materialDesign:Card x:Name="cardSick" MinWidth="220" MaxWidth="300" Width="260" Height="100" Margin="0 0 15 15" UniformCornerRadius="12" materialDesign:ElevationAssist.Elevation="Dp3" Cursor="Hand" MouseLeftButtonUp="cardSick_Click">
                            <Grid>
                                <Grid.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#D32F2F" Offset="0.0"/>
                                        <GradientStop Color="#EF5350" Offset="1.0"/>
                                    </LinearGradientBrush>
                                </Grid.Background>
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <materialDesign:PackIcon x:Name="iconSick" Kind="MedicalBag" Width="30" Height="30" Foreground="White" HorizontalAlignment="Center" Margin="0 0 0 5"/>
                                    <TextBlock x:Name="lblSick" Text="NGHỈ ỐM" FontSize="13" FontWeight="SemiBold" Foreground="White" HorizontalAlignment="Center" Opacity="0.9"/>
                                    <TextBlock x:Name="txtSickCount" Text="0" FontSize="26" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Grid>
                            <materialDesign:Card.Style>
                                <Style TargetType="materialDesign:Card">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsCompact, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="True">
                                            <Setter Property="Height" Value="65"/>
                                            <Setter Property="Width" Value="200"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </materialDesign:Card.Style>
                        </materialDesign:Card>
                    </WrapPanel>
                </WrapPanel>

                <!-- Actions Bar & Title -->
                <WrapPanel x:Name="wpToolbarRow" Orientation="Horizontal" Margin="0 10 0 10">
                    <StackPanel Margin="0 0 20 10">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <materialDesign:PackIcon Kind="AccountMultiple" Width="24" Height="24" Foreground="#1976D2" VerticalAlignment="Center" Margin="0 0 8 0"/>
                            <TextBlock Text="Danh sách nhân sự" FontSize="20" FontWeight="Bold" Foreground="#1976D2" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock x:Name="txtSubtitle" Text="Quản lý toàn bộ hồ sơ nhân viên" FontSize="12" Foreground="#78909C" Margin="32 2 0 0"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Top">
                        <!-- Search Box -->
                        <Border Background="White" CornerRadius="4" BorderBrush="#D1D5DB" BorderThickness="1" Width="280" Height="38" Margin="0 0 12 0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <materialDesign:PackIcon Kind="Magnify" Foreground="#9CA3AF" Width="20" Height="20" VerticalAlignment="Center" Margin="10 0 0 0"/>
                                <TextBox x:Name="txtSearch" Grid.Column="1" 
                                         materialDesign:HintAssist.Hint="Tìm kiếm..." 
                                         materialDesign:TextFieldAssist.DecorationVisibility="Hidden"
                                         BorderThickness="0" Background="Transparent"
                                         VerticalContentAlignment="Center" Padding="8 0 8 0"
                                         FontSize="14" Foreground="#374151"
                                         TextChanged="txtSearch_TextChanged"/>
                            </Grid>
                        </Border>

                        <!-- Add Button -->
                        <Button x:Name="btnAdd" Click="btnAdd_Click" Height="36"
                                Background="#1976D2" BorderThickness="0" Margin="0 0 12 0"
                                Style="{DynamicResource MaterialDesignRaisedButton}"
                                materialDesign:ButtonAssist.CornerRadius="18"
                                ToolTip="Thêm nhân viên mới">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Plus" Width="20" Height="20" Margin="0 0 8 0" VerticalAlignment="Center" Foreground="White"/>
                                <TextBlock Text="Thêm Mới" FontWeight="Bold" FontSize="13" VerticalAlignment="Center" Foreground="White"/>
                            </StackPanel>
                        </Button>

                        <!-- Import Excel Button -->
                        <Button x:Name="btnImportExcel" Click="btnImportExcel_Click" 
                                Height="36"
                                Background="#EF6C00" BorderThickness="0" Margin="0 0 12 0"
                                Style="{DynamicResource MaterialDesignRaisedButton}"
                                materialDesign:ButtonAssist.CornerRadius="18"
                                ToolTip="Nhập danh sách từ file Excel">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="FileImport" Width="20" Height="20" Margin="0 0 8 0" VerticalAlignment="Center" Foreground="White"/>
                                <TextBlock Text="Nhập Excel" FontWeight="Bold" FontSize="13" VerticalAlignment="Center" Foreground="White"/>
                            </StackPanel>
                        </Button>

                        <!-- Excel Button -->
                        <Button x:Name="btnExportExcel" Click="btnExportExcel_Click" 
                                Height="36"
                                Background="#2E7D32" BorderThickness="0"
                                Style="{DynamicResource MaterialDesignRaisedButton}"
                                materialDesign:ButtonAssist.CornerRadius="18"
                                ToolTip="Xuất danh sách ra Excel">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="FileExcel" Width="20" Height="20" Margin="0 0 8 0" VerticalAlignment="Center" Foreground="White"/>
                                <TextBlock Text="Xuất Excel" FontWeight="Bold" FontSize="13" VerticalAlignment="Center" Foreground="White"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </WrapPanel>
            </StackPanel>
        </materialDesign:Card>

        <!-- DataGrid -->
        <materialDesign:Card Grid.Row="1" UniformCornerRadius="8" materialDesign:ElevationAssist.Elevation="Dp1" Margin="0 0 0 10">
            <DataGrid x:Name="dgPersonnel"
                      AutoGenerateColumns="False" CanUserAddRows="False"
                      SelectionMode="Single" SelectionUnit="FullRow" IsReadOnly="True"
                      HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                      Background="White" BorderThickness="0"
                      MinRowHeight="64" ColumnHeaderHeight="50"
                      HorizontalGridLinesBrush="#EEEEEE"
                      ScrollViewer.HorizontalScrollBarVisibility="Auto"
                      ScrollViewer.VerticalScrollBarVisibility="Auto"
                      SizeChanged="dgPersonnel_SizeChanged"
                      FrozenColumnCount="2">

                <DataGrid.Resources>
                    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#F5F5F5"/>
                    <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="#F5F5F5"/>
                    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="Black"/>
                </DataGrid.Resources>

                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow" BasedOn="{StaticResource {x:Type DataGridRow}}">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="FontSize" Value="14"/>
                        <Setter Property="VerticalContentAlignment" Value="Center"/>
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#E3F2FD"/>
                                <Setter Property="BorderBrush" Value="Transparent"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#F5F9FF"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>

                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource {x:Type DataGridColumnHeader}}">
                        <Setter Property="FontWeight" Value="Bold"/>
                        <Setter Property="Foreground" Value="White"/>
                        <Setter Property="Background" Value="{DynamicResource PrimaryHueMidBrush}"/>
                        <Setter Property="FontSize" Value="13"/>
                        <Setter Property="MinHeight" Value="50"/>
                        <Setter Property="Padding" Value="10,8"/>
                        <Setter Property="HorizontalContentAlignment" Value="Center"/>
                        <Setter Property="BorderBrush" Value="#1565C0"/>
                        <Setter Property="BorderThickness" Value="0,0,1,0"/>
                        <Setter Property="ContentTemplate">
                            <Setter.Value>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" TextWrapping="Wrap" TextAlignment="Center" LineHeight="18"/>
                                </DataTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </DataGrid.ColumnHeaderStyle>

                <DataGrid.Columns>
                    <!-- COT 1: STT -->
                    <DataGridTemplateColumn Header="STT" Width="50">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding STT}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           FontWeight="SemiBold" FontSize="14" Foreground="#546E7A"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- COT 2: HỌ VÀ TÊN — chiều rộng quản lý bởi code-behind -->
                    <DataGridTemplateColumn Header="HỌ VÀ TÊN" Width="1.8*" MinWidth="220">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Grid Margin="12,0,8,0" VerticalAlignment="Center">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <!-- Avatar circle -->
                                    <Grid Width="42" Height="42" Margin="0,0,12,0">
                                        <Border CornerRadius="21" Background="#1976D2">
                                            <TextBlock Text="{Binding FullName, Converter={StaticResource NameToInitialsConverter}}"
                                                       Foreground="White" FontWeight="Bold" FontSize="17"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <Border CornerRadius="21">
                                            <Border.Background>
                                                <ImageBrush ImageSource="{Binding AvatarBase64, Converter={StaticResource Base64ToImageConverter}}" Stretch="UniformToFill"/>
                                            </Border.Background>
                                        </Border>
                                    </Grid>
                                    <!-- Name + StaffId -->
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding FullName}" FontWeight="SemiBold" Foreground="#263238"
                                                   FontSize="15" TextWrapping="Wrap" Margin="0,0,0,2"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <materialDesign:PackIcon Kind="Barcode" Width="13" Height="13"
                                                                     Foreground="#B0BEC5" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                            <TextBlock Grid.Column="1" Text="{Binding StaffId}" FontSize="12" Foreground="#78909C" VerticalAlignment="Center"/>
                                        </Grid>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- COT 3: THÔNG TIN CƠ BẢN — fixed 200 -->
                    <DataGridTemplateColumn Header="THÔNG TIN CƠ BẢN" Width="1.2*" MinWidth="160">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel VerticalAlignment="Center" Margin="10,0,0,0">
                                    <Grid Margin="0,0,0,5">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <materialDesign:PackIcon Kind="CalendarBlank" Width="14" Height="14"
                                                                 Foreground="#78909C" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1" Text="{Binding DateOfBirth, StringFormat=dd/MM/yyyy}"
                                                   FontSize="13" Foreground="#455A64" VerticalAlignment="Center"/>
                                    </Grid>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <materialDesign:PackIcon Kind="GenderMaleFemale" Width="14" Height="14"
                                                                 Foreground="#78909C" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Gender}" FontSize="13" Foreground="#455A64" VerticalAlignment="Center"/>
                                    </Grid>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- COT 4: BỘ PHẬN — fixed 250 -->
                    <DataGridTemplateColumn Header="BỘ PHẬN" Width="1.5*" MinWidth="180">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel VerticalAlignment="Center" Margin="12,0,8,0">
                                    <Border Background="#E3F2FD" CornerRadius="5" Padding="8,3"
                                            HorizontalAlignment="Left" Margin="0,0,0,5">
                                        <TextBlock Text="{Binding Department}" FontSize="13" FontWeight="SemiBold"
                                                   Foreground="#1565C0" TextWrapping="Wrap"/>
                                    </Border>
                                    <TextBlock Text="{Binding Position}" FontSize="13" Foreground="#37474F"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- COT 5: LIÊN HỆ — fixed 300 -->
                    <DataGridTemplateColumn Header="LIÊN HỆ" Width="1.5*" MinWidth="200">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel VerticalAlignment="Center" Margin="10,0,8,0">
                                    <Grid Margin="0,0,0,5">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <materialDesign:PackIcon Kind="Phone" Width="14" Height="14"
                                                                 Foreground="#43A047" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1" Text="{Binding PhoneNumber, Converter={StaticResource PhoneFormatterConverter}}"
                                                   FontSize="14" FontWeight="Medium" Foreground="#2E7D32" VerticalAlignment="Center"/>
                                    </Grid>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <materialDesign:PackIcon Kind="Email" Width="14" Height="14"
                                                                 Foreground="#78909C" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Email}" FontSize="13" Foreground="#546E7A"
                                                   TextWrapping="Wrap" VerticalAlignment="Center"/>
                                    </Grid>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>


                    <!-- COT 6: HÀNH ĐỘNG (responsive: 3 nút Full HD, ⋮ màn nhỏ) -->
                    <DataGridTemplateColumn Header="HÀNH ĐỘNG" Width="130">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Grid HorizontalAlignment="Center" VerticalAlignment="Center">

                                    <!-- Full HD: 3 nút icon riêng lế -->
                                    <StackPanel x:Name="panelFull" Orientation="Horizontal"
                                                HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <!-- Xem -->
                                        <Button Tag="{Binding Id}" Click="btnView_Click"
                                                Style="{StaticResource ActionBtnView}"
                                                ToolTip="Xem chi tiết">
                                            <materialDesign:PackIcon Kind="Eye" Width="18" Height="18" Foreground="#0288D1"/>
                                        </Button>
                                        <!-- Sửa -->
                                        <Button Tag="{Binding Id}" Click="btnEdit_Click"
                                                Loaded="AdminOnly_Loaded"
                                                Style="{StaticResource ActionBtnView}"
                                                ToolTip="Chỉnh sửa">
                                            <materialDesign:PackIcon Kind="Pencil" Width="18" Height="18" Foreground="#3949AB"/>
                                        </Button>
                                        <!-- Xóa -->
                                        <Button Tag="{Binding Id}" Click="btnDelete_Click"
                                                Loaded="AdminOnly_Loaded"
                                                Style="{StaticResource ActionBtnView}"
                                                ToolTip="Xóa">
                                            <materialDesign:PackIcon Kind="Delete" Width="18" Height="18" Foreground="#E53935"/>
                                        </Button>
                                    </StackPanel>

                                    <!-- Màn nhỏ: nút ⋮ compact -->
                                    <Button x:Name="btnCompact"
                                            Tag="{Binding Id}"
                                            Click="btnActionMenu_Click"
                                            Style="{DynamicResource MaterialDesignIconForegroundButton}"
                                            Width="34" Height="34"
                                            HorizontalAlignment="Center" VerticalAlignment="Center"
                                            Visibility="Collapsed">
                                        <materialDesign:PackIcon Kind="DotsVertical" Width="20" Height="20" Foreground="#607D8B"/>
                                        <Button.ContextMenu>
                                            <ContextMenu Style="{StaticResource ActionContextMenuStyle}">
                                                <MenuItem Tag="{Binding PlacementTarget.Tag, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                          Click="btnView_Click"
                                                          Style="{StaticResource ActionMenuItemStyle}">
                                                    <MenuItem.Icon>
                                                        <materialDesign:PackIcon Kind="Eye" Foreground="#0288D1" Width="17" Height="17"/>
                                                    </MenuItem.Icon>
                                                    <MenuItem.Header>
                                                        <TextBlock Text="Xem chi tiết" FontSize="13" FontWeight="Medium" Foreground="#263238"/>
                                                    </MenuItem.Header>
                                                </MenuItem>
                                                <MenuItem Tag="{Binding PlacementTarget.Tag, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                          Click="btnEdit_Click"
                                                          Loaded="AdminOnly_Loaded"
                                                          Style="{StaticResource ActionMenuItemStyle}">
                                                    <MenuItem.Icon>
                                                        <materialDesign:PackIcon Kind="Pencil" Foreground="#3949AB" Width="17" Height="17"/>
                                                    </MenuItem.Icon>
                                                    <MenuItem.Header>
                                                        <TextBlock Text="Chỉnh sửa" FontSize="13" FontWeight="Medium" Foreground="#263238"/>
                                                    </MenuItem.Header>
                                                </MenuItem>
                                                <Separator Style="{StaticResource ActionSeparatorStyle}"/>
                                                <MenuItem Tag="{Binding PlacementTarget.Tag, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                          Click="btnDelete_Click"
                                                          Loaded="AdminOnly_Loaded"
                                                          Style="{StaticResource ActionMenuItemStyle}">
                                                    <MenuItem.Icon>
                                                        <materialDesign:PackIcon Kind="Delete" Foreground="#E53935" Width="17" Height="17"/>
                                                    </MenuItem.Icon>
                                                    <MenuItem.Header>
                                                        <TextBlock Text="Xóa" FontSize="13" FontWeight="Medium" Foreground="#E53935"/>
                                                    </MenuItem.Header>
                                                </MenuItem>
                                            </ContextMenu>
                                        </Button.ContextMenu>
                                    </Button>
                                </Grid>

                                <DataTemplate.Triggers>
                                    <!-- Khi IsCompact=True: Ẩn 3 nút, hiện ⋮ -->
                                    <DataTrigger Binding="{Binding IsCompact, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="True">
                                        <Setter TargetName="panelFull" Property="Visibility" Value="Collapsed"/>
                                        <Setter TargetName="btnCompact" Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                </DataGrid.Columns>
            </DataGrid>
        </materialDesign:Card>

        <!-- Footer Pagination -->
        <Grid Grid.Row="2" Margin="0 5 0 0">
            <TextBlock x:Name="txtPagingInfo" Text="Hiển thị 0 nhân viên" VerticalAlignment="Center" Foreground="#78909C" FontSize="12"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="btnPrevPage" Click="btnPrevPage_Click" Style="{DynamicResource MaterialDesignIconForegroundButton}" Width="30" Height="30" Margin="0 0 5 0">
                    <materialDesign:PackIcon Kind="ChevronLeft" Foreground="#607D8B"/>
                </Button>
                <TextBlock x:Name="txtPageInfo" Text="1 / 1" VerticalAlignment="Center" Margin="10 0" FontWeight="Bold" Foreground="#455A64"/>
                <Button x:Name="btnNextPage" Click="btnNextPage_Click" Style="{DynamicResource MaterialDesignIconForegroundButton}" Width="30" Height="30">
                    <materialDesign:PackIcon Kind="ChevronRight" Foreground="#607D8B"/>
                </Button>
            </StackPanel>
        </Grid>

    </Grid>
</UserControl>
