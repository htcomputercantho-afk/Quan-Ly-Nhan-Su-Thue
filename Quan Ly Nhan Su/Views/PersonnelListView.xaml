<UserControl x:Class="TaxPersonnelManagement.Views.PersonnelListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:converters="clr-namespace:TaxPersonnelManagement.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesignTheme.Defaults.xaml" />
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesignTheme.Shadows.xaml" />
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesignTheme.Button.xaml" />
            </ResourceDictionary.MergedDictionaries>
            
            <converters:NameToInitialsConverter x:Key="NameToInitialsConverter"/>
            <converters:Base64ToImageConverter x:Key="Base64ToImageConverter"/>
            <converters:PhoneFormatterConverter x:Key="PhoneFormatterConverter"/>
        </ResourceDictionary>
    </UserControl.Resources>
    
    <materialDesign:Card Margin="20" UniformCornerRadius="8" materialDesign:ElevationAssist.Elevation="Dp1">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Top Section -->
            <StackPanel Grid.Row="0" Margin="0 0 0 10">
                <!-- Dashboard / KPIs -->
                <Grid Margin="0 0 0 20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/> <!-- Lọc -->
                        <ColumnDefinition Width="*"/>    <!-- Thẻ KPI -->
                    </Grid.ColumnDefinitions>

                    <!-- Filter Section -->
                    <StackPanel Grid.Column="0" VerticalAlignment="Top" Margin="0 0 20 0">
                        <ComboBox x:Name="cbDepartmentFilter" 
                                  Width="280"
                                  Height="40"
                                  materialDesign:HintAssist.Hint="Lọc theo bộ phận"
                                  Style="{DynamicResource MaterialDesignOutlinedComboBox}"
                                  Background="White"
                                  VerticalContentAlignment="Center"
                                  Padding="10 0"
                                  FontSize="14"
                                  Foreground="#455A64"
                                  SelectionChanged="cbDepartmentFilter_SelectionChanged">
                            <ComboBox.ItemContainerStyle>
                                <Style TargetType="ComboBoxItem" BasedOn="{StaticResource {x:Type ComboBoxItem}}">
                                    <Setter Property="Padding" Value="10"/>
                                    <Setter Property="MinHeight" Value="35"/>
                                </Style>
                            </ComboBox.ItemContainerStyle>
                        </ComboBox>
                    </StackPanel>

                    <!-- KPIs Section - Wraps items aligned with the first card, now aligned to the right -->
                    <WrapPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                        <!-- Card 1: Total -->
                        <materialDesign:Card x:Name="cardTotal" Width="280" Height="100" Margin="0 0 15 15" UniformCornerRadius="12" materialDesign:ElevationAssist.Elevation="Dp3" Cursor="Hand" MouseLeftButtonUp="cardTotal_Click">
                            <Grid>
                                <Grid.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#0078D4" Offset="0.0"/>
                                        <GradientStop Color="#00B7C3" Offset="1.0"/>
                                    </LinearGradientBrush>
                                </Grid.Background>
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <materialDesign:PackIcon Kind="AccountGroup" Width="30" Height="30" Foreground="White" HorizontalAlignment="Center" Margin="0 0 0 5"/>
                                    <TextBlock Text="TỔNG NHÂN SỰ" FontSize="14" FontWeight="SemiBold" Foreground="White" HorizontalAlignment="Center" Opacity="0.9"/>
                                    <TextBlock x:Name="txtTotalCount" Text="0" FontSize="28" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Grid>
                        </materialDesign:Card>

                        <!-- Card 2: Maternity -->
                        <materialDesign:Card x:Name="cardMaternity" Width="280" Height="100" Margin="0 0 15 15" UniformCornerRadius="12" materialDesign:ElevationAssist.Elevation="Dp3" Cursor="Hand" MouseLeftButtonUp="cardMaternity_Click">
                            <Grid>
                                <Grid.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#FF8C00" Offset="0.0"/>
                                        <GradientStop Color="#FFC107" Offset="1.0"/>
                                    </LinearGradientBrush>
                                </Grid.Background>
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <materialDesign:PackIcon Kind="BabyCarriage" Width="30" Height="30" Foreground="White" HorizontalAlignment="Center" Margin="0 0 0 5"/>
                                    <TextBlock Text="NGHỈ THAI SẢN" FontSize="14" FontWeight="SemiBold" Foreground="White" HorizontalAlignment="Center" Opacity="0.9"/>
                                    <TextBlock x:Name="txtMaternityCount" Text="0" FontSize="28" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Grid>
                        </materialDesign:Card>

                        <!-- Card 3: Sick -->
                        <materialDesign:Card x:Name="cardSick" Width="280" Height="100" Margin="0 0 15 15" UniformCornerRadius="12" materialDesign:ElevationAssist.Elevation="Dp3" Cursor="Hand" MouseLeftButtonUp="cardSick_Click">
                            <Grid>
                                <Grid.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#D32F2F" Offset="0.0"/>
                                        <GradientStop Color="#EF5350" Offset="1.0"/>
                                    </LinearGradientBrush>
                                </Grid.Background>
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <materialDesign:PackIcon Kind="MedicalBag" Width="30" Height="30" Foreground="White" HorizontalAlignment="Center" Margin="0 0 0 5"/>
                                    <TextBlock Text="NGHỈ ỐM" FontSize="14" FontWeight="SemiBold" Foreground="White" HorizontalAlignment="Center" Opacity="0.9"/>
                                    <TextBlock x:Name="txtSickCount" Text="0" FontSize="28" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Grid>
                        </materialDesign:Card>
                    </WrapPanel>
                </Grid>

                <!-- Actions Bar & Title -->
                <Grid Margin="0 10 0 10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <materialDesign:PackIcon Kind="AccountMultiple" Width="24" Height="24" Foreground="#1976D2" VerticalAlignment="Center" Margin="0 0 8 0"/>
                            <TextBlock Text="Danh sách nhân sự" FontSize="20" FontWeight="Bold" Foreground="#1976D2" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Text="Quản lý toàn bộ hồ sơ nhân viên" FontSize="12" Foreground="#78909C" Margin="32 2 0 0"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                        <!-- Search Box -->
                        <Border Background="White" CornerRadius="4" BorderBrush="#D1D5DB" BorderThickness="1" Width="280" Height="38" Margin="0 0 12 0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <materialDesign:PackIcon Kind="Magnify" Foreground="#9CA3AF" Width="20" Height="20" VerticalAlignment="Center" Margin="10 0 0 0"/>
                                <TextBox x:Name="txtSearch" Grid.Column="1" 
                                         materialDesign:HintAssist.Hint="Tìm kiếm..." 
                                         materialDesign:TextFieldAssist.DecorationVisibility="Hidden"
                                         BorderThickness="0" Background="Transparent"
                                         VerticalContentAlignment="Center" Padding="8 0 8 0"
                                         FontSize="14" Foreground="#374151"
                                         TextChanged="txtSearch_TextChanged"/>
                            </Grid>
                        </Border>

                        <!-- Add Button -->
                        <Button x:Name="btnAdd" Click="btnAdd_Click" Height="36"
                                Background="#1976D2" BorderThickness="0" Margin="0 0 12 0"
                                Style="{DynamicResource MaterialDesignRaisedButton}"
                                materialDesign:ButtonAssist.CornerRadius="18"
                                ToolTip="Thêm nhân viên mới">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Plus" Width="20" Height="20" Margin="0 0 8 0" VerticalAlignment="Center" Foreground="White"/>
                                <TextBlock Text="Thêm Mới" FontWeight="Bold" FontSize="13" VerticalAlignment="Center" Foreground="White"/>
                            </StackPanel>
                        </Button>

                        <!-- Excel Button -->
                        <Button x:Name="btnExportExcel" Click="btnExportExcel_Click" 
                                Height="36"
                                Background="#2E7D32" BorderThickness="0"
                                Style="{DynamicResource MaterialDesignRaisedButton}"
                                materialDesign:ButtonAssist.CornerRadius="18"
                                ToolTip="Xuất danh sách ra Excel">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="FileExcel" Width="20" Height="20" Margin="0 0 8 0" VerticalAlignment="Center" Foreground="White"/>
                                <TextBlock Text="Xuất Excel" FontWeight="Bold" FontSize="13" VerticalAlignment="Center" Foreground="White"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </StackPanel>

            <!-- DataGrid -->
            <!-- DataGrid -->
            <DataGrid x:Name="dgPersonnel" Grid.Row="1" AutoGenerateColumns="False" CanUserAddRows="False" 
                      SelectionMode="Single" SelectionUnit="FullRow" IsReadOnly="True"
                      HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                      Background="White" BorderThickness="0"
                      RowHeight="76"
                      materialDesign:DataGridAssist.ColumnHeaderPadding="10 10 10 10"
                      materialDesign:DataGridAssist.CellPadding="10"
                      VerticalGridLinesBrush="Transparent" HorizontalGridLinesBrush="#EEEEEE">
                
                <DataGrid.Resources>
                    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#F5F5F5"/>
                    <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="#F5F5F5"/>
                    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="Black"/>
                </DataGrid.Resources>

                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow" BasedOn="{StaticResource {x:Type DataGridRow}}">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="FontSize" Value="15"/>
                        <Setter Property="VerticalContentAlignment" Value="Center"/>
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#F5F5F5"/>
                                <Setter Property="BorderBrush" Value="Transparent"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FAFAFA"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>

                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource {x:Type DataGridColumnHeader}}">
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="Foreground" Value="#546E7A"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="FontSize" Value="15"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>

                <DataGrid.Columns>
                    <!-- STT -->
                    <DataGridTemplateColumn Header="STT" Width="50">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding STT}" 
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           FontWeight="SemiBold" FontSize="15" Foreground="#546E7A"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- NAME INFO -->
                    <DataGridTemplateColumn Header="HỌ VÀ TÊN" Width="2.2*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <!-- Avatar -->
                                    <Grid Width="45" Height="45" Margin="0 0 14 0" Effect="{DynamicResource MaterialDesignShadowDepth1}">
                                        <!-- Fallback: Initials -->
                                        <Border CornerRadius="30" Background="#1976D2">
                                            <TextBlock Text="{Binding FullName, Converter={StaticResource NameToInitialsConverter}}" 
                                                       Foreground="White" FontWeight="Bold" FontSize="20" 
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        
                                        <!-- Overlay: Avatar Image -->
                                        <Border CornerRadius="30">
                                            <Border.Background>
                                                <ImageBrush ImageSource="{Binding AvatarBase64, Converter={StaticResource Base64ToImageConverter}}" Stretch="UniformToFill"/>
                                            </Border.Background>
                                        </Border>
                                    </Grid>
                                    
                                    <!-- Name/ID -->
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="{Binding FullName}" FontWeight="SemiBold" Foreground="#263238" FontSize="18" Margin="0 0 0 2"/>
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="Barcode" Width="14" Height="14" Foreground="#B0BEC5" VerticalAlignment="Center" Margin="0 0 4 0"/>
                                            <TextBlock Text="{Binding StaffId}" FontSize="15" Foreground="#78909C"/>
                                        </StackPanel>
                                    </StackPanel>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- INFO (DOB/Gender) -->
                    <DataGridTemplateColumn Header="THÔNG TIN CƠ BẢN" Width="1.5*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel VerticalAlignment="Center">
                                    <StackPanel Orientation="Horizontal" Margin="0 0 0 6">
                                        <materialDesign:PackIcon Kind="CalendarBlank" Width="15" Height="15" Foreground="#78909C" Margin="0 0 8 0" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding DateOfBirth, StringFormat=dd/MM/yyyy}" FontSize="16" Foreground="#455A64"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="GenderMaleFemale" Width="15" Height="15" Foreground="#78909C" Margin="0 0 8 0" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding Gender}" FontSize="16" Foreground="#455A64"/>
                                    </StackPanel>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- POSITION -->
                    <DataGridTemplateColumn Header="VỊ TRÍ" Width="2*">
                         <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel VerticalAlignment="Center">
                                    <!-- Department Tag -->
                                    <Border Background="#E3F2FD" CornerRadius="6" Padding="10 4" HorizontalAlignment="Left" Margin="0 0 0 6">
                                         <TextBlock Text="{Binding Department}" FontSize="14" FontWeight="SemiBold" Foreground="#1565C0"/>
                                    </Border>
                                    <!-- Position -->
                                    <TextBlock Text="{Binding Position}" FontWeight="Medium" Foreground="#37474F" FontSize="16"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- CONTACT -->
                    <DataGridTemplateColumn Header="LIÊN HỆ" Width="1.8*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel VerticalAlignment="Center">
                                    <StackPanel Orientation="Horizontal" Margin="0 0 0 6">
                                        <materialDesign:PackIcon Kind="Phone" Width="15" Height="15" Foreground="#43A047" Margin="0 0 8 0" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding PhoneNumber, Converter={StaticResource PhoneFormatterConverter}}" FontSize="16" FontWeight="Medium" Foreground="#2E7D32"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="Email" Width="15" Height="15" Foreground="#78909C" Margin="0 0 8 0" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding Email}" FontSize="15" Foreground="#546E7A"/>
                                    </StackPanel>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- ACTIONS -->
                    <DataGridTemplateColumn Header="HÀNH ĐỘNG" Width="Auto">
                         <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <Button x:Name="btnView" Click="btnView_Click" Tag="{Binding Id}"
                                            Style="{DynamicResource MaterialDesignFloatingActionMiniLightButton}" ToolTip="Xem chi tiết" 
                                            Width="32" Height="32" Margin="0 0 8 0" Background="#E1F5FE" BorderBrush="#E1F5FE" Foreground="#0288D1" materialDesign:ElevationAssist.Elevation="Dp0">
                                        <materialDesign:PackIcon Kind="Eye" Width="16" Height="16"/>
                                    </Button>
                                    
                                    <Button x:Name="btnEdit" Click="btnEdit_Click" Tag="{Binding Id}" Loaded="AdminOnly_Loaded"
                                            Style="{DynamicResource MaterialDesignFloatingActionMiniLightButton}" ToolTip="Chỉnh sửa" 
                                            Width="32" Height="32" Margin="0 0 8 0" Background="#E8EAF6" BorderBrush="#E8EAF6" Foreground="#3949AB" materialDesign:ElevationAssist.Elevation="Dp0">
                                        <materialDesign:PackIcon Kind="Pencil" Width="16" Height="16"/>
                                    </Button>
                                    
                                    <Button x:Name="btnDelete" Click="btnDelete_Click" Tag="{Binding Id}" Loaded="AdminOnly_Loaded"
                                            Style="{DynamicResource MaterialDesignFloatingActionMiniLightButton}" ToolTip="Xóa" 
                                            Width="32" Height="32" Background="#FFEBEE" BorderBrush="#FFEBEE" Foreground="#D32F2F" materialDesign:ElevationAssist.Elevation="Dp0">
                                        <materialDesign:PackIcon Kind="Delete" Width="16" Height="16"/>
                                    </Button>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>


            <!-- Footer Pagination -->
            <Grid Grid.Row="2" Margin="0 10 0 0">
                <TextBlock x:Name="txtPagingInfo" Text="Hiển thị 0 nhân viên" VerticalAlignment="Center" Foreground="#78909C" FontSize="12"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                     <Button x:Name="btnPrevPage" Click="btnPrevPage_Click" Style="{DynamicResource MaterialDesignIconForegroundButton}" Width="30" Height="30" Margin="0 0 5 0">
                        <materialDesign:PackIcon Kind="ChevronLeft" Foreground="#607D8B"/>
                    </Button>
                    <TextBlock x:Name="txtPageInfo" Text="1 / 1" VerticalAlignment="Center" Margin="10 0" FontWeight="Bold" Foreground="#455A64"/>
                     <Button x:Name="btnNextPage" Click="btnNextPage_Click" Style="{DynamicResource MaterialDesignIconForegroundButton}" Width="30" Height="30">
                        <materialDesign:PackIcon Kind="ChevronRight" Foreground="#607D8B"/>
                    </Button>
                </StackPanel>
            </Grid>

        </Grid>
    </materialDesign:Card>
</UserControl>
