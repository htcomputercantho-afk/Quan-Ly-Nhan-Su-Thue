<UserControl x:Class="TaxPersonnelManagement.Views.SalaryListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:local="clr-namespace:TaxPersonnelManagement.Views"
             xmlns:converters="clr-namespace:TaxPersonnelManagement.Converters"
             xmlns:helpers="clr-namespace:TaxPersonnelManagement.Helpers"
        Language="vi-VN"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="1200">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesignTheme.Defaults.xaml" />
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesignTheme.ComboBox.xaml" />
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesignTheme.Shadows.xaml" />
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesignTheme.Button.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/> <!-- Filters -->
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Orientation="Horizontal" Margin="0 0 0 20">
            <materialDesign:PackIcon Kind="ChartLineVariant" Width="28" Height="28" Foreground="{DynamicResource PrimaryHueMidBrush}" VerticalAlignment="Center" Margin="0 0 10 0"/>
            <TextBlock Text="THEO DÕI NÂNG LƯƠNG" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource PrimaryHueMidBrush}" VerticalAlignment="Center"/>
        </StackPanel>

        <!-- Filters -->
        <!-- Filters -->
        <!-- Filter Toolbar -->
        <materialDesign:Card Grid.Row="1" Margin="0 0 0 20" Padding="16" UniformCornerRadius="8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="30"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Year Filter -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <materialDesign:PackIcon Kind="CalendarMonth" Width="24" Height="24" Foreground="{DynamicResource PrimaryHueMidBrush}" VerticalAlignment="Center" Margin="0 0 10 0"/>
                    <TextBlock Text="Năm:" VerticalAlignment="Center" FontWeight="Bold" Margin="0 0 10 0" Foreground="#555"/>
                    <ComboBox x:Name="cbYear" Width="150"
                              materialDesign:HintAssist.Hint="Tất cả"
                              Style="{DynamicResource MaterialDesignOutlinedComboBox}"
                              Background="White" Padding="10"
                              VerticalAlignment="Center"
                              VerticalContentAlignment="Center"
                              SelectionChanged="cbFilter_SelectionChanged">
                    </ComboBox>
                </StackPanel>

                <!-- Period Filter -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <materialDesign:PackIcon Kind="CalendarRange" Width="24" Height="24" Foreground="{DynamicResource PrimaryHueMidBrush}" VerticalAlignment="Center" Margin="0 0 10 0"/>
                    <TextBlock Text="Kỳ xem:" VerticalAlignment="Center" FontWeight="Bold" Margin="0 0 10 0" Foreground="#555"/>
                    <ComboBox x:Name="cbPeriod" Width="180"
                              materialDesign:HintAssist.Hint="Cả năm" 
                              Style="{DynamicResource MaterialDesignOutlinedComboBox}"
                              Background="White" Padding="10"
                              VerticalAlignment="Center"
                              VerticalContentAlignment="Center"
                              SelectionChanged="cbFilter_SelectionChanged">
                        <ComboBox.ItemContainerStyle>
                            <Style TargetType="ComboBoxItem" BasedOn="{StaticResource {x:Type ComboBoxItem}}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsHeader}" Value="True">
                                        <Setter Property="FontWeight" Value="Bold"/>
                                        <Setter Property="Foreground" Value="{DynamicResource PrimaryHueMidBrush}"/>
                                        <Setter Property="IsHitTestVisible" Value="False"/>
                                        <Setter Property="Focusable" Value="False"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ComboBox.ItemContainerStyle>
                    </ComboBox>
                </StackPanel>

                <!-- Export Button -->
                <Button Grid.Column="4" Height="36"
                        Style="{DynamicResource MaterialDesignRaisedButton}"
                        materialDesign:ButtonAssist.CornerRadius="18"
                        Background="#2E7D32" BorderThickness="0" Foreground="White"
                        ToolTip="Xuất danh sách lương hiện tại ra file Excel"
                        Click="btnExport_Click">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="FileExcel" VerticalAlignment="Center" Margin="0 0 8 0" Width="20" Height="20"/>
                        <TextBlock Text="Xuất Excel" VerticalAlignment="Center" FontWeight="Bold"/>
                    </StackPanel>
                </Button>
            </Grid>
        </materialDesign:Card>

        <materialDesign:Card Grid.Row="2" Style="{DynamicResource MaterialDesignCard}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

            <DataGrid x:Name="dgSalary" Grid.Row="0" AutoGenerateColumns="False" IsReadOnly="True" 
                      CanUserAddRows="False" HeadersVisibility="Column"
                      LoadingRow="dgSalary_LoadingRow"
                      BorderThickness="0" VerticalGridLinesBrush="Transparent" HorizontalGridLinesBrush="#EEEEEE"
                      GridLinesVisibility="Horizontal" 
                      AlternationCount="2" AlternatingRowBackground="#FAFAFA"
                      MinRowHeight="50" VerticalContentAlignment="Center"
                      SelectionMode="Single"
                      FrozenColumnCount="2"
                      ScrollViewer.HorizontalScrollBarVisibility="Auto">
                <DataGrid.Resources>
                    <converters:Base64ToImageConverter x:Key="Base64ToImageConverter"/>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="FontWeight" Value="Bold"/>
                        <Setter Property="FontSize" Value="14"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Padding" Value="10"/>
                        <Setter Property="HorizontalContentAlignment" Value="Center"/>
                    </Style>
                    <Style TargetType="DataGridCell">
                        <Setter Property="TextBlock.TextAlignment" Value="Center"/>
                        <Setter Property="FontSize" Value="15"/>
                        <Setter Property="Padding" Value="4"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="{x:Type DataGridCell}">
                                    <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" SnapsToDevicePixels="True">
                                        <ContentPresenter SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" VerticalAlignment="Center" HorizontalAlignment="Stretch"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                         <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="{DynamicResource PrimaryHueMidBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource PrimaryHueMidForegroundBrush}"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                    <Style x:Key="CenterAlignedColumn" TargetType="TextBlock">
                         <Setter Property="HorizontalAlignment" Value="Center"/>
                         <Setter Property="VerticalAlignment" Value="Center"/>
                         <Setter Property="TextWrapping" Value="Wrap"/>
                         <Setter Property="FontSize" Value="15"/>
                    </Style>

                    <Style x:Key="WrappedHeaderStyle" TargetType="DataGridColumnHeader" BasedOn="{StaticResource {x:Type DataGridColumnHeader}}">
                         <Setter Property="MinHeight" Value="80"/>
                         <Setter Property="FontSize" Value="14"/>
                         <Setter Property="ContentTemplate">
                             <Setter.Value>
                                 <DataTemplate>
                                     <TextBlock Text="{Binding}" TextWrapping="Wrap" TextAlignment="Center" HorizontalAlignment="Center" Padding="2"/>
                                 </DataTemplate>
                             </Setter.Value>
                         </Setter>
                    </Style>

                    <Style x:Key="ActionIconButtonStyle" TargetType="Button">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="Width" Value="32"/>
                        <Setter Property="Height" Value="32"/>
                        <Setter Property="Cursor" Value="Hand"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="16" BorderBrush="Transparent" BorderThickness="0">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#E0E0E0"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.Resources>
                
                <DataGrid.Columns>
                    <!-- STT -->
                    <DataGridTextColumn Header="STT" Binding="{Binding RelativeSource={RelativeSource AncestorType=DataGridRow}, Path=Header}" Width="60" HeaderStyle="{StaticResource WrappedHeaderStyle}"/>
                    
                    <DataGridTemplateColumn Header="HỌ VÀ TÊN" Width="250" HeaderStyle="{StaticResource WrappedHeaderStyle}">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="10 4 0 4">
                                    <!-- Avatar -->
                                    <Grid Width="32" Height="32" Margin="0 0 10 0" VerticalAlignment="Top">
                                        <!-- Placeholder -->
                                        <Ellipse Fill="{DynamicResource PrimaryHueMidBrush}"/>
                                        <materialDesign:PackIcon Kind="Account" Width="20" Height="20" Foreground="White" 
                                                                 HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        
                                        <!-- Real Image Overlay -->
                                        <Ellipse>
                                            <Ellipse.Fill>
                                                <ImageBrush ImageSource="{Binding AvatarBase64, Converter={StaticResource Base64ToImageConverter}}" Stretch="UniformToFill"/>
                                            </Ellipse.Fill>
                                            <Ellipse.Style>
                                                <Style TargetType="Ellipse">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding AvatarBase64}" Value="{x:Null}">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding AvatarBase64}" Value="">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Ellipse.Style>
                                        </Ellipse>
                                    </Grid>
                                    <TextBlock Text="{Binding FullName}" VerticalAlignment="Center" FontWeight="Medium" TextWrapping="Wrap" FontSize="15"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="BỘ PHẬN" Width="200" HeaderStyle="{StaticResource WrappedHeaderStyle}">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border x:Name="brdDept" Background="#E8EAF6" CornerRadius="6" Padding="10,4" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="10,4">
                                    <TextBlock Text="{Binding Department}" FontSize="14" FontWeight="SemiBold" Foreground="#3949AB" TextWrapping="Wrap"/>
                                </Border>
                                <DataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding Department}" Value="{x:Null}">
                                        <Setter TargetName="brdDept" Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Department}" Value="">
                                        <Setter TargetName="brdDept" Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTextColumn Header="NGÀY SINH" Binding="{Binding DateOfBirth, StringFormat=dd/MM/yyyy}" Width="120" ElementStyle="{StaticResource CenterAlignedColumn}" HeaderStyle="{StaticResource WrappedHeaderStyle}"/>
                    <DataGridTextColumn Header="MÃ NGẠCH" Binding="{Binding RankCode}" Width="110" ElementStyle="{StaticResource CenterAlignedColumn}" HeaderStyle="{StaticResource WrappedHeaderStyle}"/>
                    <DataGridTextColumn Header="BẬC LƯƠNG" Binding="{Binding CurrentSalaryStep}" Width="110" ElementStyle="{StaticResource CenterAlignedColumn}" HeaderStyle="{StaticResource WrappedHeaderStyle}"/>
                    
                    <DataGridTemplateColumn Header="HỆ SỐ LƯƠNG" Width="130" HeaderStyle="{StaticResource WrappedHeaderStyle}">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border x:Name="brdCoef" Background="#E3F2FD" CornerRadius="8" Padding="10,4" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="4">
                                    <TextBlock Text="{Binding CurrentSalaryCoefficient}" FontWeight="SemiBold" FontSize="15" 
                                               Foreground="#1565C0" HorizontalAlignment="Center"/>
                                </Border>
                                <DataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding CurrentSalaryCoefficient}" Value="0">
                                        <Setter TargetName="brdCoef" Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding CurrentSalaryCoefficient}" Value="{x:Null}">
                                        <Setter TargetName="brdCoef" Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTextColumn Header="% VƯỢT KHUNG" Binding="{Binding ExceedFramePercent, StringFormat={}{0}%}" Width="140" ElementStyle="{StaticResource CenterAlignedColumn}" HeaderStyle="{StaticResource WrappedHeaderStyle}"/>
                    
                    <DataGridTextColumn Header="THỜI ĐIỂM&#x0a;TÍNH BẬC LƯƠNG&#x0a;LẦN SAU" Binding="{Binding NextSalaryStepDate, StringFormat=dd/MM/yyyy}" Width="200" ElementStyle="{StaticResource CenterAlignedColumn}" HeaderStyle="{StaticResource WrappedHeaderStyle}"/>

                    <DataGridTextColumn Header="THÁNG" Binding="{Binding ExpectedSalaryIncreaseDate, StringFormat=MM}" Width="90" ElementStyle="{StaticResource CenterAlignedColumn}" HeaderStyle="{StaticResource WrappedHeaderStyle}"/>
                    
                    <DataGridTemplateColumn Header="DỰ KIẾN&#x0a;LÊN LƯƠNG" Width="180" HeaderStyle="{StaticResource WrappedHeaderStyle}">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border x:Name="brdExpectedDate" Background="#FFF3E0" CornerRadius="8" Padding="12,6" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="4">
                                    <TextBlock Text="{Binding ExpectedSalaryIncreaseDate, StringFormat=dd/MM/yyyy}" 
                                               FontWeight="Bold" Foreground="#E65100" FontSize="15"/>
                                </Border>
                                <DataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding ExpectedSalaryIncreaseDate}" Value="{x:Null}">
                                        <Setter TargetName="brdExpectedDate" Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="GHI CHÚ / TRẠNG THÁI" Width="160" HeaderStyle="{StaticResource WrappedHeaderStyle}">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border Background="#FFC107" CornerRadius="12" Padding="10 4" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0 4">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Visibility" Value="Visible"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SalaryIncreaseStatus}" Value="">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding SalaryIncreaseStatus}" Value="{x:Null}">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="{Binding SalaryIncreaseStatus}" Foreground="Black" FontWeight="SemiBold" TextWrapping="Wrap" TextAlignment="Center"/>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    
                    <!-- Actions -->
                    <DataGridTemplateColumn Header="THAO TÁC" Width="100" HeaderStyle="{StaticResource WrappedHeaderStyle}">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Button Style="{StaticResource ActionIconButtonStyle}" ToolTip="Sửa" Click="btnEditSalary_Click" Loaded="AdminOnly_Loaded">
                                        <materialDesign:PackIcon Kind="Pencil" Width="18" Height="18" Foreground="{DynamicResource PrimaryHueMidBrush}"/>
                                    </Button>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>

                <!-- Pagination Footer -->
                <Grid Grid.Row="1" Margin="15 8">
                    <TextBlock x:Name="txtPagingInfo" Text="Hiển thị 0 nhân viên" VerticalAlignment="Center" Foreground="#78909C" FontSize="12"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button x:Name="btnPrevPage" Click="BtnPrevPage_Click" 
                                Style="{DynamicResource MaterialDesignIconForegroundButton}" Width="30" Height="30" Margin="0 0 5 0">
                            <materialDesign:PackIcon Kind="ChevronLeft" Foreground="#607D8B"/>
                        </Button>
                        <TextBlock x:Name="txtPageInfo" Text="1 / 1" VerticalAlignment="Center" Margin="10 0" FontWeight="Bold" Foreground="#455A64"/>
                        <Button x:Name="btnNextPage" Click="BtnNextPage_Click" 
                                Style="{DynamicResource MaterialDesignIconForegroundButton}" Width="30" Height="30">
                            <materialDesign:PackIcon Kind="ChevronRight" Foreground="#607D8B"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Grid>
        </materialDesign:Card>
    </Grid>
</UserControl>
