<Page x:Class="TaxPersonnelManagement.Views.TrainingListView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      xmlns:converters="clr-namespace:TaxPersonnelManagement.Converters"
      mc:Ignorable="d" 
      Language="vi-VN"
      d:DesignHeight="600" d:DesignWidth="1200"
      Title="Quản Lý Đào Tạo Và Bồi Dưỡng">

    <Page.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesignTheme.Defaults.xaml" />
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesignTheme.ComboBox.xaml" />
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesignTheme.Shadows.xaml" />
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesignTheme.Button.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <converters:DateFormatterConverter x:Key="DateFormatterConverter"/>
        </ResourceDictionary>
    </Page.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Orientation="Horizontal" Margin="0 0 0 20">
            <materialDesign:PackIcon Kind="School" Width="28" Height="28" Foreground="{DynamicResource PrimaryHueMidBrush}" VerticalAlignment="Center" Margin="0 0 10 0"/>
            <TextBlock Text="QUẢN LÝ ĐÀO TẠO VÀ BỒI DƯỠNG" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource PrimaryHueMidBrush}" VerticalAlignment="Center"/>
        </StackPanel>

        <!-- Filter Toolbar -->
        <materialDesign:Card Grid.Row="1" Margin="0 0 0 20" Padding="16 16 16 6" UniformCornerRadius="8">
            <WrapPanel Orientation="Horizontal" VerticalAlignment="Center">
                <!-- Search Box -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0 0 20 10">
                    <materialDesign:PackIcon Kind="Magnify" Width="24" Height="24" Foreground="{DynamicResource PrimaryHueMidBrush}" VerticalAlignment="Center" Margin="0 0 10 0"/>
                    <TextBlock Text="Tìm kiếm:" VerticalAlignment="Center" FontWeight="Bold" Margin="0 0 10 0" Foreground="#555"/>
                    <Border Background="White" CornerRadius="4" BorderBrush="#D1D5DB" BorderThickness="1" Width="280" Height="38">
                        <TextBox x:Name="txtSearch"
                                 materialDesign:HintAssist.Hint="Tên lớp, số QĐ, đơn vị..."
                                 materialDesign:TextFieldAssist.DecorationVisibility="Hidden"
                                 materialDesign:TextFieldAssist.HasClearButton="True"
                                 BorderThickness="0" Background="Transparent"
                                 VerticalContentAlignment="Center" Padding="10 0"
                                 FontSize="14" Foreground="#374151"
                                 TextChanged="txtSearch_TextChanged"/>
                    </Border>
                </StackPanel>

                <!-- Action Buttons -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0 0 0 10">
                    <!-- Add Class Button -->
                    <Button x:Name="btnAddClass" Click="btnAddClass_Click"
                            Style="{DynamicResource MaterialDesignRaisedButton}"
                            Background="{DynamicResource PrimaryHueMidBrush}" BorderThickness="0"
                            materialDesign:ButtonAssist.CornerRadius="18"
                            Height="38" Margin="0 0 10 0">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Plus" Width="20" Height="20" Margin="0 0 8 0" VerticalAlignment="Center"/>
                            <TextBlock Text="Thêm lớp, hội nghị" FontWeight="Bold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    
                    <!-- Export Button -->
                    <Button x:Name="btnExport" Click="btnExport_Click"
                            Style="{DynamicResource MaterialDesignRaisedButton}"
                            Background="#2E7D32" BorderThickness="0"
                            materialDesign:ButtonAssist.CornerRadius="18"
                            Height="38">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="FileExcel" Width="20" Height="20" Margin="0 0 8 0" VerticalAlignment="Center"/>
                            <TextBlock Text="Xuất Excel" FontWeight="Bold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </WrapPanel>
        </materialDesign:Card>

        <!-- Data Grid Card -->
        <materialDesign:Card Grid.Row="2" Style="{DynamicResource MaterialDesignCard}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <DataGrid x:Name="dgTrainingClasses" Grid.Row="0"
                          AutoGenerateColumns="False" IsReadOnly="True" 
                          CanUserAddRows="False" HeadersVisibility="Column"
                          BorderThickness="0"
                          VerticalGridLinesBrush="Transparent"
                          HorizontalGridLinesBrush="#EEEEEE"
                          GridLinesVisibility="Horizontal" 
                          AlternationCount="2" AlternatingRowBackground="#FAFAFA"
                          MinRowHeight="50" VerticalContentAlignment="Center"
                          SelectionMode="Single"
                          ScrollViewer.HorizontalScrollBarVisibility="Auto"
                          ScrollViewer.CanContentScroll="False"
                          FrozenColumnCount="2">
                    <DataGrid.Resources>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="FontWeight" Value="Bold"/>
                            <Setter Property="FontSize" Value="14"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Padding" Value="10"/>
                            <Setter Property="HorizontalContentAlignment" Value="Center"/>
                        </Style>
                        <Style TargetType="DataGridCell">
                            <Setter Property="TextBlock.TextAlignment" Value="Center"/>
                            <Setter Property="FontSize" Value="15"/>
                            <Setter Property="Padding" Value="4"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="{x:Type DataGridCell}">
                                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" SnapsToDevicePixels="True">
                                            <ContentPresenter SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" VerticalAlignment="Center" HorizontalAlignment="Stretch"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource PrimaryHueMidBrush}"/>
                                    <Setter Property="Foreground" Value="{DynamicResource PrimaryHueMidForegroundBrush}"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                        <Style x:Key="LeftAlignedColumn" TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Left"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                            <Setter Property="TextWrapping" Value="Wrap"/>
                            <Setter Property="Margin" Value="10 0"/>
                            <Setter Property="FontSize" Value="15"/>
                        </Style>
                        <Style x:Key="WrappedHeaderStyle" TargetType="DataGridColumnHeader" BasedOn="{StaticResource {x:Type DataGridColumnHeader}}">
                            <Setter Property="MinHeight" Value="60"/>
                            <Setter Property="FontSize" Value="14"/>
                            <Setter Property="ContentTemplate">
                                <Setter.Value>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}" TextWrapping="Wrap" TextAlignment="Center" HorizontalAlignment="Center" Padding="2"/>
                                    </DataTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                        <Style x:Key="LeftAlignedWrappedHeaderStyle" TargetType="DataGridColumnHeader" BasedOn="{StaticResource {x:Type DataGridColumnHeader}}">
                            <Setter Property="MinHeight" Value="60"/>
                            <Setter Property="FontSize" Value="14"/>
                            <Setter Property="HorizontalContentAlignment" Value="Left"/>
                            <Setter Property="ContentTemplate">
                                <Setter.Value>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}" TextWrapping="Wrap" TextAlignment="Left" HorizontalAlignment="Left" Padding="10 2 2 2"/>
                                    </DataTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </DataGrid.Resources>

                    <DataGrid.Columns>
                        <!-- STT -->
                        <DataGridTextColumn Header="STT" Binding="{Binding STT}" Width="60"/>

                        <!-- TÊN CÁC LỚP, HỘI NGHỊ -->
                        <DataGridTemplateColumn Header="TÊN CÁC LỚP, HỘI NGHỊ" Width="*" MinWidth="260" HeaderStyle="{StaticResource WrappedHeaderStyle}">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding ClassName}" TextWrapping="Wrap" TextAlignment="Left" HorizontalAlignment="Left" FontWeight="SemiBold" Margin="10,0" VerticalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="#333"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=DataGridCell}}" Value="True">
                                                        <Setter Property="Foreground" Value="{DynamicResource PrimaryHueMidForegroundBrush}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- NGÀY THAM GIA -->
                        <DataGridTextColumn Header="NGÀY THAM GIA" Binding="{Binding ParticipationDate, Converter={StaticResource DateFormatterConverter}}" Width="140" HeaderStyle="{StaticResource WrappedHeaderStyle}"/>

                        <!-- SỐ QĐ -->
                        <DataGridTextColumn Header="SỐ QĐ" Binding="{Binding DecisionNumber}" Width="130" HeaderStyle="{StaticResource WrappedHeaderStyle}"/>

                        <!-- NGÀY RA QĐ -->
                        <DataGridTextColumn Header="NGÀY RA QĐ" Binding="{Binding DecisionDate, Converter={StaticResource DateFormatterConverter}}" Width="140" HeaderStyle="{StaticResource WrappedHeaderStyle}"/>

                        <!-- ĐƠN VỊ RA QĐ -->
                        <DataGridTemplateColumn Header="ĐƠN VỊ RA QĐ" Width="180" HeaderStyle="{StaticResource WrappedHeaderStyle}">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding DecisionUnit}" TextWrapping="Wrap" TextAlignment="Left" HorizontalAlignment="Left" Margin="10,0" VerticalAlignment="Center"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- SỐ LƯỢNG -->
                        <DataGridTemplateColumn Header="SỐ LƯỢNG" Width="110" HeaderStyle="{StaticResource WrappedHeaderStyle}">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Background="#E3F2FD" CornerRadius="12" Padding="10,3" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding ParticipantCount}" FontWeight="Bold" Foreground="#1E88E5" FontSize="14"/>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- CHI TIẾT -->
                        <DataGridTemplateColumn Header="CHI TIẾT" Width="110">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Click="btnDetail_Click" Tag="{Binding Id}"
                                             Height="32" Padding="8 0" VerticalAlignment="Center">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource MaterialDesignFlatButton}">
                                                <Setter Property="Foreground" Value="{DynamicResource PrimaryHueMidBrush}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=DataGridCell}}" Value="True">
                                                        <Setter Property="Foreground" Value="{DynamicResource PrimaryHueMidForegroundBrush}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="Eye" Width="16" Height="16" Margin="0 0 4 0" VerticalAlignment="Center"/>
                                            <TextBlock Text="Chi tiết" FontSize="13" FontWeight="Bold" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Pagination/Count Info (Footer) -->
                <Border Grid.Row="1" Background="#F5F5F5" BorderBrush="#EEEEEE" BorderThickness="0 1 0 0" Padding="15 10">
                    <Grid>
                        <TextBlock x:Name="txtTotalCount" Text="Hiển thị 0 lớp học / hội nghị" VerticalAlignment="Center" FontSize="14" Foreground="#666"/>
                    </Grid>
                </Border>
            </Grid>
        </materialDesign:Card>
    </Grid>
</Page>
