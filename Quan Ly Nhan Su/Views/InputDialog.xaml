<Window x:Class="TaxPersonnelManagement.Views.InputDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Thêm nhiệm kỳ mới" Height="230" Width="380"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        FontFamily="{DynamicResource MaterialDesignFont}"
        Language="vi-VN">

    <Border Background="White" CornerRadius="12" BorderBrush="#E2E8F0" BorderThickness="1" Margin="10">
        <Border.Effect>
            <DropShadowEffect BlurRadius="15" ShadowDepth="3" Opacity="0.15" Color="#000000"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- Title -->
                <RowDefinition Height="*"/>    <!-- Input -->
                <RowDefinition Height="Auto"/> <!-- Buttons -->
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Background="{DynamicResource PrimaryHueMidBrush}" CornerRadius="11 11 0 0" Padding="15 10">
                <Grid>
                    <TextBlock Text="Thêm Nhiệm Kỳ Mới" Foreground="White" FontSize="15" FontWeight="Bold" VerticalAlignment="Center"/>
                    <Button HorizontalAlignment="Right" Click="btnCancel_Click" Background="Transparent" BorderThickness="0" Padding="0" Width="24" Height="24" Style="{DynamicResource MaterialDesignToolButton}">
                        <materialDesign:PackIcon Kind="Close" Foreground="White" Width="18" Height="18"/>
                    </Button>
                </Grid>
            </Border>

            <!-- Input area -->
            <StackPanel Grid.Row="1" Margin="20 15 20 10">
                <TextBlock Text="Nhập nhiệm kỳ quy hoạch mới (ví dụ: 2026-2031):" FontWeight="SemiBold" Foreground="#374151" Margin="0 0 0 8" FontSize="13"/>
                <TextBox x:Name="txtInput" Style="{StaticResource ModernTextBox}" Height="40" Padding="10 0" VerticalContentAlignment="Center"/>
            </StackPanel>

            <!-- Footer -->
            <Border Grid.Row="2" Background="#F8FAFC" CornerRadius="0 0 11 11" BorderBrush="#EDF2F7" BorderThickness="0 1 0 0" Padding="20 12">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="HỦY BỎ" Click="btnCancel_Click" Style="{StaticResource PremiumOutlineButtonStyle}" 
                            BorderBrush="#8A9099" Foreground="#555555"
                            Width="90" Height="36" Margin="0 0 10 0" FontSize="12" FontWeight="Bold"/>
                    <Button Content="XÁC NHẬN" Click="btnConfirm_Click" Style="{StaticResource PremiumButtonStyle}" 
                            Width="110" Height="36" FontSize="12" FontWeight="Bold"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
