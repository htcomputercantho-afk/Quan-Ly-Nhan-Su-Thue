<Window x:Class="TaxPersonnelManagement.Views.AddTrainingClassDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:helpers="clr-namespace:TaxPersonnelManagement.Helpers"
        mc:Ignorable="d"
        Title="Thông tin Lớp học / Hội nghị" Height="480" Width="480"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        FontFamily="{DynamicResource MaterialDesignFont}"
        Language="vi-VN">

    <Window.Resources>
        <!-- Modern DatePicker Style -->
        <Style x:Key="ModernDatePicker" TargetType="DatePicker">
            <Setter Property="Language" Value="vi-VN"/>
            <Setter Property="helpers:DatePickerHelper.FixCalendarLocale" Value="True"/>
            <Setter Property="helpers:DatePickerHelper.EnableSmartDateEntry" Value="True"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#D1D5DB"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Padding" Value="10 0"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DatePicker">
                        <Border x:Name="border" Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="4">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <DatePickerTextBox x:Name="PART_TextBox" 
                                                   Grid.Column="0"
                                                   HorizontalContentAlignment="Stretch"
                                                   VerticalContentAlignment="Center"
                                                   Background="Transparent" 
                                                   BorderThickness="0"
                                                   Padding="{TemplateBinding Padding}"
                                                   Foreground="{TemplateBinding Foreground}"
                                                   FontWeight="{TemplateBinding FontWeight}"
                                                   Focusable="True">
                                    <DatePickerTextBox.Template>
                                        <ControlTemplate TargetType="{x:Type DatePickerTextBox}">
                                            <Grid>
                                                <ScrollViewer x:Name="PART_ContentHost" HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}" />
                                                <TextBlock x:Name="Watermark" Text="dd/MM/yyyy" 
                                                           IsHitTestVisible="False" 
                                                           Foreground="Gray" Opacity="0.7"
                                                           VerticalAlignment="Center" 
                                                           Visibility="Hidden"/>
                                            </Grid>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="Text" Value="">
                                                    <Setter TargetName="Watermark" Property="Visibility" Value="Visible"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </DatePickerTextBox.Template>
                                </DatePickerTextBox>

                                <Button x:Name="PART_Button" 
                                        Grid.Column="1" 
                                        Width="30"
                                        Padding="0"
                                        Margin="0 0 5 0"
                                        Background="Transparent" 
                                        BorderThickness="0"
                                        Foreground="{DynamicResource PrimaryHueMidBrush}"
                                        Style="{DynamicResource MaterialDesignToolButton}">
                                    <materialDesign:PackIcon Kind="CalendarMonth" Width="20" Height="20"/>
                                </Button>

                                <Popup x:Name="PART_Popup" 
                                       AllowsTransparency="True" 
                                       Placement="Bottom" 
                                       StaysOpen="False"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource PrimaryHueMidBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border CornerRadius="12" Background="White" BorderBrush="#E0E0E0" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="15" Direction="-90" RenderingBias="Quality" ShadowDepth="2" Opacity="0.15"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="55"/> <!-- Header -->
                <RowDefinition Height="*"/>    <!-- Content -->
                <RowDefinition Height="70"/>   <!-- Action Buttons -->
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Background="{DynamicResource PrimaryHueMidBrush}" CornerRadius="12 12 0 0" Padding="20 0">
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <materialDesign:PackIcon Kind="School" Foreground="White" Width="24" Height="24" Margin="0 0 10 0" VerticalAlignment="Center"/>
                        <TextBlock x:Name="txtTitle" Text="Thêm Lớp học / Hội nghị" Foreground="White" FontSize="16" FontWeight="Bold" VerticalAlignment="Center"/>
                    </StackPanel>
                    <Button HorizontalAlignment="Right" Click="btnCancel_Click" Background="Transparent" BorderThickness="0" Padding="0" Width="30" Height="30" Style="{DynamicResource MaterialDesignToolButton}">
                        <materialDesign:PackIcon Kind="Close" Foreground="White" Width="22" Height="22"/>
                    </Button>
                </Grid>
            </Border>

            <!-- Content -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="25 15">
                <StackPanel>
                    <!-- Tên các lớp, hội nghị -->
                    <StackPanel Margin="0 0 0 15">
                        <TextBlock Text="Tên các lớp, hội nghị (*)" FontWeight="SemiBold" Foreground="#374151" Margin="0 0 0 5" FontSize="14"/>
                        <TextBox x:Name="txtClassName" Style="{StaticResource ModernTextBox}" Height="40" Padding="10 0" VerticalContentAlignment="Center"/>
                    </StackPanel>

                    <!-- Ngày tham gia -->
                    <StackPanel Margin="0 0 0 15">
                        <TextBlock Text="Ngày tham gia" FontWeight="SemiBold" Foreground="#374151" Margin="0 0 0 5" FontSize="14"/>
                        <DatePicker x:Name="dpParticipationDate" Style="{StaticResource ModernDatePicker}"/>
                    </StackPanel>

                    <!-- Số quyết định -->
                    <StackPanel Margin="0 0 0 15">
                        <TextBlock Text="Số quyết định" FontWeight="SemiBold" Foreground="#374151" Margin="0 0 0 5" FontSize="14"/>
                        <TextBox x:Name="txtDecisionNumber" Style="{StaticResource ModernTextBox}" Height="40" Padding="10 0" VerticalContentAlignment="Center"/>
                    </StackPanel>

                    <!-- Ngày ra quyết định -->
                    <StackPanel Margin="0 0 0 15">
                        <TextBlock Text="Ngày ra quyết định" FontWeight="SemiBold" Foreground="#374151" Margin="0 0 0 5" FontSize="14"/>
                        <DatePicker x:Name="dpDecisionDate" Style="{StaticResource ModernDatePicker}"/>
                    </StackPanel>

                    <!-- Đơn vị ra quyết định -->
                    <StackPanel Margin="0 0 0 15">
                        <TextBlock Text="Đơn vị ra quyết định" FontWeight="SemiBold" Foreground="#374151" Margin="0 0 0 5" FontSize="14"/>
                        <TextBox x:Name="txtDecisionUnit" Style="{StaticResource ModernTextBox}" Height="40" Padding="10 0" VerticalContentAlignment="Center"/>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>

            <!-- Actions -->
            <Border Grid.Row="2" Background="#F9FAFB" CornerRadius="0 0 12 12" BorderBrush="#E5E7EB" BorderThickness="0 1 0 0">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0 0 20 0">
                    <Button x:Name="btnCancel" Content="Hủy bỏ" Click="btnCancel_Click" 
                            Style="{DynamicResource MaterialDesignFlatButton}" Margin="0 0 10 0" Height="40" Width="100"/>
                    <Button x:Name="btnSave" Content="Lưu lại" Click="btnSave_Click" 
                            Style="{DynamicResource MaterialDesignRaisedButton}" 
                            Background="{DynamicResource PrimaryHueMidBrush}" BorderThickness="0" 
                            Height="40" Width="100" materialDesign:ButtonAssist.CornerRadius="4"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
