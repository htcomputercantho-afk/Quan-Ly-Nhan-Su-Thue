<Window x:Class="TaxPersonnelManagement.Views.EditMonthlyIncomeDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Chi tiết thu nhập" Height="500" Width="650" 
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize" 
        WindowStyle="None" Background="Transparent" AllowsTransparency="True">

    <Border Background="White" CornerRadius="16" BorderThickness="1" BorderBrush="#E2E8F0">
        <Border.Effect>
            <DropShadowEffect BlurRadius="30" ShadowDepth="10" Opacity="0.15" Color="#000"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- Header -->
                <RowDefinition Height="*"/>    <!-- List of items -->
                <RowDefinition Height="Auto"/> <!-- Footer Actions -->
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0" Margin="25 20 25 10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="5" Height="24" CornerRadius="2.5" Background="{DynamicResource PrimaryHueMidBrush}" Margin="0 0 12 0"/>
                    <TextBlock x:Name="txtHeaderTitle" Text="Chi tiết thu nhập - Tháng X" FontSize="20" FontWeight="Bold" Foreground="#2D3748" VerticalAlignment="Center"/>
                </StackPanel>
                
                <Button Grid.Column="1" Click="btnCancel_Click" Style="{DynamicResource MaterialDesignIconForegroundButton}" Width="32" Height="32" Foreground="#A0AEC0" ToolTip="Đóng">
                    <materialDesign:PackIcon Kind="Close" Width="20" Height="20"/>
                </Button>
            </Grid>
            
            <!-- List Section -->
            <Border Grid.Row="1" BorderThickness="0 1 0 1" BorderBrush="#EDF2F7" Background="#FAFAFA">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="10 15">
                    <ItemsControl x:Name="lstIncomeItems">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0 4" Height="44">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="180"/> <!-- Amount -->
                                        <ColumnDefinition Width="10"/>
                                        <ColumnDefinition Width="*"/>   <!-- Reason -->
                                        <ColumnDefinition Width="10"/>
                                        <ColumnDefinition Width="Auto"/>  <!-- Delete -->
                                    </Grid.ColumnDefinitions>

                                    <!-- Amount input -->
                                    <Border Grid.Column="0" CornerRadius="8" Background="White" BorderThickness="1" BorderBrush="#E2E8F0">
                                        <Grid>
                                            <TextBox Text="{Binding DisplayAmount, UpdateSourceTrigger=PropertyChanged}" 
                                                     materialDesign:TextFieldAssist.DecorationVisibility="Hidden"
                                                     BorderThickness="0" 
                                                     VerticalAlignment="Center"
                                                     Padding="10 0"
                                                     FontSize="14"
                                                     FontWeight="SemiBold"
                                                     Foreground="#1A202C"
                                                     TextAlignment="Right"
                                                     Background="Transparent"/>
                                            <TextBlock Text="Số tiền (đ)" IsHitTestVisible="False" VerticalAlignment="Center" Margin="12 0" Foreground="#A0AEC0" TextAlignment="Right">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding DisplayAmount}" Value="">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding DisplayAmount}" Value="{x:Null}">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Grid>
                                    </Border>

                                    <!-- Reason input -->
                                    <Border Grid.Column="2" CornerRadius="8" Background="White" BorderThickness="1" BorderBrush="#E2E8F0">
                                        <Grid>
                                            <TextBox Text="{Binding Reason, UpdateSourceTrigger=PropertyChanged}" 
                                                     materialDesign:TextFieldAssist.DecorationVisibility="Hidden"
                                                     BorderThickness="0" 
                                                     VerticalAlignment="Center"
                                                     Padding="10 0"
                                                     FontSize="14"
                                                     Foreground="#4A5568"
                                                     Background="Transparent"/>
                                            <TextBlock Text="Nội dung / Lý do..." IsHitTestVisible="False" VerticalAlignment="Center" Margin="12 0" Foreground="#A0AEC0">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Reason}" Value="">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Reason}" Value="{x:Null}">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Grid>
                                    </Border>

                                    <!-- Delete Button -->
                                    <Button Grid.Column="4" Click="btnDeleteItem_Click" 
                                            Style="{DynamicResource MaterialDesignIconForegroundButton}" 
                                            Width="36" Height="36" Background="Transparent" BorderThickness="0" ToolTip="Xóa">
                                        <materialDesign:PackIcon Kind="TrashCan" Foreground="#D32F2F" Width="22" Height="22"/>
                                    </Button>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>

            <!-- Footer Actions -->
            <Grid Grid.Row="2" Margin="25 15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Add Button -->
                <Button Grid.Column="0" Click="btnAddItem_Click" Style="{DynamicResource MaterialDesignOutlinedButton}" 
                        BorderBrush="#1976D2" Foreground="#1976D2" Height="40" Padding="15 0"
                        materialDesign:ButtonAssist.CornerRadius="8">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Plus" Width="18" Height="18" Margin="0 0 6 0" VerticalAlignment="Center"/>
                        <TextBlock Text="Thêm khoản mới" FontSize="13.5" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <!-- Confirm & Cancel -->
                <Button Grid.Column="2" Click="btnCancel_Click" Style="{DynamicResource MaterialDesignOutlinedButton}" 
                        BorderBrush="#718096" Foreground="#718096" Height="40" Width="100"
                        materialDesign:ButtonAssist.CornerRadius="8">
                    <TextBlock Text="Hủy bỏ" FontSize="13.5" FontWeight="SemiBold"/>
                </Button>

                <Button Grid.Column="4" Click="btnConfirm_Click" Style="{DynamicResource MaterialDesignRaisedButton}" 
                        Background="#2E7D32" BorderBrush="#2E7D32" Foreground="White" Height="40" Width="120"
                        materialDesign:ButtonAssist.CornerRadius="8">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Check" Width="18" Height="18" Margin="0 0 6 0" VerticalAlignment="Center"/>
                        <TextBlock Text="Xác nhận" FontSize="13.5" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Grid>
    </Border>
</Window>
