<Window x:Class="TaxPersonnelManagement.Views.PersonnelSelectorDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        mc:Ignorable="d"
        Title="Chọn cán bộ công chức" Height="580" Width="700"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        FontFamily="{DynamicResource MaterialDesignFont}"
        Language="vi-VN">

    <Border Background="White" CornerRadius="16" BorderBrush="#E2E8F0" BorderThickness="1" Margin="15">
        <Border.Effect>
            <DropShadowEffect BlurRadius="25" ShadowDepth="5" Opacity="0.15" Color="#000000"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- Header -->
                <RowDefinition Height="Auto"/> <!-- Filter & Search -->
                <RowDefinition Height="*"/>    <!-- DataGrid -->
                <RowDefinition Height="Auto"/> <!-- Footer -->
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0" Margin="24 20 24 10" MouseDown="Header_MouseDown" Background="Transparent" Cursor="SizeAll">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="5" Height="24" CornerRadius="2.5" Background="{DynamicResource PrimaryHueMidBrush}" Margin="0 0 12 0"/>
                    <StackPanel>
                        <TextBlock Text="Chọn Cán Bộ Công Chức" FontSize="18.5" FontWeight="Bold" Foreground="#1E293B"/>
                        <TextBlock Text="Chọn nhiều cán bộ cùng lúc theo tổ hoặc toàn bộ để thêm vào danh sách" FontSize="11.5" Foreground="#64748B" Margin="0 2 0 0"/>
                    </StackPanel>
                </StackPanel>
                
                <Button Grid.Column="1" Click="btnClose_Click" Style="{DynamicResource MaterialDesignIconForegroundButton}" Width="32" Height="32" Foreground="#94A3B8" ToolTip="Đóng" Cursor="Hand">
                    <materialDesign:PackIcon Kind="Close" Width="20" Height="20"/>
                </Button>
            </Grid>

            <!-- Filter & Search -->
            <Grid Grid.Row="1" Margin="24 5 24 12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.2*"/> <!-- Combo chọn Tổ -->
                    <ColumnDefinition Width="20"/>    <!-- Gap -->
                    <ColumnDefinition Width="2*"/>   <!-- TextBox tìm kiếm -->
                </Grid.ColumnDefinitions>

                <!-- Combo chọn Tổ -->
                <StackPanel Grid.Column="0">
                    <TextBlock Text="TỔ / BỘ PHẬN" Style="{StaticResource ModernLabel}" Margin="0 0 0 6"/>
                    <ComboBox x:Name="cboDepartmentFilter" Style="{StaticResource ModernComboBox}"
                              materialDesign:HintAssist.Hint="Lọc theo tổ bộ phận"
                              SelectionChanged="Filter_Changed"/>
                </StackPanel>

                <!-- Tìm kiếm -->
                <StackPanel Grid.Column="2">
                    <TextBlock Text="TÌM KIẾM CÁN BỘ" Style="{StaticResource ModernLabel}" Margin="0 0 0 6"/>
                    <TextBox x:Name="txtSearchQuery" Style="{StaticResource ModernTextBox}"
                             materialDesign:HintAssist.Hint="Tìm theo họ tên, số CCCD..."
                             TextChanged="Filter_Changed"/>
                </StackPanel>
            </Grid>

            <!-- DataGrid -->
            <Border Grid.Row="2" Margin="24 0 24 15" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8" Background="White" ClipToBounds="True">
                <DataGrid x:Name="dgPersonnelSelector" AutoGenerateColumns="False" IsReadOnly="False" 
                          CanUserAddRows="False" HeadersVisibility="Column"
                          BorderThickness="0"
                          VerticalGridLinesBrush="Transparent"
                          HorizontalGridLinesBrush="#EEEEEE"
                          GridLinesVisibility="Horizontal" 
                          MinRowHeight="40" VerticalContentAlignment="Center"
                          SelectionMode="Single"
                          ScrollViewer.HorizontalScrollBarVisibility="Auto">
                    
                    <DataGrid.Resources>
                        <!-- Style Header chung -->
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="FontWeight" Value="Bold"/>
                            <Setter Property="FontSize" Value="13"/>
                            <Setter Property="Background" Value="#F8FAFC"/>
                            <Setter Property="Foreground" Value="#475569"/>
                            <Setter Property="Height" Value="42"/>
                            <Setter Property="BorderThickness" Value="0 0 0 1"/>
                            <Setter Property="BorderBrush" Value="#E2E8F0"/>
                        </Style>
                        
                        <!-- Style Cell chung -->
                        <Style TargetType="DataGridCell">
                            <Setter Property="FontSize" Value="14"/>
                            <Setter Property="Padding" Value="5"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="{x:Type DataGridCell}">
                                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" SnapsToDevicePixels="True">
                                            <ContentPresenter SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" VerticalAlignment="Center" HorizontalAlignment="Stretch"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource PrimaryHueMidBrush}"/>
                                    <Setter Property="Foreground" Value="{DynamicResource PrimaryHueMidForegroundBrush}"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.Resources>

                    <DataGrid.Columns>
                        <!-- CheckBox Select -->
                        <DataGridTemplateColumn Width="50">
                            <DataGridTemplateColumn.HeaderStyle>
                                <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource {x:Type DataGridColumnHeader}}">
                                    <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                </Style>
                            </DataGridTemplateColumn.HeaderStyle>
                            <DataGridTemplateColumn.Header>
                                <CheckBox x:Name="chkSelectAll" Click="chkSelectAll_Click" HorizontalAlignment="Center"/>
                            </DataGridTemplateColumn.Header>
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <CheckBox IsChecked="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}" 
                                              Checked="chkPersonnel_CheckedChanged" 
                                              Unchecked="chkPersonnel_CheckedChanged" 
                                              HorizontalAlignment="Center"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- STT -->
                        <DataGridTextColumn Header="STT" Binding="{Binding STT}" Width="55" IsReadOnly="True">
                            <DataGridTextColumn.HeaderStyle>
                                <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource {x:Type DataGridColumnHeader}}">
                                    <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.HeaderStyle>
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <!-- HỌ VÀ TÊN -->
                        <DataGridTemplateColumn Header="HỌ VÀ TÊN" Width="2*" MinWidth="180" IsReadOnly="True">
                            <DataGridTemplateColumn.HeaderStyle>
                                <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource {x:Type DataGridColumnHeader}}">
                                    <Setter Property="HorizontalContentAlignment" Value="Left"/>
                                    <Setter Property="Padding" Value="10 0 0 0"/>
                                </Style>
                            </DataGridTemplateColumn.HeaderStyle>
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding FullName}" VerticalAlignment="Center" FontWeight="Medium" FontSize="14" Margin="10 0 0 0"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- SỐ CCCD -->
                        <DataGridTextColumn Header="SỐ CCCD" Binding="{Binding IdentityCardNumber}" Width="1.5*" MinWidth="130" IsReadOnly="True">
                            <DataGridTextColumn.HeaderStyle>
                                <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource {x:Type DataGridColumnHeader}}">
                                    <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.HeaderStyle>
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <!-- BỘ PHẬN CÔNG TÁC -->
                        <DataGridTemplateColumn Header="BỘ PHẬN CÔNG TÁC" Width="2*" MinWidth="180" IsReadOnly="True">
                            <DataGridTemplateColumn.HeaderStyle>
                                <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource {x:Type DataGridColumnHeader}}">
                                    <Setter Property="HorizontalContentAlignment" Value="Left"/>
                                    <Setter Property="Padding" Value="10 0 0 0"/>
                                </Style>
                            </DataGridTemplateColumn.HeaderStyle>
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Background="#E8EAF6" CornerRadius="4" Padding="6,2" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="10 0 0 0">
                                        <TextBlock Text="{Binding Department}" FontSize="13" FontWeight="SemiBold" Foreground="#3949AB"/>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <!-- Footer -->
            <Border Grid.Row="3" Background="#F8FAFC" CornerRadius="0 0 16 16" BorderBrush="#EDF2F7" BorderThickness="0 1 0 0" Padding="24 16">
                <Grid>
                    <TextBlock x:Name="lblSelectionCount" Text="Đã chọn: 0 / 0 cán bộ" VerticalAlignment="Center" HorizontalAlignment="Left" FontWeight="SemiBold" Foreground="#475569"/>
                    
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="HỦY BỎ" Click="btnClose_Click" Style="{StaticResource PremiumOutlineButtonStyle}" 
                                BorderBrush="#8A9099" Foreground="#555555"
                                Width="105" Height="40" Margin="0 0 12 0" FontSize="13" FontWeight="Bold"/>
                        <Button x:Name="btnConfirm" Content="XÁC NHẬN THÊM" Click="btnConfirm_Click" Style="{StaticResource PremiumButtonStyle}" 
                                Width="160" Height="40" FontSize="13" FontWeight="Bold"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
