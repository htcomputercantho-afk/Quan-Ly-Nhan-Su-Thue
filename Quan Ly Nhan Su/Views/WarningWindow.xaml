<Window x:Class="TaxPersonnelManagement.Views.WarningWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        SizeToContent="Height" Width="400"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Topmost="True"
        Background="Transparent">
    
    <Border Background="White" CornerRadius="20" Margin="20">
        <Border.Effect>
            <DropShadowEffect BlurRadius="30" ShadowDepth="0" Opacity="0.2" Color="Black"/>
        </Border.Effect>
        <Grid Margin="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Top Indicator Bar -->
            <Border Grid.Row="0" Height="6" Background="#ED8936" CornerRadius="20 20 0 0"/>

            <StackPanel Grid.Row="1" Margin="30 25 30 10" VerticalAlignment="Center">
                <Border Width="70" Height="70" CornerRadius="35" Background="#FFF5F0" HorizontalAlignment="Center" Margin="0 0 0 20">
                    <materialDesign:PackIcon Kind="AlertCircleOutline" Width="40" Height="40" Foreground="#DD6B20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                
                <TextBlock x:Name="txtTitle" Text="Cảnh Báo" FontSize="22" FontWeight="Bold" Foreground="#2D3748" HorizontalAlignment="Center" Margin="0 0 0 12"/>
                <TextBlock x:Name="txtMessage" Text="Nội dung cảnh báo..." FontSize="15" Foreground="#4A5568" TextWrapping="Wrap" TextAlignment="Center" HorizontalAlignment="Center" LineHeight="22"/>
            </StackPanel>
            
            <Border Grid.Row="2" Background="#F7FAFC" CornerRadius="0 0 20 20" Padding="0 20">
                <Button Content="ĐÃ HIỂU" Click="Close_Click" 
                        Width="140" Height="45"
                        materialDesign:ButtonAssist.CornerRadius="10"
                        Style="{DynamicResource MaterialDesignRaisedButton}"
                        Background="#ED8936" BorderBrush="#ED8936" Foreground="White"
                        FontSize="14" FontWeight="Bold"
                        HorizontalAlignment="Center">
                    <Button.Effect>
                        <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.1" Color="#ED8936"/>
                    </Button.Effect>
                </Button>
            </Border>
        </Grid>
    </Border>
</Window>
