<Window x:Class="TaxPersonnelManagement.Views.SalaryConfigDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        mc:Ignorable="d"
        Title="Thiết lập Bảng lương theo Ngạch" Height="450" Width="700"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        FontFamily="{DynamicResource MaterialDesignFont}"
        Language="vi-VN">

    <Border CornerRadius="10" Background="White" BorderBrush="#E0E0E0" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="15" Direction="-90" RenderingBias="Quality" ShadowDepth="2" Opacity="0.1"/>
        </Border.Effect>
        <Grid Grid.IsSharedSizeScope="True">
            <Grid.RowDefinitions>
                <RowDefinition Height="50"/> <!-- Header -->
                <RowDefinition Height="Auto"/> <!-- Selection -->
                <RowDefinition Height="Auto"/> <!-- Divider -->
                <RowDefinition Height="Auto"/> <!-- Input -->
                <RowDefinition Height="Auto"/> <!-- List Header -->
                <RowDefinition Height="*"/>    <!-- List Content -->
                <RowDefinition Height="20"/>   <!-- Footer Padding -->
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Background="#1976D2" CornerRadius="10 10 0 0" Padding="15 0">
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <materialDesign:PackIcon Kind="TableCog" Foreground="White" Width="24" Height="24" Margin="0 0 10 0"/>
                        <TextBlock Text="Thiết lập Bảng lương theo Ngạch" Foreground="White" FontSize="16" FontWeight="Bold" VerticalAlignment="Center"/>
                    </StackPanel>
                    <Button HorizontalAlignment="Right" Click="btnClose_Click" Background="Transparent" BorderThickness="0" Padding="0" Width="30" Height="30">
                        <materialDesign:PackIcon Kind="Close" Foreground="White" Width="20" Height="20"/>
                    </Button>
                </Grid>
            </Border>

            <!-- Selection -->
            <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0 20 0 10">
                <TextBlock Text="Chọn Mã ngạch:" VerticalAlignment="Center" FontWeight="Bold" Margin="0 0 10 0"/>
                <ComboBox x:Name="cboRank" Width="300" 
                          Style="{StaticResource ModernComboBox}"
                          materialDesign:HintAssist.Hint="-- Chọn ngạch để thiết lập --"
                          DisplayMemberPath="Code"
                          SelectionChanged="cboRank_SelectionChanged"
                          IsEditable="False"/>
            </StackPanel>

            <!-- Divider -->
            <Separator Grid.Row="2" Margin="20 5"/>

            <!-- Input Row -->
            <Grid Grid.Row="3" Margin="20 10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="15"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="15"/>
                    <ColumnDefinition Width="180"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="Bậc lương" Style="{StaticResource ModernLabel}"/>
                    <TextBox x:Name="txtSalaryStep" materialDesign:HintAssist.Hint="VD: 1/9" Style="{StaticResource ModernTextBox}" Height="40" Padding="10 0" VerticalContentAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <TextBlock Text="Hệ số tương ứng" Style="{StaticResource ModernLabel}"/>
                    <TextBox x:Name="txtCoefficient" materialDesign:HintAssist.Hint="VD: 2.34 hoặc 3.00" Style="{StaticResource ModernTextBox}" Height="40" Padding="10 0" VerticalContentAlignment="Center" PreviewTextInput="NumberValidationTextBox"/>
                </StackPanel>

                <Button x:Name="btnAdd" Grid.Column="4" VerticalAlignment="Bottom" Height="40" 
                        Background="#2E7D32" BorderThickness="0" Foreground="White"
                        Click="btnAdd_Click" materialDesign:ButtonAssist.CornerRadius="4">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="PlusCircle" Margin="0 0 8 0" VerticalAlignment="Center"/>
                        <TextBlock Text="Thêm vào bảng" FontWeight="Bold" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </Grid>

            <!-- List Header -->
            <StackPanel Grid.Row="4" Margin="20 10 20 0">
                <StackPanel Orientation="Horizontal" Margin="0 0 0 5">
                    <materialDesign:PackIcon Kind="FormatListBulleted" Foreground="#1976D2" Margin="0 0 5 0"/>
                    <TextBlock Text="Bảng hệ số chi tiết" FontWeight="Bold" Foreground="#1976D2"/>
                </StackPanel>
                <Border BorderBrush="#E0E0E0" BorderThickness="0 0 0 1" Padding="15 8" Background="White">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" SharedSizeGroup="ColIcon"/> <!-- Icon Spacer -->
                            <ColumnDefinition Width="*"/>    <!-- Text Info (No SharedSizeGroup for Star sizing) -->
                            <ColumnDefinition Width="Auto" SharedSizeGroup="ColBadge"/> <!-- Badge -->
                            <ColumnDefinition Width="80" SharedSizeGroup="ColAction"/>   <!-- Action -->
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Width="40" Margin="0 0 15 0"/> <!-- Spacer to match Icon -->
                        <TextBlock Grid.Column="1" Text="BẬC LƯƠNG" FontWeight="Bold" Foreground="#555" FontSize="12" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="2" Text="HỆ SỐ" FontWeight="Bold" Foreground="#555" FontSize="12" Margin="0 0 20 0" HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="3" Text="THAO TÁC" FontWeight="Bold" Foreground="#555" FontSize="12" HorizontalAlignment="Center"/>
                    </Grid>
                </Border>
            </StackPanel>

            <!-- List Content -->
            <Border Grid.Row="5" Margin="20 0 20 0" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="0 0 4 4">
                <Grid>
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="lstSalarySpecs">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="#F0F0F0" BorderThickness="0 0 0 1" Padding="15 12" Background="White">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" SharedSizeGroup="ColIcon"/> <!-- Icon -->
                                                <ColumnDefinition Width="*"/>    <!-- Text Info (No SharedSizeGroup for Star sizing) -->
                                                <ColumnDefinition Width="Auto" SharedSizeGroup="ColBadge"/> <!-- Badge -->
                                                <ColumnDefinition Width="80" SharedSizeGroup="ColAction"/>   <!-- Action -->
                                            </Grid.ColumnDefinitions>

                                            <!-- 1. Icon -->
                                            <Border Grid.Column="0" Width="40" Height="40" CornerRadius="20" Background="#E3F2FD" Margin="0 0 15 0">
                                                <materialDesign:PackIcon Kind="Layers" Width="20" Height="20" Foreground="#1976D2" 
                                                                         HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>

                                            <!-- 2. Text Info -->
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="BẬC LƯƠNG" FontSize="10" Foreground="#888" FontWeight="SemiBold" Margin="0 0 0 2"/>
                                                <TextBlock Text="{Binding SalaryStep}" FontSize="15" FontWeight="Bold" Foreground="#333"/>
                                            </StackPanel>

                                            <!-- 3. Coefficient Badge -->
                                            <Border Grid.Column="2" Background="#0F9D58" CornerRadius="12" Padding="12 4" VerticalAlignment="Center" Margin="0 0 20 0">
                                                <TextBlock Text="{Binding Coefficient, StringFormat=N2}" Foreground="White" FontWeight="Bold" FontSize="14"/>
                                            </Border>

                                            <!-- 4. Delete Action -->
                                            <Button Grid.Column="3" Click="btnDelete_Click" Tag="{Binding Id}"
                                                    Width="35" Height="35" Background="Transparent" BorderThickness="0" Padding="0"
                                                    Style="{DynamicResource MaterialDesignToolButton}"
                                                    ToolTip="Xóa cấu hình này" Foreground="#E53935">
                                                <materialDesign:PackIcon Kind="DeleteOutline" Width="22" Height="22"/>
                                            </Button>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                    <!-- Empty State Message -->
                    <TextBlock x:Name="lblEmptyState" Text="Vui lòng chọn ngạch ở trên để xem dữ liệu" 
                               HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="Gray"
                               Visibility="Visible"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
