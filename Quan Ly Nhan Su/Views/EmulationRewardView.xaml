<Page x:Class="TaxPersonnelManagement.Views.EmulationRewardView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      mc:Ignorable="d" 
      d:DesignHeight="700" d:DesignWidth="1000"
      Title="Thi đua khen thưởng">
    
    <Page.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesignTheme.Defaults.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Page.Resources>

    <Grid Background="#F5F5F5" Margin="20">
        <!-- Main Layout: 2 Columns -->
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320"/>
            <ColumnDefinition Width="20"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- LEFT PANE: PERSONNEL LIST -->
        <Border Grid.Column="0" Background="White" CornerRadius="12" Effect="{DynamicResource MaterialDesignShadowDepth2}">
            <Grid Margin="15">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/> <!-- Header Text -->
                    <RowDefinition Height="Auto"/> <!-- Search -->
                    <RowDefinition Height="*"/>    <!-- ListView -->
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="DANH SÁCH CÔNG CHỨC" FontWeight="Bold" FontSize="16" Foreground="#1976D2" Margin="0 0 0 15"/>

                <Border Grid.Row="1" Margin="0 0 0 15" Background="#F8F9FA" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="8" Padding="10 5">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Magnify" Width="20" Height="20" Foreground="Gray" VerticalAlignment="Center" Margin="0 0 8 0"/>
                        <TextBox x:Name="txtSearch" Width="240" materialDesign:HintAssist.Hint="Tìm kiếm theo Tên, CCCD..." 
                                 materialDesign:TextFieldAssist.DecorationVisibility="Collapsed"
                                 BorderThickness="0" Background="Transparent" VerticalAlignment="Center"
                                 TextChanged="TxtSearch_TextChanged"/>
                    </StackPanel>
                </Border>

                <ListView x:Name="lvPersonnel" Grid.Row="2" SelectionChanged="LvPersonnel_SelectionChanged" 
                          BorderThickness="0" Background="Transparent"
                          ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="5 8">
                                <TextBlock Text="{Binding FullName}" FontWeight="Bold" FontSize="15" Foreground="#333333" TextWrapping="Wrap"/>
                                <StackPanel Orientation="Horizontal" Margin="0 3 0 0">
                                    <materialDesign:PackIcon Kind="IdCard" Width="14" Height="14" Foreground="Gray" VerticalAlignment="Center" Margin="0 0 5 0"/>
                                    <TextBlock Text="{Binding IdentityCardNumber}" FontSize="13" Foreground="Gray" VerticalAlignment="Center"/>
                                </StackPanel>
                            </StackPanel>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="Padding" Value="10 5"/>
                            <Setter Property="Margin" Value="0 2"/>
                            <Setter Property="materialDesign:ListBoxItemAssist.CornerRadius" Value="8"/>
                        </Style>
                    </ListView.ItemContainerStyle>
                </ListView>
            </Grid>
        </Border>

        <!-- RIGHT PANE: HEADER & CARDS -->
        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Top Header for Right Pane -->
            <Grid Grid.Row="0" Margin="0 0 20 15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock x:Name="txtPrompt" Grid.Column="0" 
                           Text="Vui lòng chọn một công chức bên trái để xem danh hiệu thi đua, khen thưởng." 
                           Foreground="#78909C" FontStyle="Italic" FontSize="14" 
                           VerticalAlignment="Center" HorizontalAlignment="Left"/>

                <Button x:Name="btnExportExcel" Grid.Column="1" Height="38" Click="BtnExportExcel_Click" 
                        Style="{DynamicResource MaterialDesignRaisedButton}"
                        Background="#2E7D32" BorderBrush="#2E7D32" Foreground="White" Padding="16,0"
                        materialDesign:ButtonAssist.CornerRadius="19" VerticalAlignment="Center"
                        Effect="{DynamicResource MaterialDesignShadowDepth1}">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="FileExcel" Width="20" Height="20" Margin="0 0 8 0" VerticalAlignment="Center" Foreground="White"/>
                        <TextBlock Text="Xuất Excel" FontWeight="Bold" VerticalAlignment="Center" FontSize="14"/>
                    </StackPanel>
                </Button>
            </Grid>

            <!-- Scrollable Content -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel x:Name="pnlDetails" IsEnabled="False" Opacity="0.5">

                    <!-- CARD 1: EMULATION (Danh hiệu thi đua) -->
                    <materialDesign:Card UniformCornerRadius="12" materialDesign:ElevationAssist.Elevation="Dp3" Padding="0" Margin="0 0 20 20">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- Card Header -->
                            <Border Grid.Row="0" CornerRadius="12 12 0 0" Padding="25 15">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#1976D2" Offset="0.0"/>
                                        <GradientStop Color="#42A5F5" Offset="1.0"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="Medal" Width="26" Height="26" Foreground="White" VerticalAlignment="Center" Margin="0 0 12 0"/>
                                    <TextBlock Text="DANH HIỆU THI ĐUA" FontSize="18" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>

                            <!-- Card Body -->
                            <StackPanel Grid.Row="1" Margin="25">
                                <TextBlock TextWrapping="Wrap" FontSize="14" Foreground="#546E7A" Margin="0 0 0 15">
                                    Danh sách các danh hiệu thi đua mà Công chức đã đạt được.
                                </TextBlock>

                                <Border Background="#F5F5F5" CornerRadius="8" Padding="15" Margin="0 0 0 10">
                                    <TextBox x:Name="txtEmulationTitles" AcceptsReturn="True" TextWrapping="Wrap" 
                                             IsReadOnly="True"
                                             VerticalScrollBarVisibility="Auto" MinHeight="100" MaxHeight="250"
                                             FontSize="15" materialDesign:HintAssist.Hint="Không có dữ liệu danh hiệu"
                                             materialDesign:TextFieldAssist.DecorationVisibility="Collapsed" BorderThickness="0" Background="Transparent"/>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </materialDesign:Card>


                    <!-- CARD 2: REWARDS (Hình thức khen thưởng) -->
                    <materialDesign:Card UniformCornerRadius="12" materialDesign:ElevationAssist.Elevation="Dp3" Padding="0" Margin="0 0 20 20">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- Card Header -->
                            <Border Grid.Row="0" CornerRadius="12 12 0 0" Padding="25 15">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#E65100" Offset="0.0"/>
                                        <GradientStop Color="#FB8C00" Offset="1.0"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="Gift" Width="26" Height="26" Foreground="White" VerticalAlignment="Center" Margin="0 0 12 0"/>
                                    <TextBlock Text="HÌNH THỨC KHEN THƯỞNG" FontSize="18" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>

                            <!-- Card Body -->
                            <StackPanel Grid.Row="1" Margin="25">
                                <TextBlock TextWrapping="Wrap" FontSize="14" Foreground="#546E7A" Margin="0 0 0 15">
                                    Danh sách các hình thức khen thưởng mà Công chức đã đạt được.
                                </TextBlock>

                                <Border Background="#FFF3E0" CornerRadius="8" Padding="15" Margin="0 0 0 10">
                                    <TextBox x:Name="txtRewardForms" AcceptsReturn="True" TextWrapping="Wrap" 
                                             IsReadOnly="True"
                                             VerticalScrollBarVisibility="Auto" MinHeight="100" MaxHeight="250"
                                             FontSize="15" materialDesign:HintAssist.Hint="Không có dữ liệu khen thưởng"
                                             materialDesign:TextFieldAssist.DecorationVisibility="Collapsed" BorderThickness="0" Background="Transparent"/>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </materialDesign:Card>

                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</Page>
