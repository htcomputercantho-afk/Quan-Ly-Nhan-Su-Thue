<Window x:Class="TaxPersonnelManagement.Views.SuccessWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Height="380" Width="460"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True">

    <Window.Triggers>
        <EventTrigger RoutedEvent="Window.Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.3"/>
                    <ThicknessAnimation Storyboard.TargetProperty="Margin" From="0 20 0 -20" To="0" Duration="0:0:0.3">
                        <ThicknessAnimation.EasingFunction>
                            <CubicEase EasingMode="EaseOut"/>
                        </ThicknessAnimation.EasingFunction>
                    </ThicknessAnimation>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Window.Triggers>

    <Border Background="White" CornerRadius="16" Margin="15">
        <Border.Effect>
            <DropShadowEffect BlurRadius="40" ShadowDepth="4" Opacity="0.2" Color="#1565C0"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Gradient Header Bar -->
            <Border Grid.Row="0" CornerRadius="16 16 0 0" Padding="0 28 0 22">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#1565C0" Offset="0"/>
                        <GradientStop Color="#1E88E5" Offset="0.5"/>
                        <GradientStop Color="#42A5F5" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <StackPanel HorizontalAlignment="Center">
                    <!-- Animated Check Icon -->
                    <Border Width="64" Height="64" CornerRadius="32" Background="#FFFFFF" HorizontalAlignment="Center">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="12" Opacity="0.25" Color="#000000" ShadowDepth="2"/>
                        </Border.Effect>
                        <materialDesign:PackIcon Kind="Check" Width="36" Height="36" 
                                                 Foreground="#43A047" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </StackPanel>
            </Border>

            <!-- Message Content -->
            <StackPanel Grid.Row="1" VerticalAlignment="Center" Margin="30 20 30 10">
                <TextBlock x:Name="txtMessage" Text="Thành công!" 
                           FontSize="22" FontWeight="Bold" Foreground="#212121" 
                           HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap"/>
                <TextBlock x:Name="txtSubMessage" Text="" 
                           FontSize="13" Foreground="#78909C" Margin="0 10 0 0"
                           HorizontalAlignment="Center" TextAlignment="Center" 
                           TextWrapping="NoWrap" TextTrimming="CharacterEllipsis"
                           MaxWidth="380" ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}"
                           Visibility="Collapsed" FontStyle="Italic"/>
            </StackPanel>
            
            <!-- Actions -->
            <StackPanel Grid.Row="2" Margin="25 5 25 25">
                <!-- File Action Buttons -->
                <StackPanel x:Name="pnlActions" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0 0 0 15" Visibility="Collapsed">
                    <Button x:Name="btnOpenFile" Click="OpenFile_Click" Height="40" Padding="18 0"
                            Margin="0 0 12 0" Cursor="Hand"
                            Background="#E8F5E9" BorderBrush="#A5D6A7" BorderThickness="1.5"
                            materialDesign:ButtonAssist.CornerRadius="20">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource MaterialDesignFlatButton}">
                                <Setter Property="Foreground" Value="#2E7D32"/>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="FileDocumentOutline" Width="18" Height="18" 
                                                     VerticalAlignment="Center" Margin="0 0 8 0"/>
                            <TextBlock Text="Mở tệp" FontWeight="SemiBold" FontSize="13" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    
                    <Button x:Name="btnOpenFolder" Click="OpenFolder_Click" Height="40" Padding="18 0"
                            Cursor="Hand"
                            Background="#E3F2FD" BorderBrush="#90CAF9" BorderThickness="1.5"
                            materialDesign:ButtonAssist.CornerRadius="20">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource MaterialDesignFlatButton}">
                                <Setter Property="Foreground" Value="#1565C0"/>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="FolderOpenOutline" Width="18" Height="18" 
                                                     VerticalAlignment="Center" Margin="0 0 8 0"/>
                            <TextBlock Text="Mở thư mục" FontWeight="SemiBold" FontSize="13" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- Close Button -->
                <Button Content="Đóng" Click="Close_Click" 
                        Width="160" Height="44" FontSize="14" FontWeight="Bold"
                        Foreground="White" Cursor="Hand"
                        materialDesign:ButtonAssist.CornerRadius="22"
                        HorizontalAlignment="Center">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource MaterialDesignRaisedButton}">
                            <Setter Property="Background">
                                <Setter.Value>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#1565C0" Offset="0"/>
                                        <GradientStop Color="#1E88E5" Offset="1"/>
                                    </LinearGradientBrush>
                                </Setter.Value>
                            </Setter>
                            <Setter Property="BorderThickness" Value="0"/>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</Window>
