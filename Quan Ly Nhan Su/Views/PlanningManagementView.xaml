<Page x:Class="TaxPersonnelManagement.Views.PlanningManagementView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      xmlns:converters="clr-namespace:TaxPersonnelManagement.Converters"
      mc:Ignorable="d" 
      Language="vi-VN"
      d:DesignHeight="700" d:DesignWidth="1200"
      Title="Quản Lý Quy hoạch Nhân sự">

    <Page.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesignTheme.Defaults.xaml" />
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesignTheme.Shadows.xaml" />
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesignTheme.Button.xaml" />
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesignTheme.TabControl.xaml" />
            </ResourceDictionary.MergedDictionaries>
            
            <converters:DateFormatterConverter x:Key="DateFormatterConverter"/>
            <converters:EmptyStringToDashConverter x:Key="EmptyStringToDashConverter"/>

            <!-- Custom TabItem Style -->
            <Style x:Key="ModernTabItem" TargetType="TabItem">
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="FontWeight" Value="Bold"/>
                <Setter Property="Background" Value="#E0E0E0"/>
                <Setter Property="Foreground" Value="#555555"/>
                <Setter Property="Margin" Value="0 0 10 0"/>
                <Setter Property="Padding" Value="20 10"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="TabItem">
                            <Grid>
                                <Border x:Name="border" 
                                        Background="{TemplateBinding Background}" 
                                        CornerRadius="20" 
                                        Padding="{TemplateBinding Padding}"
                                        Margin="2" 
                                        BorderThickness="1"
                                        BorderBrush="Transparent">
                                    <ContentPresenter ContentSource="Header" 
                                                      HorizontalAlignment="Center" 
                                                      VerticalAlignment="Center"/>
                                </Border>
                            </Grid>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter TargetName="border" Property="Background" Value="{DynamicResource PrimaryHueMidBrush}"/>
                                    <Setter Property="Foreground" Value="White"/>
                                    <Setter TargetName="border" Property="Effect">
                                        <Setter.Value>
                                            <DropShadowEffect ShadowDepth="2" BlurRadius="5" Opacity="0.3" Direction="270"/>
                                        </Setter.Value>
                                    </Setter>
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource PrimaryHueMidBrush}"/>
                                    <Setter Property="Foreground" Value="{DynamicResource PrimaryHueMidBrush}"/>
                                </Trigger>
                                <MultiTrigger>
                                    <MultiTrigger.Conditions>
                                        <Condition Property="IsMouseOver" Value="True"/>
                                        <Condition Property="IsSelected" Value="True"/>
                                    </MultiTrigger.Conditions>
                                    <Setter TargetName="border" Property="BorderBrush" Value="Transparent"/>
                                    <Setter Property="Foreground" Value="White"/>
                                </MultiTrigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Custom TabControl Style -->
            <Style x:Key="ModernTabControl" TargetType="TabControl">
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="TabControl">
                            <Grid KeyboardNavigation.TabNavigation="Local">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                
                                <!-- Tab Headers Panel -->
                                <WrapPanel IsItemsHost="True" Grid.Row="0" Margin="0 0 0 15" KeyboardNavigation.TabIndex="1"/>
                                
                                <!-- Content Panel -->
                                <Border Grid.Row="1" Background="{TemplateBinding Background}" BorderThickness="{TemplateBinding BorderThickness}" Padding="{TemplateBinding Padding}"
                                        KeyboardNavigation.TabIndex="2" KeyboardNavigation.TabNavigation="Local" KeyboardNavigation.DirectionalNavigation="Contained">
                                    <ContentPresenter x:Name="PART_SelectedContentHost" ContentSource="SelectedContent"/>
                                </Border>
                            </Grid>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Style for Grouping Header -->
            <Style x:Key="PlanningGroupHeaderStyle" TargetType="GroupItem">
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="GroupItem">
                            <Expander IsExpanded="True" Background="White" BorderBrush="#E5E7EB" BorderThickness="0 0 0 1">
                                <Expander.Header>
                                    <Border Background="#E8F5E9" Padding="15 8" CornerRadius="4" Margin="5 2">
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="FolderStar" Width="20" Height="20" Foreground="#2E7D32" VerticalAlignment="Center" Margin="0 0 8 0"/>
                                            <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="15" Foreground="#2E7D32" VerticalAlignment="Center"/>
                                            <TextBlock Text=" (" Foreground="#666" FontSize="14" VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding ItemCount}" FontWeight="Bold" Foreground="#2E7D32" FontSize="14" VerticalAlignment="Center"/>
                                            <TextBlock Text=" cán bộ)" Foreground="#666" FontSize="14" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                </Expander.Header>
                                <ItemsPresenter />
                            </Expander>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </ResourceDictionary>
    </Page.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0 0 0 15">
            <materialDesign:PackIcon Kind="AccountStar" Width="28" Height="28" Foreground="{DynamicResource PrimaryHueMidBrush}" VerticalAlignment="Center" Margin="0 0 10 0"/>
            <TextBlock Text="QUẢN LÝ QUY HOẠCH NHÂN SỰ" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource PrimaryHueMidBrush}" VerticalAlignment="Center"/>
        </StackPanel>

        <!-- Tab Control for Professional / Party Planning -->
        <materialDesign:Card Grid.Row="1" Style="{DynamicResource MaterialDesignCard}" UniformCornerRadius="12">
            <TabControl x:Name="tcPlanning" Style="{StaticResource ModernTabControl}" 
                        Background="Transparent" BorderThickness="0" Padding="0" SelectionChanged="tcPlanning_SelectionChanged">
                <TabControl.Resources>
                    <Style TargetType="TabItem" BasedOn="{StaticResource ModernTabItem}"/>
                </TabControl.Resources>
                
                <!-- TAB 1: QUY HOẠCH CHUYÊN MÔN -->
                <TabItem Header="QUY HOẠCH CHUYÊN MÔN">
                    <Border Background="#F5F5F5" Padding="15">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                        <!-- Toolbar -->
                        <materialDesign:Card Grid.Row="0" Margin="0 0 0 15" Padding="16 12" UniformCornerRadius="8">
                            <WrapPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <!-- Search -->
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0 0 15 8">
                                    <materialDesign:PackIcon Kind="Magnify" Width="22" Height="22" Foreground="{DynamicResource PrimaryHueMidBrush}" VerticalAlignment="Center" Margin="0 0 8 0"/>
                                    <Border Background="White" CornerRadius="4" BorderBrush="#D1D5DB" BorderThickness="1" Width="200" Height="36">
                                        <TextBox x:Name="txtSearchProf"
                                                 materialDesign:HintAssist.Hint="Tìm Họ tên, CCCD..."
                                                 materialDesign:TextFieldAssist.DecorationVisibility="Hidden"
                                                 materialDesign:TextFieldAssist.HasClearButton="True"
                                                 BorderThickness="0" Background="Transparent"
                                                 VerticalContentAlignment="Center" Padding="8 0" FontSize="14"
                                                 TextChanged="FilterProf_Changed"/>
                                    </Border>
                                </StackPanel>

                                <!-- Department -->
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0 0 15 8">
                                    <TextBlock Text="Bộ phận:" VerticalAlignment="Center" FontWeight="Bold" Margin="0 0 8 0" Foreground="#555" FontSize="14"/>
                                    <ComboBox x:Name="cboDeptProf" Width="220" Height="36" SelectionChanged="FilterProf_Changed" 
                                              BorderThickness="1" BorderBrush="#D1D5DB" Background="White" Foreground="Black" Padding="8 0" VerticalContentAlignment="Center"/>
                                </StackPanel>

                                <!-- Planning Term -->
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0 0 15 8">
                                    <TextBlock Text="Nhiệm kỳ:" VerticalAlignment="Center" FontWeight="Bold" Margin="0 0 8 0" Foreground="#555" FontSize="14"/>
                                    <ComboBox x:Name="cboTermProf" Width="160" Height="36" SelectionChanged="FilterProf_Changed" 
                                              BorderThickness="1" BorderBrush="#D1D5DB" Background="White" Foreground="Black" Padding="8 0" VerticalContentAlignment="Center">
                                    </ComboBox>
                                </StackPanel>

                                <!-- Status (Phân loại) -->
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0 0 15 8">
                                    <TextBlock Text="Trạng thái:" VerticalAlignment="Center" FontWeight="Bold" Margin="0 0 8 0" Foreground="#555" FontSize="14"/>
                                    <ComboBox x:Name="cboStatusProf" Width="180" Height="36" SelectionChanged="FilterProf_Changed" 
                                              BorderThickness="1" BorderBrush="#D1D5DB" Background="White" Foreground="Black" Padding="8 0" VerticalContentAlignment="Center">
                                        <ComboBoxItem Content="Tất cả trạng thái" IsSelected="True"/>
                                        <ComboBoxItem Content="1. Tiếp tục quy hoạch"/>
                                        <ComboBoxItem Content="2. Đưa ra khỏi quy hoạch"/>
                                        <ComboBoxItem Content="3. Bổ sung quy hoạch"/>
                                    </ComboBox>
                                </StackPanel>

                                <!-- Actions -->
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0 0 0 8">
                                    <Button x:Name="btnAddProf" Click="btnAddProf_Click"
                                            Style="{DynamicResource MaterialDesignRaisedButton}"
                                            Background="{DynamicResource PrimaryColor}" BorderThickness="0"
                                            materialDesign:ButtonAssist.CornerRadius="18" Height="36" Margin="0 0 10 0">
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="Plus" Width="18" Height="18" Margin="0 0 6 0" VerticalAlignment="Center"/>
                                            <TextBlock Text="Thêm quy hoạch" FontWeight="Bold" VerticalAlignment="Center" FontSize="13"/>
                                        </StackPanel>
                                    </Button>

                                    <Button x:Name="btnExportProf" Click="btnExportProf_Click"
                                            Style="{DynamicResource MaterialDesignRaisedButton}"
                                            Background="#2E7D32" BorderThickness="0"
                                            materialDesign:ButtonAssist.CornerRadius="18" Height="36">
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="FileExcel" Width="18" Height="18" Margin="0 0 6 0" VerticalAlignment="Center"/>
                                            <TextBlock Text="Xuất Excel" FontWeight="Bold" VerticalAlignment="Center" FontSize="13"/>
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </WrapPanel>
                        </materialDesign:Card>

                        <!-- DataGrid Professional -->
                        <DataGrid x:Name="dgProf" Grid.Row="1"
                                  AutoGenerateColumns="False" IsReadOnly="True" 
                                  CanUserAddRows="False" HeadersVisibility="Column"
                                  BorderThickness="0" Background="White"
                                  VerticalGridLinesBrush="Transparent"
                                  HorizontalGridLinesBrush="#EEEEEE"
                                  GridLinesVisibility="Horizontal" 
                                  AlternationCount="2" AlternatingRowBackground="#FAFAFA"
                                  MinRowHeight="50" VerticalContentAlignment="Center"
                                  SelectionMode="Single" SelectionUnit="FullRow" FrozenColumnCount="2"
                                  ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                  ScrollViewer.CanContentScroll="False">
                            <DataGrid.GroupStyle>
                                <GroupStyle ContainerStyle="{StaticResource PlanningGroupHeaderStyle}"/>
                            </DataGrid.GroupStyle>

                            <DataGrid.RowStyle>
                                <Style TargetType="DataGridRow" BasedOn="{StaticResource {x:Type DataGridRow}}">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="#E3F2FD"/>
                                            <Setter Property="Foreground" Value="#1F2937"/>
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#F5F9FF"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.RowStyle>
                            
                            <DataGrid.Resources>
                                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="Transparent"/>
                                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#1F2937"/>
                                <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="Transparent"/>
                                <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}" Color="#1F2937"/>

                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="FontWeight" Value="Bold"/>
                                    <Setter Property="FontSize" Value="14"/>
                                    <Setter Property="Background" Value="#F3F4F6"/>
                                    <Setter Property="Padding" Value="10"/>
                                    <Setter Property="MinHeight" Value="60"/>
                                    <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                    <Setter Property="ContentTemplate">
                                        <Setter.Value>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding}" TextWrapping="Wrap" TextAlignment="Center" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </DataTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                                <Style TargetType="DataGridCell">
                                    <Setter Property="TextBlock.TextAlignment" Value="Left"/>
                                    <Setter Property="FontSize" Value="15"/>
                                    <Setter Property="Padding" Value="6"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="{x:Type DataGridCell}">
                                                <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" SnapsToDevicePixels="True">
                                                    <ContentPresenter SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" VerticalAlignment="Center" HorizontalAlignment="Stretch"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Setter Property="Foreground" Value="#1F2937"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.Resources>

                            <DataGrid.Columns>
                                <DataGridTextColumn Header="STT" Binding="{Binding STT}" Width="55">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="HorizontalAlignment" Value="Center"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                                <DataGridTemplateColumn Header="HỌ VÀ TÊN" Width="170" MinWidth="140">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Personnel.FullName}" FontWeight="Bold" Margin="8 0" VerticalAlignment="Center" TextWrapping="Wrap">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="#1F2937"/>
                                                        <Style.Triggers>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTextColumn Header="CCCD" Binding="{Binding Personnel.IdentityCardNumber}" Width="125">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="HorizontalAlignment" Value="Center"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                                <DataGridTextColumn Header="NGÀY SINH" Binding="{Binding Personnel.DateOfBirth, Converter={StaticResource DateFormatterConverter}}" Width="110">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="HorizontalAlignment" Value="Center"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                                <DataGridTextColumn Header="BỘ PHẬN" Binding="{Binding Personnel.Department}" Width="130">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Margin" Value="8 0"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Setter Property="TextWrapping" Value="Wrap"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                                <DataGridTextColumn Header="CHỨC VỤ HIỆN TẠI" Binding="{Binding Personnel.Position}" Width="130">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Margin" Value="8 0"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Setter Property="TextWrapping" Value="Wrap"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                                <DataGridTextColumn Header="CHỨC DANH QUY HOẠCH" Binding="{Binding PlannedPosition}" Width="150">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Margin" Value="8 0"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Setter Property="TextWrapping" Value="Wrap"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                                <DataGridTextColumn Header="CHỨC DANH CHUYỂN TIẾP" Binding="{Binding PlannedTransitionPosition}" Width="150">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Margin" Value="8 0"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Setter Property="TextWrapping" Value="Wrap"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                                <DataGridTextColumn Header="TRÌNH ĐỘ CHUYÊN MÔN" Binding="{Binding TrainingLevel}" Width="130">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Margin" Value="8 0"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Setter Property="TextWrapping" Value="Wrap"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                                <DataGridTextColumn Header="LÝ LUẬN CHÍNH TRỊ" Binding="{Binding PoliticalTheoryLevel}" Width="120">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Margin" Value="8 0"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Setter Property="TextWrapping" Value="Wrap"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                                <DataGridTextColumn Header="NHIỆM KỲ" Binding="{Binding PlanningTerm}" Width="95">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="HorizontalAlignment" Value="Center"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                                <DataGridTextColumn Header="SỐ QĐ" Binding="{Binding DecisionNumber, Converter={StaticResource EmptyStringToDashConverter}}" Width="110">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="HorizontalAlignment" Value="Center"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                                <DataGridTextColumn Header="NGÀY KÝ" Binding="{Binding DecisionDate, Converter={StaticResource DateFormatterConverter}}" Width="110">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="HorizontalAlignment" Value="Center"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                                <DataGridTextColumn Header="ĐƠN VỊ RA QĐ" Binding="{Binding DecisionUnit}" Width="135">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Margin" Value="8 0"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Setter Property="TextWrapping" Value="Wrap"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                                <DataGridTextColumn Header="ĐÁNH GIÁ 3 NĂM GẦN NHẤT" Binding="{Binding Evaluation3Years}" Width="160">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Margin" Value="8 0"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Setter Property="TextWrapping" Value="Wrap"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                                <DataGridTextColumn Header="GHI CHÚ" Binding="{Binding Note}" Width="150">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Margin" Value="8 0"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Setter Property="TextWrapping" Value="Wrap"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                                <DataGridTemplateColumn Header="THAO TÁC" Width="120">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                <Button Click="btnEdit_Click" ToolTip="Sửa bản ghi"
                                                        Style="{StaticResource MaterialDesignIconButton}" Width="32" Height="32" Padding="0" Foreground="#1976D2">
                                                    <materialDesign:PackIcon Kind="Pencil" Width="18" Height="18"/>
                                                </Button>
                                                <Button Click="btnDelete_Click" ToolTip="Xóa bản ghi"
                                                        Style="{StaticResource MaterialDesignIconButton}" Width="32" Height="32" Padding="0" Foreground="#D32F2F" Margin="5 0 0 0">
                                                    <materialDesign:PackIcon Kind="Delete" Width="18" Height="18"/>
                                                </Button>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>

                        <!-- Footer -->
                        <Border Grid.Row="2" Background="#FAFAFA" BorderBrush="#EEEEEE" BorderThickness="0 1 0 0" Padding="15 10" Margin="-15 15 -15 -15" CornerRadius="0 0 8 8">
                            <TextBlock x:Name="txtTotalProf" Text="Hiển thị 0 bản ghi quy hoạch chuyên môn" FontSize="14" Foreground="#666" FontWeight="SemiBold"/>
                        </Border>
                    </Grid>
                </Border>
            </TabItem>

                <!-- TAB 2: QUY HOẠCH ĐẢNG -->
                <TabItem Header="QUY HOẠCH ĐẢNG">
                    <Border Background="#F5F5F5" Padding="15">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                        <!-- Toolbar -->
                        <materialDesign:Card Grid.Row="0" Margin="0 0 0 15" Padding="16 12" UniformCornerRadius="8">
                            <WrapPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <!-- Search -->
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0 0 15 8">
                                    <materialDesign:PackIcon Kind="Magnify" Width="22" Height="22" Foreground="{DynamicResource PrimaryHueMidBrush}" VerticalAlignment="Center" Margin="0 0 8 0"/>
                                    <Border Background="White" CornerRadius="4" BorderBrush="#D1D5DB" BorderThickness="1" Width="200" Height="36">
                                        <TextBox x:Name="txtSearchParty"
                                                 materialDesign:HintAssist.Hint="Tìm Họ tên, CCCD..."
                                                 materialDesign:TextFieldAssist.DecorationVisibility="Hidden"
                                                 materialDesign:TextFieldAssist.HasClearButton="True"
                                                 BorderThickness="0" Background="Transparent"
                                                 VerticalContentAlignment="Center" Padding="8 0" FontSize="14"
                                                 TextChanged="FilterParty_Changed"/>
                                    </Border>
                                </StackPanel>

                                <!-- Department -->
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0 0 15 8">
                                    <TextBlock Text="Bộ phận:" VerticalAlignment="Center" FontWeight="Bold" Margin="0 0 8 0" Foreground="#555" FontSize="14"/>
                                    <ComboBox x:Name="cboDeptParty" Width="220" Height="36" SelectionChanged="FilterParty_Changed" 
                                              BorderThickness="1" BorderBrush="#D1D5DB" Background="White" Foreground="Black" Padding="8 0" VerticalContentAlignment="Center"/>
                                </StackPanel>

                                <!-- Planning Term -->
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0 0 15 8">
                                    <TextBlock Text="Nhiệm kỳ:" VerticalAlignment="Center" FontWeight="Bold" Margin="0 0 8 0" Foreground="#555" FontSize="14"/>
                                    <ComboBox x:Name="cboTermParty" Width="160" Height="36" SelectionChanged="FilterParty_Changed" 
                                              BorderThickness="1" BorderBrush="#D1D5DB" Background="White" Foreground="Black" Padding="8 0" VerticalContentAlignment="Center">
                                    </ComboBox>
                                </StackPanel>

                                <!-- Status (Phân loại) -->
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0 0 15 8">
                                    <TextBlock Text="Trạng thái:" VerticalAlignment="Center" FontWeight="Bold" Margin="0 0 8 0" Foreground="#555" FontSize="14"/>
                                    <ComboBox x:Name="cboStatusParty" Width="180" Height="36" SelectionChanged="FilterParty_Changed" 
                                              BorderThickness="1" BorderBrush="#D1D5DB" Background="White" Foreground="Black" Padding="8 0" VerticalContentAlignment="Center">
                                        <ComboBoxItem Content="Tất cả trạng thái" IsSelected="True"/>
                                        <ComboBoxItem Content="1. Tiếp tục quy hoạch"/>
                                        <ComboBoxItem Content="2. Đưa ra khỏi quy hoạch"/>
                                        <ComboBoxItem Content="3. Bổ sung quy hoạch"/>
                                    </ComboBox>
                                </StackPanel>

                                <!-- Actions -->
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0 0 0 8">
                                    <Button x:Name="btnAddParty" Click="btnAddParty_Click"
                                            Style="{DynamicResource MaterialDesignRaisedButton}"
                                            Background="{DynamicResource PrimaryColor}" BorderThickness="0"
                                            materialDesign:ButtonAssist.CornerRadius="18" Height="36" Margin="0 0 10 0">
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="Plus" Width="18" Height="18" Margin="0 0 6 0" VerticalAlignment="Center"/>
                                            <TextBlock Text="Thêm quy hoạch" FontWeight="Bold" VerticalAlignment="Center" FontSize="13"/>
                                        </StackPanel>
                                    </Button>

                                    <Button x:Name="btnExportParty" Click="btnExportParty_Click"
                                            Style="{DynamicResource MaterialDesignRaisedButton}"
                                            Background="#2E7D32" BorderThickness="0"
                                            materialDesign:ButtonAssist.CornerRadius="18" Height="36">
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="FileExcel" Width="18" Height="18" Margin="0 0 6 0" VerticalAlignment="Center"/>
                                            <TextBlock Text="Xuất Excel" FontWeight="Bold" VerticalAlignment="Center" FontSize="13"/>
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </WrapPanel>
                        </materialDesign:Card>

                        <!-- DataGrid Party -->
                        <DataGrid x:Name="dgParty" Grid.Row="1"
                                  AutoGenerateColumns="False" IsReadOnly="True" 
                                  CanUserAddRows="False" HeadersVisibility="Column"
                                  BorderThickness="0" Background="White"
                                  VerticalGridLinesBrush="Transparent"
                                  HorizontalGridLinesBrush="#EEEEEE"
                                  GridLinesVisibility="Horizontal" 
                                  AlternationCount="2" AlternatingRowBackground="#FAFAFA"
                                  MinRowHeight="50" VerticalContentAlignment="Center"
                                  SelectionMode="Single" SelectionUnit="FullRow" FrozenColumnCount="2"
                                  ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                  ScrollViewer.CanContentScroll="False">
                            <DataGrid.GroupStyle>
                                <GroupStyle ContainerStyle="{StaticResource PlanningGroupHeaderStyle}"/>
                            </DataGrid.GroupStyle>

                            <DataGrid.RowStyle>
                                <Style TargetType="DataGridRow" BasedOn="{StaticResource {x:Type DataGridRow}}">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="#E3F2FD"/>
                                            <Setter Property="Foreground" Value="#1F2937"/>
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#F5F9FF"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.RowStyle>
                            
                            <DataGrid.Resources>
                                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="Transparent"/>
                                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#1F2937"/>
                                <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="Transparent"/>
                                <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}" Color="#1F2937"/>

                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="FontWeight" Value="Bold"/>
                                    <Setter Property="FontSize" Value="14"/>
                                    <Setter Property="Background" Value="#F3F4F6"/>
                                    <Setter Property="Padding" Value="10"/>
                                    <Setter Property="MinHeight" Value="60"/>
                                    <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                    <Setter Property="ContentTemplate">
                                        <Setter.Value>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding}" TextWrapping="Wrap" TextAlignment="Center" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </DataTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                                <Style TargetType="DataGridCell">
                                    <Setter Property="TextBlock.TextAlignment" Value="Left"/>
                                    <Setter Property="FontSize" Value="15"/>
                                    <Setter Property="Padding" Value="6"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="{x:Type DataGridCell}">
                                                <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" SnapsToDevicePixels="True">
                                                    <ContentPresenter SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" VerticalAlignment="Center" HorizontalAlignment="Stretch"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Setter Property="Foreground" Value="#1F2937"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.Resources>

                            <DataGrid.Columns>
                                <DataGridTextColumn Header="STT" Binding="{Binding STT}" Width="55">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="HorizontalAlignment" Value="Center"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                                <DataGridTemplateColumn Header="HỌ VÀ TÊN" Width="170" MinWidth="140">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Personnel.FullName}" FontWeight="Bold" Margin="8 0" VerticalAlignment="Center" TextWrapping="Wrap">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="#1F2937"/>
                                                        <Style.Triggers>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTextColumn Header="CCCD" Binding="{Binding Personnel.IdentityCardNumber}" Width="125">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="HorizontalAlignment" Value="Center"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                                <DataGridTextColumn Header="NGÀY SINH" Binding="{Binding Personnel.DateOfBirth, Converter={StaticResource DateFormatterConverter}}" Width="110">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="HorizontalAlignment" Value="Center"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                                <DataGridTextColumn Header="BỘ PHẬN" Binding="{Binding Personnel.Department}" Width="130">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Margin" Value="8 0"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Setter Property="TextWrapping" Value="Wrap"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                                <DataGridTextColumn Header="CHỨC VỤ HIỆN TẠI" Binding="{Binding Personnel.Position}" Width="130">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Margin" Value="8 0"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Setter Property="TextWrapping" Value="Wrap"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                                <DataGridTextColumn Header="CHỨC DANH QUY HOẠCH" Binding="{Binding PlannedPosition}" Width="150">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Margin" Value="8 0"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Setter Property="TextWrapping" Value="Wrap"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                                <DataGridTextColumn Header="CHỨC DANH CHUYỂN TIẾP" Binding="{Binding PlannedTransitionPosition}" Width="150">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Margin" Value="8 0"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Setter Property="TextWrapping" Value="Wrap"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                                <DataGridTextColumn Header="TRÌNH ĐỘ CHUYÊN MÔN" Binding="{Binding TrainingLevel}" Width="130">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Margin" Value="8 0"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Setter Property="TextWrapping" Value="Wrap"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                                <DataGridTextColumn Header="LÝ LUẬN CHÍNH TRỊ" Binding="{Binding PoliticalTheoryLevel}" Width="120">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Margin" Value="8 0"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Setter Property="TextWrapping" Value="Wrap"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                                <DataGridTextColumn Header="NHIỆM KỲ" Binding="{Binding PlanningTerm}" Width="95">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="HorizontalAlignment" Value="Center"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                                <DataGridTextColumn Header="SỐ QĐ" Binding="{Binding DecisionNumber, Converter={StaticResource EmptyStringToDashConverter}}" Width="110">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="HorizontalAlignment" Value="Center"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                                <DataGridTextColumn Header="NGÀY KÝ" Binding="{Binding DecisionDate, Converter={StaticResource DateFormatterConverter}}" Width="110">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="HorizontalAlignment" Value="Center"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                                <DataGridTextColumn Header="ĐƠN VỊ RA QĐ" Binding="{Binding DecisionUnit}" Width="135">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Margin" Value="8 0"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Setter Property="TextWrapping" Value="Wrap"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                                <DataGridTextColumn Header="ĐÁNH GIÁ 3 NĂM GẦN NHẤT" Binding="{Binding Evaluation3Years}" Width="160">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Margin" Value="8 0"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Setter Property="TextWrapping" Value="Wrap"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                                <DataGridTextColumn Header="GHI CHÚ" Binding="{Binding Note}" Width="150">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Margin" Value="8 0"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Setter Property="TextWrapping" Value="Wrap"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                                <DataGridTemplateColumn Header="THAO TÁC" Width="120">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                <Button Click="btnEdit_Click" ToolTip="Sửa bản ghi"
                                                        Style="{StaticResource MaterialDesignIconButton}" Width="32" Height="32" Padding="0" Foreground="#1976D2">
                                                    <materialDesign:PackIcon Kind="Pencil" Width="18" Height="18"/>
                                                </Button>
                                                <Button Click="btnDelete_Click" ToolTip="Xóa bản ghi"
                                                        Style="{StaticResource MaterialDesignIconButton}" Width="32" Height="32" Padding="0" Foreground="#D32F2F" Margin="5 0 0 0">
                                                    <materialDesign:PackIcon Kind="Delete" Width="18" Height="18"/>
                                                </Button>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>

                        <!-- Footer -->
                        <Border Grid.Row="2" Background="#FAFAFA" BorderBrush="#EEEEEE" BorderThickness="0 1 0 0" Padding="15 10" Margin="-15 15 -15 -15" CornerRadius="0 0 8 8">
                            <TextBlock x:Name="txtTotalParty" Text="Hiển thị 0 bản ghi quy hoạch đảng" FontSize="14" Foreground="#666" FontWeight="SemiBold"/>
                        </Border>
                    </Grid>
                </Border>
            </TabItem>
            </TabControl>
        </materialDesign:Card>

        <!-- Loading Overlay -->
        <Grid x:Name="LoadingOverlay" Grid.RowSpan="2" Visibility="Collapsed" Panel.ZIndex="1000">
            <Border Background="Black" Opacity="0.15"/>
            <materialDesign:Card UniformCornerRadius="10" Width="220" Height="140" materialDesign:ElevationAssist.Elevation="Dp6" VerticalAlignment="Center" HorizontalAlignment="Center">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <ProgressBar Style="{StaticResource MaterialDesignCircularProgressBar}" Value="0" IsIndeterminate="True" Width="40" Height="40" Margin="0 0 0 15"/>
                    <TextBlock Text="Đang xuất Excel..." FontSize="15" FontWeight="SemiBold" Foreground="#374151" HorizontalAlignment="Center"/>
                </StackPanel>
            </materialDesign:Card>
        </Grid>
    </Grid>
</Page>
