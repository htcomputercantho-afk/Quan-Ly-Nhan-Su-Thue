<Window x:Class="TaxPersonnelManagement.Views.BulkIncomeDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        mc:Ignorable="d"
        Title="Nhập Thu Nhập Khác Hàng Loạt" 
        SizeToContent="Height" MaxHeight="800" Width="470"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="#F5F5F5" FontFamily="Roboto">
    
    <Border Background="White" CornerRadius="8" Margin="10" Effect="{DynamicResource MaterialDesignShadowDepth2}">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackPanel Grid.Row="0" Margin="0 0 0 15">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <materialDesign:PackIcon Kind="CardsOutline" Width="28" Height="28" Foreground="#7B1FA2" Margin="0 0 10 0" VerticalAlignment="Center"/>
                    <TextBlock Text="Nhập Hàng Loạt" FontSize="22" FontWeight="Bold" Foreground="#7B1FA2" VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock Text="Thêm thu nhập khác cho nhiều công chức cùng lúc" Foreground="Gray" FontSize="13" TextAlignment="Center" Margin="0 5 0 0"/>
            </StackPanel>

            <!-- Content -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0 0 -10 0" Padding="0 0 10 0">
                <StackPanel Margin="0 10 0 0">
                    <!-- Data Info -->
                    <GroupBox Header="Thông tin khoản thu" materialDesign:ColorZoneAssist.Mode="Standard" BorderBrush="#E0E0E0" Background="#FAFAFA" Margin="0 0 0 15">
                        <StackPanel Margin="5">
                            <Grid Margin="0 0 0 15">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="15"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Tháng" FontSize="12" Foreground="#7B1FA2" FontWeight="Bold" Margin="0 0 0 5"/>
                                    <ComboBox x:Name="cboMonth" materialDesign:TextFieldAssist.UnderlineBrush="#7B1FA2" FontSize="15" Padding="5">
                                        <ComboBoxItem Content="Tháng 1"/>
                                        <ComboBoxItem Content="Tháng 2"/>
                                        <ComboBoxItem Content="Tháng 3"/>
                                        <ComboBoxItem Content="Tháng 4"/>
                                        <ComboBoxItem Content="Tháng 5"/>
                                        <ComboBoxItem Content="Tháng 6"/>
                                        <ComboBoxItem Content="Tháng 7"/>
                                        <ComboBoxItem Content="Tháng 8"/>
                                        <ComboBoxItem Content="Tháng 9"/>
                                        <ComboBoxItem Content="Tháng 10"/>
                                        <ComboBoxItem Content="Tháng 11"/>
                                        <ComboBoxItem Content="Tháng 12"/>
                                    </ComboBox>
                                </StackPanel>
                                
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Năm" FontSize="12" Foreground="#7B1FA2" FontWeight="Bold" Margin="0 0 0 5"/>
                                    <ComboBox x:Name="cboYear" materialDesign:TextFieldAssist.UnderlineBrush="#7B1FA2" FontSize="15" Padding="5"/>
                                </StackPanel>
                            </Grid>

                            <TextBlock Text="Số tiền thưởng (VNĐ)" FontSize="12" Foreground="#7B1FA2" FontWeight="Bold" Margin="0 0 0 5"/>
                            <TextBox x:Name="txtAmount" Style="{DynamicResource MaterialDesignOutlinedTextBox}" 
                                     materialDesign:HintAssist.Hint="Ví dụ: 500,000" FontSize="15" Margin="0 0 0 15" 
                                     Padding="10" TextChanged="TxtAmount_TextChanged"
                                     PreviewTextInput="TxtAmount_PreviewTextInput"
                                     InputMethod.IsInputMethodEnabled="False"
                                     materialDesign:TextFieldAssist.HasClearButton="True"/>
                            
                            <TextBlock Text="Nội dung thưởng" FontSize="12" Foreground="#7B1FA2" FontWeight="Bold" Margin="0 0 0 5"/>
                            <TextBox x:Name="txtReason" Style="{DynamicResource MaterialDesignOutlinedTextBox}" 
                                     materialDesign:HintAssist.Hint="Nhập nội dung thưởng tại đây (có thể nhập nhiều dòng)..." 
                                     FontSize="15" Padding="10" Margin="0 0 0 5"
                                     AcceptsReturn="True" TextWrapping="Wrap" MinHeight="100" 
                                     VerticalScrollBarVisibility="Auto" SpellCheck.IsEnabled="True"/>
                        </StackPanel>
                    </GroupBox>

                    <!-- Target Selection -->
                    <GroupBox Header="Đối tượng áp dụng" materialDesign:ColorZoneAssist.Mode="Standard" BorderBrush="#E0E0E0" Background="#FAFAFA">
                        <StackPanel Margin="5">
                            <RadioButton x:Name="radAll" Content="Tất cả công chức" GroupName="TargetGroup" IsChecked="True" Margin="0 0 0 10" Foreground="#444"/>
                            <RadioButton x:Name="radFemale" Content="Chỉ Công chức Nữ" GroupName="TargetGroup" Margin="0 0 0 10" Foreground="#444"/>
                            <RadioButton x:Name="radMale" Content="Chỉ Công chức Nam" GroupName="TargetGroup" Margin="0 0 0 10" Foreground="#444"/>
                            
                            <RadioButton x:Name="radDepartment" Content="Theo phòng ban:" GroupName="TargetGroup" Checked="RadDepartment_Checked" Unchecked="RadDepartment_Unchecked" Margin="0 0 0 5" Foreground="#444"/>
                            <ComboBox x:Name="cboDepartment" materialDesign:TextFieldAssist.UnderlineBrush="#7B1FA2" IsEnabled="False" Margin="25 0 0 0" Padding="5"/>
                        </StackPanel>
                    </GroupBox>
                    <TextBlock Text="*Số tiền nhập vào sẽ được CỘNG THÊM vào dữ liệu đang có của tháng được chọn." 
                               FontSize="11" Foreground="#E65100" FontWeight="SemiBold" FontStyle="Italic" Margin="0 15 0 0" TextWrapping="Wrap"/>
                </StackPanel>
            </ScrollViewer>

            <!-- Buttons -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0 15 0 0">
                <Button Content="ĐÓNG" IsCancel="True" Style="{DynamicResource MaterialDesignOutlinedButton}" 
                        Width="120" Height="40" Margin="0 0 15 0" FontSize="13" FontWeight="Bold"/>
                <Button Content="ÁP DỤNG" Click="BtnApply_Click" Background="#7B1FA2" BorderBrush="#7B1FA2" 
                        Foreground="White" Width="140" Height="40" FontSize="13" FontWeight="Bold"
                        materialDesign:ButtonAssist.CornerRadius="5"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
