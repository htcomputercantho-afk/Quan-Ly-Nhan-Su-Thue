                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- Section 2: ThÃ´ng tin cÃ´ng tÃ¡c -->
                            <Border Background="White" CornerRadius="8" Effect="{DynamicResource MaterialDesignShadowDepth1}" Margin="0 0 0 20">
                                <StackPanel>
                                    <Border Background="{DynamicResource SecondaryColor}" CornerRadius="8 8 0 0" Padding="15 10">
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="Briefcase" Foreground="White" VerticalAlignment="Center" Margin="0 0 10 0"/>
