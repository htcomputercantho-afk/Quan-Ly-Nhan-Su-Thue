<Window x:Class="TaxPersonnelManagement.Views.PlanningTermManagementDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Quản lý Nhiệm kỳ Quy hoạch" Height="450" Width="500" 
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize" 
        WindowStyle="None" Background="Transparent" AllowsTransparency="True"
        FontFamily="{DynamicResource MaterialDesignFont}"
        Language="vi-VN">

    <Border Background="White" CornerRadius="16" BorderThickness="1" BorderBrush="#E2E8F0">
        <Border.Effect>
            <DropShadowEffect BlurRadius="30" ShadowDepth="10" Opacity="0.15" Color="#000"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- Header -->
                <RowDefinition Height="Auto"/> <!-- Input Section -->
                <RowDefinition Height="*"/>    <!-- List Section -->
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0" Margin="25 25 25 15" MouseDown="Header_MouseDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="5" Height="24" CornerRadius="2.5" Background="{DynamicResource PrimaryHueMidBrush}" Margin="0 0 12 0"/>
                    <TextBlock Text="Quản lý Nhiệm kỳ Quy hoạch" FontSize="20" FontWeight="Bold" Foreground="#2D3748" VerticalAlignment="Center"/>
                </StackPanel>
                
                <Button Grid.Column="1" Click="btnClose_Click" Style="{DynamicResource MaterialDesignIconForegroundButton}" Width="32" Height="32" Foreground="#A0AEC0" ToolTip="Đóng">
                    <materialDesign:PackIcon Kind="Close" Width="20" Height="20"/>
                </Button>
            </Grid>
            
            <!-- Input Section -->
            <Grid Grid.Row="1" Margin="25 5 25 20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <!-- Từ năm -->
                    <Border Grid.Column="0" CornerRadius="8" Background="#F7FAFC" BorderThickness="1" BorderBrush="#E2E8F0" Height="50">
                        <TextBox x:Name="txtFromYear" 
                                 materialDesign:HintAssist.Hint="Từ năm (VD: 2026)" 
                                 materialDesign:TextFieldAssist.DecorationVisibility="Hidden"
                                 BorderThickness="0" 
                                 VerticalAlignment="Center"
                                 HorizontalContentAlignment="Center"
                                 Padding="10 0"
                                 FontSize="14"
                                 Foreground="#4A5568"
                                 Background="Transparent"
                                 PreviewTextInput="YearTextBox_PreviewTextInput"
                                 MaxLength="4"/>
                    </Border>
                    
                    <!-- Dấu nối -->
                    <TextBlock Grid.Column="1" Text="-" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="10 0" FontSize="18" FontWeight="Bold" Foreground="#A0AEC0"/>
                    
                    <!-- Đến năm -->
                    <Border Grid.Column="2" CornerRadius="8" Background="#F7FAFC" BorderThickness="1" BorderBrush="#E2E8F0" Height="50">
                        <TextBox x:Name="txtToYear" 
                                 materialDesign:HintAssist.Hint="Đến năm (VD: 2031)" 
                                 materialDesign:TextFieldAssist.DecorationVisibility="Hidden"
                                 BorderThickness="0" 
                                 VerticalAlignment="Center"
                                 HorizontalContentAlignment="Center"
                                 Padding="10 0"
                                 FontSize="14"
                                 Foreground="#4A5568"
                                 Background="Transparent"
                                 PreviewTextInput="YearTextBox_PreviewTextInput"
                                 MaxLength="4"/>
                    </Border>
                </Grid>
                
                <Button Grid.Column="1" x:Name="btnAdd" Click="btnAdd_Click" Margin="10 0 0 0" Height="50" Width="50" 
                        Background="{DynamicResource PrimaryHueMidBrush}" BorderBrush="{DynamicResource PrimaryHueMidBrush}" 
                        Style="{DynamicResource MaterialDesignFloatingActionMiniButton}"
                        ToolTip="Thêm nhiệm kỳ">
                    <materialDesign:PackIcon Kind="Plus" Width="24" Height="24"/>
                </Button>
            </Grid>

            <!-- List Section -->
            <Border Grid.Row="2" Background="#F7FAFC" BorderThickness="0 1 0 0" BorderBrush="#EDF2F7" CornerRadius="0 0 16 16" Padding="20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <TextBlock Text="DANH SÁCH HIỆN CÓ (Nhấp đúp chuột để chọn)" FontSize="12" FontWeight="Bold" Foreground="#A0AEC0" Margin="5 0 0 15"/>

                    <ListBox x:Name="lstPlanningTerms" Grid.Row="1" Background="Transparent" BorderThickness="0" ScrollViewer.HorizontalScrollBarVisibility="Disabled" Padding="0">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Margin" Value="0 0 0 10"/>
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border x:Name="ItemBorder" Background="White" CornerRadius="8" BorderThickness="1" BorderBrush="#E2E8F0" Padding="15 12">
                                                <Border.Effect>
                                                    <DropShadowEffect BlurRadius="5" ShadowDepth="2" Opacity="0.02" Color="#000"/>
                                                </Border.Effect>
                                                <ContentPresenter/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="ItemBorder" Property="BorderBrush" Value="{DynamicResource PrimaryHueMidBrush}"/>
                                                    <Setter TargetName="ItemBorder" Property="Effect">
                                                        <Setter.Value>
                                                            <DropShadowEffect BlurRadius="10" ShadowDepth="3" Opacity="0.1" Color="#000"/>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Trigger>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="ItemBorder" Property="BorderBrush" Value="{DynamicResource PrimaryHueMidBrush}"/>
                                                    <Setter TargetName="ItemBorder" Property="BorderThickness" Value="2"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <EventSetter Event="MouseDoubleClick" Handler="ListBoxItem_MouseDoubleClick"/>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <Grid VerticalAlignment="Center">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <materialDesign:PackIcon Kind="CalendarRange" Foreground="#718096" Width="20" Height="20" Margin="0 0 12 0" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1" Text="{Binding TermName}" FontSize="15" FontWeight="Medium" Foreground="#2D3748" VerticalAlignment="Center" TextWrapping="Wrap"/>
                                    </Grid>
                                    
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                        <Button Tag="{Binding}" Click="btnEdit_Click" 
                                                Width="32" Height="32" Padding="0" Margin="0 0 4 0" ToolTip="Sửa"
                                                Background="Transparent" BorderThickness="0">
                                            <materialDesign:PackIcon Kind="Pencil" Foreground="#1976D2" Width="20" Height="20"/>
                                        </Button>
                                        <Button Tag="{Binding}" Click="btnDelete_Click" 
                                                Width="32" Height="32" Padding="0" ToolTip="Xóa"
                                                Background="Transparent" BorderThickness="0">
                                            <materialDesign:PackIcon Kind="TrashCan" Foreground="#D32F2F" Width="20" Height="20"/>
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
