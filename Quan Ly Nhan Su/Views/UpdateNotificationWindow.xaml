<Window x:Class="TaxPersonnelManagement.Views.UpdateNotificationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Cập nhật phần mềm" Height="460" Width="520"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterScreen">
    
    <Border Background="White" CornerRadius="16" Margin="15">
        <Border.Effect>
            <DropShadowEffect BlurRadius="15" Direction="-90" RenderingBias="Quality" ShadowDepth="2" Color="#44000000"/>
        </Border.Effect>
        
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Background="{DynamicResource PrimaryHueMidBrush}" CornerRadius="16,16,0,0" Padding="20,15">
                <StackPanel Orientation="Horizontal">
                    <md:PackIcon Kind="Update" Foreground="White" Width="24" Height="24" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBlock Text="PHÁT HIỆN BẢN CẬP NHẬT MỚI" Foreground="White" FontWeight="Bold" FontSize="16" VerticalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- Content -->
            <Border Grid.Row="1" Padding="30,20">
                <StackPanel>
                <TextBlock Text="Một phiên bản mới đã sẵn sàng để tải xuống!" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,10"/>
                
                <Border Background="#F5F5F5" CornerRadius="8" Padding="15" Margin="0,0,0,20">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                            <TextBlock Text="Hiện tại" FontSize="12" Foreground="Gray" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="txtCurrentVersion" Text="1.0.1.2" FontSize="18" FontWeight="Bold" Foreground="#333"/>
                        </StackPanel>

                        <md:PackIcon Grid.Column="1" Kind="ArrowRightBold" Foreground="{DynamicResource PrimaryHueMidBrush}" Width="24" Height="24" VerticalAlignment="Center"/>

                        <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                            <TextBlock Text="Bản mới" FontSize="12" Foreground="Gray" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="txtNewVersion" Text="1.0.1.3" FontSize="18" FontWeight="Bold" Foreground="#2E7D32"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <TextBlock Text="Nội dung thay đổi:" FontWeight="Bold" FontSize="13" Margin="0,0,0,8"/>
                <Border Background="#F8F9FA" CornerRadius="6" BorderBrush="#E0E0E0" BorderThickness="1">
                    <ScrollViewer MaxHeight="160" Padding="2">
                        <TextBlock x:Name="txtChangelog" 
                                   TextWrapping="Wrap" Foreground="#444" FontSize="13" LineHeight="22"
                                   Padding="10,8"/>
                    </ScrollViewer>
                </Border>
            </StackPanel>
            </Border>

            <!-- Footer Buttons -->
            <Border Grid.Row="2" Background="#FAFAFA" CornerRadius="0,0,16,16" Padding="25,20">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="btnLater" Content="ĐỂ SAU" 
                            Style="{DynamicResource MaterialDesignFlatButton}" 
                            Foreground="Gray"
                            FontSize="13" FontWeight="SemiBold"
                            Height="40" Padding="20,0"
                            Margin="0,0,12,0" Click="btnLater_Click"/>
                    
                    <Button x:Name="btnUpdate" Content="CẬP NHẬT NGAY" 
                            Style="{DynamicResource MaterialDesignRaisedButton}" 
                            Background="{DynamicResource PrimaryHueMidBrush}" 
                            BorderBrush="{DynamicResource PrimaryHueMidBrush}"
                            md:ButtonAssist.CornerRadius="20"
                            FontSize="13" FontWeight="Bold"
                            Height="40" Padding="25,0"
                            Click="btnUpdate_Click">
                        <Button.Resources>
                            <Style TargetType="md:PackIcon">
                                <Setter Property="Margin" Value="0,0,8,0"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
