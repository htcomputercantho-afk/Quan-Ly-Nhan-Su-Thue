<Page x:Class="TaxPersonnelManagement.Views.AnnualIncomeView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      mc:Ignorable="d" 
      d:DesignHeight="700" d:DesignWidth="1000"
      Title="Tổng thu nhập năm">

    <Grid Background="#F5F5F5" Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/> <!-- Left Sidebar -->
            <ColumnDefinition Width="*"/> <!-- Main Content -->
        </Grid.ColumnDefinitions>

        <!-- Left Sidebar: Personnel List -->
        <Border Grid.Column="0" Background="White" Margin="0 0 10 0" CornerRadius="8" Effect="{DynamicResource MaterialDesignShadowDepth1}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Text="Danh sách Công chức" FontWeight="Bold" FontSize="16" Margin="15 15 15 5" Foreground="{DynamicResource PrimaryHueMidBrush}"/>
                
                <Border Grid.Row="1" Background="#F8F9FA" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="20" Margin="15 5 15 10" Padding="10 5">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Magnify" Width="20" Height="20" Foreground="Gray" VerticalAlignment="Center" Margin="0 0 5 0"/>
                        <TextBox x:Name="txtSearch" Width="200"
                                 materialDesign:HintAssist.Hint="Tìm kiếm theo tên..." 
                                 BorderThickness="0" Background="Transparent" VerticalAlignment="Center"
                                 TextChanged="TxtSearch_TextChanged"/>
                    </StackPanel>
                </Border>
                
                <ListView x:Name="lvPersonnel" Grid.Row="2" SelectionChanged="LvPersonnel_SelectionChanged" BorderThickness="0" Margin="5 0 5 5">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Margin="5 8">
                                <materialDesign:PackIcon Kind="AccountCircle" Width="24" Height="24" Foreground="Gray" VerticalAlignment="Center" Margin="0 0 10 0"/>
                                <StackPanel VerticalAlignment="Center" Margin="5 0 0 0">
                                    <TextBlock Text="{Binding FullName, FallbackValue='Tên nhân viên'}" FontSize="15" FontWeight="Medium"/>
                                    <StackPanel Orientation="Horizontal" Margin="0 4 0 0">
                                        <TextBlock Text="{Binding StaffId, FallbackValue='Mã CB'}" Foreground="Gray" FontSize="13"/>
                                        <TextBlock Text=" - " Foreground="Gray" FontSize="13"/>
                                        <TextBlock Text="{Binding IdentityCardNumber, FallbackValue='CCCD'}" Foreground="Gray" FontSize="13"/>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Border>

        <!-- Right Content -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- Summary Cards -->
                <RowDefinition Height="*"/> <!-- Main Area -->
            </Grid.RowDefinitions>

            <!-- Top Section: Summary Cards -->
            <!-- Top Section: Summary Cards -->
            <WrapPanel Grid.Row="0" Margin="0 0 0 0">
                <!-- Salary -->
                <Border Background="White" Width="220" Margin="0 0 10 10" CornerRadius="8" Padding="15" BorderBrush="#E0E0E0" BorderThickness="1" Effect="{DynamicResource MaterialDesignShadowDepth1}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Cash" Width="20" Height="20" Foreground="#1976D2" Margin="0 0 5 0"/>
                            <TextBlock Text="Lương" Foreground="Gray" FontSize="15" FontWeight="SemiBold"/>
                        </StackPanel>
                        <TextBlock x:Name="txtTotalSalary" Text="0 đ" FontWeight="Bold" FontSize="20" Margin="0 10 0 0" HorizontalAlignment="Right"/>
                    </StackPanel>
                </Border>
                <!-- Overtime -->
                <Border Background="White" Width="220" Margin="0 0 10 10" CornerRadius="8" Padding="15" BorderBrush="#E0E0E0" BorderThickness="1" Effect="{DynamicResource MaterialDesignShadowDepth1}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="ClockTimeFour" Width="20" Height="20" Foreground="#F57C00" Margin="0 0 5 0"/>
                            <TextBlock Text="Làm thêm giờ" Foreground="Gray" FontSize="15" FontWeight="SemiBold"/>
                        </StackPanel>
                        <TextBlock x:Name="txtTotalOvertime" Text="0 đ" FontWeight="Bold" FontSize="20" Margin="0 10 0 0" HorizontalAlignment="Right"/>
                    </StackPanel>
                </Border>
                <!-- Other Income -->
                <Border Background="White" Width="220" Margin="0 0 10 10" CornerRadius="8" Padding="15" BorderBrush="#E0E0E0" BorderThickness="1" Effect="{DynamicResource MaterialDesignShadowDepth1}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Cards" Width="20" Height="20" Foreground="#7B1FA2" Margin="0 0 5 0"/>
                            <TextBlock Text="Thu nhập khác" Foreground="Gray" FontSize="15" FontWeight="SemiBold"/>
                        </StackPanel>
                        <TextBlock x:Name="txtTotalOther" Text="0 đ" FontWeight="Bold" FontSize="20" Margin="0 10 0 0" HorizontalAlignment="Right"/>
                    </StackPanel>
                </Border>
                <!-- Total -->
                <Border Background="White" Width="220" Margin="0 0 10 10" CornerRadius="8" Padding="15" BorderBrush="#E0E0E0" BorderThickness="2" Effect="{DynamicResource MaterialDesignShadowDepth1}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Finance" Width="20" Height="20" Foreground="#388E3C" Margin="0 0 5 0"/>
                            <TextBlock Text="Tổng" Foreground="Black" FontSize="15" FontWeight="Bold"/>
                        </StackPanel>
                        <TextBlock x:Name="txtGrandTotal" Text="0 đ" FontWeight="Bold" FontSize="22" Margin="0 10 0 0" Foreground="#388E3C" HorizontalAlignment="Right"/>
                    </StackPanel>
                </Border>
            </WrapPanel>

            <!-- Main Area: Monthly Breakdown -->
            <Border Grid.Row="1" Background="White" CornerRadius="8" Padding="15" Effect="{DynamicResource MaterialDesignShadowDepth1}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="15"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <!-- Header -->
                    <WrapPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0 0 0 5">
                        <TextBlock Text="Chi tiết thu nhập từng tháng" FontWeight="Bold" FontSize="18" VerticalAlignment="Center" Foreground="{DynamicResource PrimaryHueMidBrush}" Margin="0 5 15 5"/>
                        <TextBlock Text="Năm:" VerticalAlignment="Center" Margin="0 5 10 5" FontSize="15" FontWeight="SemiBold"/>
                        <TextBlock Text="Cập nhật năm:" VerticalAlignment="Center" Margin="0 5 10 5" FontSize="14" Foreground="#555555"/>
                        <ComboBox x:Name="cboYear" Width="80" Height="32" Margin="0 5 15 5" SelectionChanged="CboYear_SelectionChanged"
                                  FontSize="15" FontWeight="Medium" Foreground="#1976D2"
                                  Background="#F5F5F5" BorderBrush="#BDBDBD" BorderThickness="1" Padding="10,4" VerticalContentAlignment="Center"
                                  materialDesign:TextFieldAssist.DecorationVisibility="Hidden"
                                  materialDesign:TextFieldAssist.UnderlineBrush="{x:Null}"/>

                        <Button x:Name="btnBulkAdd" Height="36" Click="BtnBulkAdd_Click" Margin="0 5 10 5" 
                                Background="#7B1FA2" BorderBrush="#7B1FA2" Foreground="White" Padding="15,0"
                                materialDesign:ButtonAssist.CornerRadius="18">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <materialDesign:PackIcon Kind="CardsOutline" Width="18" Height="18" Margin="0 0 6 0" VerticalAlignment="Center" Foreground="White"/>
                                <TextBlock Text="Nhập hàng loạt" FontWeight="Medium" VerticalAlignment="Center" FontSize="14"/>
                            </StackPanel>
                        </Button>

                        <Button x:Name="btnImportExcel" Height="36" Click="BtnImportExcel_Click" Margin="0 5 10 5" 
                                Background="#1976D2" BorderBrush="#1976D2" Foreground="White" Padding="15,0"
                                materialDesign:ButtonAssist.CornerRadius="18">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Border Background="White" CornerRadius="2" Padding="1" Margin="0 0 6 0">
                                    <TextBlock Text="x" Foreground="#1976D2" FontSize="10" FontWeight="Bold" FontFamily="Consolas" Width="12" TextAlignment="Center"/>
                                </Border>
                                <TextBlock Text="Import Excel" FontWeight="Medium" VerticalAlignment="Center" FontSize="14"/>
                            </StackPanel>
                        </Button>
                        
                        <Button x:Name="btnSave" Height="36" Click="BtnSave_Click" Margin="0 5 10 5"
                                Background="#2E7D32" BorderBrush="#2E7D32" Foreground="White" Padding="15,0"
                                materialDesign:ButtonAssist.CornerRadius="18">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <materialDesign:PackIcon Kind="ContentSave" Width="18" Height="18" Margin="0 0 6 0" VerticalAlignment="Center" Foreground="White"/>
                                <TextBlock Text="Lưu dữ liệu" FontWeight="Medium" VerticalAlignment="Center" FontSize="14"/>
                            </StackPanel>
                        </Button>
                    </WrapPanel>

                    <!-- Info Message -->
                    <TextBlock Grid.Row="1" HorizontalAlignment="Left" VerticalAlignment="Center" Text="*Chọn một công chức và click đúp vào ô để sửa dữ liệu" Foreground="Gray" FontStyle="Italic"/>

                    <!-- DataGrid -->
                    <DataGrid x:Name="dgMonthlyIncome" Grid.Row="2" AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False"
                              IsReadOnly="False"
                              HeadersVisibility="Column" SelectionMode="Single"
                              BorderThickness="1" BorderBrush="#EEEEEE" Background="White"
                              AlternatingRowBackground="#FAFAFA"
                              RowHeight="70"
                              FrozenColumnCount="1"
                              BeginningEdit="DgMonthlyIncome_BeginningEdit"
                              CellEditEnding="DgMonthlyIncome_CellEditEnding">
                        
                        <!-- Column Header Style -->
                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="#F0F2F5"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="Padding" Value="10"/>
                                <Setter Property="BorderThickness" Value="0 0 1 1"/>
                                <Setter Property="BorderBrush" Value="#E0E0E0"/>
                                <Setter Property="HorizontalContentAlignment" Value="Center"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>
                        
                        <DataGrid.Columns>
                            <!-- Income Type (Readonly) -->
                            <DataGridTextColumn Header="Loại thu nhập" Binding="{Binding IncomeType}" Width="150" IsReadOnly="True" FontWeight="SemiBold"/>
                            
                            <!-- Month 1 -->
                            <DataGridTemplateColumn Header="Tháng 1" Width="130">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="5">
                                            <TextBlock Text="{Binding M1Amount, StringFormat='{}{0:N0} đ'}" FontWeight="SemiBold" TextAlignment="Right"/>
                                            <TextBlock Text="{Binding M1Note}" Foreground="Gray" FontStyle="Italic" TextWrapping="Wrap" MaxWidth="120" FontSize="11" TextAlignment="Right"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                                <DataGridTemplateColumn.CellEditingTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="5">
                                            <TextBox Text="{Binding M1Amount, UpdateSourceTrigger=LostFocus}" materialDesign:HintAssist.Hint="Tiền" TextAlignment="Right"/>
                                            <TextBox Text="{Binding M1Note, UpdateSourceTrigger=LostFocus}" materialDesign:HintAssist.Hint="Ghi chú" Foreground="Gray" FontStyle="Italic" FontSize="11" TextAlignment="Right"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellEditingTemplate>
                            </DataGridTemplateColumn>

                            <!-- Month 2 -->
                            <DataGridTemplateColumn Header="Tháng 2" Width="130">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="5">
