                                            <TextBlock Text="{Binding M4Note}" Foreground="Gray" FontStyle="Italic" TextWrapping="Wrap" MaxWidth="120" FontSize="11" TextAlignment="Right"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                                <DataGridTemplateColumn.CellEditingTemplate>
                                    <DataTemplate>
