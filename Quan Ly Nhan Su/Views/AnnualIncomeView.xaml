                                            <TextBlock Text="{Binding M5Note}" Foreground="Gray" FontStyle="Italic" TextWrapping="Wrap" MaxWidth="120" FontSize="11" TextAlignment="Right"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                                <DataGridTemplateColumn.CellEditingTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="5">
                                            <TextBox Text="{Binding M5Amount, UpdateSourceTrigger=LostFocus}" materialDesign:HintAssist.Hint="Tiền" TextAlignment="Right"/>
                                            <TextBox Text="{Binding M5Note, UpdateSourceTrigger=LostFocus}" materialDesign:HintAssist.Hint="Ghi chú" Foreground="Gray" FontStyle="Italic" FontSize="11" TextAlignment="Right"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellEditingTemplate>
                            </DataGridTemplateColumn>

                            <!-- Month 6 -->
                            <DataGridTemplateColumn Header="Tháng 6" Width="130">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="5">
                                            <TextBlock Text="{Binding M6Amount, StringFormat='{}{0:N0} đ'}" FontWeight="SemiBold" TextAlignment="Right"/>
                                            <TextBlock Text="{Binding M6Note}" Foreground="Gray" FontStyle="Italic" TextWrapping="Wrap" MaxWidth="120" FontSize="11" TextAlignment="Right"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                                <DataGridTemplateColumn.CellEditingTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="5">
                                            <TextBox Text="{Binding M6Amount, UpdateSourceTrigger=LostFocus}" materialDesign:HintAssist.Hint="Tiền" TextAlignment="Right"/>
                                            <TextBox Text="{Binding M6Note, UpdateSourceTrigger=LostFocus}" materialDesign:HintAssist.Hint="Ghi chú" Foreground="Gray" FontStyle="Italic" FontSize="11" TextAlignment="Right"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellEditingTemplate>
                            </DataGridTemplateColumn>

                            <!-- Month 7 -->
                            <DataGridTemplateColumn Header="Tháng 7" Width="130">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="5">
                                            <TextBlock Text="{Binding M7Amount, StringFormat='{}{0:N0} đ'}" FontWeight="SemiBold" TextAlignment="Right"/>
                                            <TextBlock Text="{Binding M7Note}" Foreground="Gray" FontStyle="Italic" TextWrapping="Wrap" MaxWidth="120" FontSize="11" TextAlignment="Right"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                                <DataGridTemplateColumn.CellEditingTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="5">
                                            <TextBox Text="{Binding M7Amount, UpdateSourceTrigger=LostFocus}" materialDesign:HintAssist.Hint="Tiền" TextAlignment="Right"/>
                                            <TextBox Text="{Binding M7Note, UpdateSourceTrigger=LostFocus}" materialDesign:HintAssist.Hint="Ghi chú" Foreground="Gray" FontStyle="Italic" FontSize="11" TextAlignment="Right"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellEditingTemplate>
                            </DataGridTemplateColumn>

                            <!-- Month 8 -->
                            <DataGridTemplateColumn Header="Tháng 8" Width="130">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="5">
                                            <TextBlock Text="{Binding M8Amount, StringFormat='{}{0:N0} đ'}" FontWeight="SemiBold" TextAlignment="Right"/>
                                            <TextBlock Text="{Binding M8Note}" Foreground="Gray" FontStyle="Italic" TextWrapping="Wrap" MaxWidth="120" FontSize="11" TextAlignment="Right"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                                <DataGridTemplateColumn.CellEditingTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="5">
                                            <TextBox Text="{Binding M8Amount, UpdateSourceTrigger=LostFocus}" materialDesign:HintAssist.Hint="Tiền" TextAlignment="Right"/>
                                            <TextBox Text="{Binding M8Note, UpdateSourceTrigger=LostFocus}" materialDesign:HintAssist.Hint="Ghi chú" Foreground="Gray" FontStyle="Italic" FontSize="11" TextAlignment="Right"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellEditingTemplate>
                            </DataGridTemplateColumn>

                            <!-- Month 9 -->
                            <DataGridTemplateColumn Header="Tháng 9" Width="130">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="5">
                                            <TextBlock Text="{Binding M9Amount, StringFormat='{}{0:N0} đ'}" FontWeight="SemiBold" TextAlignment="Right"/>
                                            <TextBlock Text="{Binding M9Note}" Foreground="Gray" FontStyle="Italic" TextWrapping="Wrap" MaxWidth="120" FontSize="11" TextAlignment="Right"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                                <DataGridTemplateColumn.CellEditingTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="5">
                                            <TextBox Text="{Binding M9Amount, UpdateSourceTrigger=LostFocus}" materialDesign:HintAssist.Hint="Tiền" TextAlignment="Right"/>
                                            <TextBox Text="{Binding M9Note, UpdateSourceTrigger=LostFocus}" materialDesign:HintAssist.Hint="Ghi chú" Foreground="Gray" FontStyle="Italic" FontSize="11" TextAlignment="Right"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellEditingTemplate>
                            </DataGridTemplateColumn>

                            <!-- Month 10 -->
                            <DataGridTemplateColumn Header="Tháng 10" Width="130">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="5">
                                            <TextBlock Text="{Binding M10Amount, StringFormat='{}{0:N0} đ'}" FontWeight="SemiBold" TextAlignment="Right"/>
                                            <TextBlock Text="{Binding M10Note}" Foreground="Gray" FontStyle="Italic" TextWrapping="Wrap" MaxWidth="120" FontSize="11" TextAlignment="Right"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                                <DataGridTemplateColumn.CellEditingTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="5">
                                            <TextBox Text="{Binding M10Amount, UpdateSourceTrigger=LostFocus}" materialDesign:HintAssist.Hint="Tiền" TextAlignment="Right"/>
                                            <TextBox Text="{Binding M10Note, UpdateSourceTrigger=LostFocus}" materialDesign:HintAssist.Hint="Ghi chú" Foreground="Gray" FontStyle="Italic" FontSize="11" TextAlignment="Right"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellEditingTemplate>
                            </DataGridTemplateColumn>

                            <!-- Month 11 -->
                            <DataGridTemplateColumn Header="Tháng 11" Width="130">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="5">
                                            <TextBlock Text="{Binding M11Amount, StringFormat='{}{0:N0} đ'}" FontWeight="SemiBold" TextAlignment="Right"/>
                                            <TextBlock Text="{Binding M11Note}" Foreground="Gray" FontStyle="Italic" TextWrapping="Wrap" MaxWidth="120" FontSize="11" TextAlignment="Right"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                                <DataGridTemplateColumn.CellEditingTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="5">
                                            <TextBox Text="{Binding M11Amount, UpdateSourceTrigger=LostFocus}" materialDesign:HintAssist.Hint="Tiền" TextAlignment="Right"/>
                                            <TextBox Text="{Binding M11Note, UpdateSourceTrigger=LostFocus}" materialDesign:HintAssist.Hint="Ghi chú" Foreground="Gray" FontStyle="Italic" FontSize="11" TextAlignment="Right"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellEditingTemplate>
                            </DataGridTemplateColumn>

                            <!-- Month 12 -->
                            <DataGridTemplateColumn Header="Tháng 12" Width="130">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="5">
                                            <TextBlock Text="{Binding M12Amount, StringFormat='{}{0:N0} đ'}" FontWeight="SemiBold" TextAlignment="Right"/>
                                            <TextBlock Text="{Binding M12Note}" Foreground="Gray" FontStyle="Italic" TextWrapping="Wrap" MaxWidth="120" FontSize="11" TextAlignment="Right"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                                <DataGridTemplateColumn.CellEditingTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="5">
                                            <TextBox Text="{Binding M12Amount, UpdateSourceTrigger=LostFocus}" materialDesign:HintAssist.Hint="Tiền" TextAlignment="Right"/>
                                            <TextBox Text="{Binding M12Note, UpdateSourceTrigger=LostFocus}" materialDesign:HintAssist.Hint="Ghi chú" Foreground="Gray" FontStyle="Italic" FontSize="11" TextAlignment="Right"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellEditingTemplate>
                            </DataGridTemplateColumn>

                            <!-- Total (Readonly) -->
                            <DataGridTextColumn Header="Tổng cả năm (VNĐ)" Binding="{Binding Total, Mode=OneWay, StringFormat='{}{0:N0} đ'}" Width="160" IsReadOnly="True" FontWeight="Bold">
                                <DataGridTextColumn.CellStyle>
                                    <Style TargetType="DataGridCell">
                                        <Setter Property="Foreground" Value="#2E7D32"/>
                                        <Setter Property="HorizontalAlignment" Value="Right"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                    </Style>
                                </DataGridTextColumn.CellStyle>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>
