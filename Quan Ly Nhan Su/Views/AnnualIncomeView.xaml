<Page x:Class="TaxPersonnelManagement.Views.AnnualIncomeView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      xmlns:converters="clr-namespace:TaxPersonnelManagement.Converters"
      mc:Ignorable="d" 
      d:DesignHeight="700" d:DesignWidth="1000"
      Title="Tổng thu nhập năm">

    <Grid Background="#F5F5F5" Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/> <!-- Left Sidebar -->
            <ColumnDefinition Width="*"/> <!-- Main Content -->
        </Grid.ColumnDefinitions>

        <!-- Loading Overlay -->
        <Grid x:Name="LoadingOverlay" Grid.ColumnSpan="2" Visibility="Collapsed" Panel.ZIndex="1000">
            <Border Background="Black" Opacity="0.15"/>
            <materialDesign:Card UniformCornerRadius="10" Width="220" Height="140" materialDesign:ElevationAssist.Elevation="Dp6" VerticalAlignment="Center" HorizontalAlignment="Center">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <ProgressBar Style="{DynamicResource MaterialDesignCircularProgressBar}" 
                                 Value="0" IsIndeterminate="True" 
                                 Width="40" Height="40" 
                                 Foreground="#1976D2" Margin="0 0 0 15"/>
                    <TextBlock Text="Đang xử lý dữ liệu..." FontSize="14" FontWeight="SemiBold" Foreground="#455A64" HorizontalAlignment="Center"/>
                    <TextBlock Text="Vui lòng chờ trong giây lát" FontSize="11" Foreground="#78909C" HorizontalAlignment="Center" Margin="0 5 0 0"/>
                </StackPanel>
            </materialDesign:Card>
        </Grid>

        <!-- Left Sidebar: Personnel List -->
        <Border Grid.Column="0" Background="White" Margin="0 0 10 0" CornerRadius="8" Effect="{DynamicResource MaterialDesignShadowDepth1}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Text="Danh sách Công chức" FontWeight="Bold" FontSize="16" Margin="15 15 15 5" Foreground="{DynamicResource PrimaryHueMidBrush}"/>
                
                <Border Grid.Row="1" Background="#F8F9FA" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="20" Margin="15 5 15 10" Padding="10 5">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Magnify" Width="20" Height="20" Foreground="Gray" VerticalAlignment="Center" Margin="0 0 5 0"/>
                        <TextBox x:Name="txtSearch" Width="200"
                                 materialDesign:HintAssist.Hint="Tìm kiếm theo tên..." 
                                 BorderThickness="0" Background="Transparent" VerticalAlignment="Center"
                                 TextChanged="TxtSearch_TextChanged"/>
                    </StackPanel>
                </Border>
                
                <ListView x:Name="lvPersonnel" Grid.Row="2" SelectionChanged="LvPersonnel_SelectionChanged" BorderThickness="0" Margin="5 0 5 5">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Margin="5 8">
                                <materialDesign:PackIcon Kind="AccountCircle" Width="24" Height="24" Foreground="Gray" VerticalAlignment="Center" Margin="0 0 10 0"/>
                                <StackPanel VerticalAlignment="Center" Margin="5 0 0 0">
                                    <TextBlock Text="{Binding FullName, FallbackValue='Tên nhân viên'}" FontSize="15" FontWeight="Medium"/>
                                    <StackPanel Orientation="Horizontal" Margin="0 4 0 0">
                                        <TextBlock Text="{Binding StaffId, FallbackValue='Mã CB'}" Foreground="Gray" FontSize="13"/>
                                        <TextBlock Text=" - " Foreground="Gray" FontSize="13"/>
                                        <TextBlock Text="{Binding IdentityCardNumber, FallbackValue='CCCD'}" Foreground="Gray" FontSize="13"/>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Border>

        <!-- Right Content -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- Summary Cards -->
                <RowDefinition Height="*"/> <!-- Main Area -->
            </Grid.RowDefinitions>

            <!-- Top Section: Summary Cards -->
            <WrapPanel Grid.Row="0" Margin="0 0 0 0">
                <!-- Salary -->
                <Border Background="White" Width="220" Margin="0 0 10 10" CornerRadius="8" Padding="15" BorderBrush="#E0E0E0" BorderThickness="1" Effect="{DynamicResource MaterialDesignShadowDepth1}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Cash" Width="20" Height="20" Foreground="#1976D2" Margin="0 0 5 0"/>
                            <TextBlock Text="Lương" Foreground="Gray" FontSize="15" FontWeight="SemiBold"/>
                        </StackPanel>
                        <TextBlock x:Name="txtTotalSalary" Text="0 đ" FontWeight="Bold" FontSize="20" Margin="0 10 0 0" HorizontalAlignment="Right"/>
                    </StackPanel>
                </Border>
                <!-- Overtime -->
                <Border Background="White" Width="220" Margin="0 0 10 10" CornerRadius="8" Padding="15" BorderBrush="#E0E0E0" BorderThickness="1" Effect="{DynamicResource MaterialDesignShadowDepth1}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="ClockTimeFour" Width="20" Height="20" Foreground="#F57C00" Margin="0 0 5 0"/>
                            <TextBlock Text="Làm thêm giờ" Foreground="Gray" FontSize="15" FontWeight="SemiBold"/>
                        </StackPanel>
                        <TextBlock x:Name="txtTotalOvertime" Text="0 đ" FontWeight="Bold" FontSize="20" Margin="0 10 0 0" HorizontalAlignment="Right"/>
                    </StackPanel>
                </Border>
                <!-- Other Income -->
                <Border Background="White" Width="220" Margin="0 0 10 10" CornerRadius="8" Padding="15" BorderBrush="#E0E0E0" BorderThickness="1" Effect="{DynamicResource MaterialDesignShadowDepth1}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Cards" Width="20" Height="20" Foreground="#7B1FA2" Margin="0 0 5 0"/>
                            <TextBlock Text="Thu nhập khác" Foreground="Gray" FontSize="15" FontWeight="SemiBold"/>
                        </StackPanel>
                        <TextBlock x:Name="txtTotalOther" Text="0 đ" FontWeight="Bold" FontSize="20" Margin="0 10 0 0" HorizontalAlignment="Right"/>
                    </StackPanel>
                </Border>
                <!-- Total -->
                <Border Background="White" Width="220" Margin="0 0 10 10" CornerRadius="8" Padding="15" BorderBrush="#E0E0E0" BorderThickness="2" Effect="{DynamicResource MaterialDesignShadowDepth1}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Finance" Width="20" Height="20" Foreground="#388E3C" Margin="0 0 5 0"/>
                            <TextBlock Text="Tổng" Foreground="Black" FontSize="15" FontWeight="Bold"/>
                        </StackPanel>
                        <TextBlock x:Name="txtGrandTotal" Text="0 đ" FontWeight="Bold" FontSize="22" Margin="0 10 0 0" Foreground="#388E3C" HorizontalAlignment="Right"/>
                    </StackPanel>
                </Border>
            </WrapPanel>

            <!-- Main Area: Monthly Breakdown -->
            <Border Grid.Row="1" Background="White" CornerRadius="8" Padding="15" Effect="{DynamicResource MaterialDesignShadowDepth1}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="15"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <!-- Header -->
                    <WrapPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0 0 0 5">
                        <TextBlock Text="Chi tiết thu nhập từng tháng" FontWeight="Bold" FontSize="18" VerticalAlignment="Center" Foreground="{DynamicResource PrimaryHueMidBrush}" Margin="0 5 15 5"/>
                        <TextBlock Text="Năm:" VerticalAlignment="Center" Margin="0 5 10 5" FontSize="15" FontWeight="SemiBold"/>
                        <TextBlock Text="Cập nhật năm:" VerticalAlignment="Center" Margin="0 5 10 5" FontSize="14" Foreground="#555555"/>
                        <ComboBox x:Name="cboYear" Width="80" Height="32" Margin="0 5 15 5" SelectionChanged="CboYear_SelectionChanged"
                                  FontSize="15" FontWeight="Medium" Foreground="#1976D2"
                                  Background="#F5F5F5" BorderBrush="#BDBDBD" BorderThickness="1" Padding="10,4" VerticalContentAlignment="Center"
                                  materialDesign:TextFieldAssist.DecorationVisibility="Hidden"
                                  materialDesign:TextFieldAssist.UnderlineBrush="{x:Null}"/>

                        <Button x:Name="btnBulkAdd" Height="36" Click="BtnBulkAdd_Click" Margin="0 5 10 5" 
                                Style="{DynamicResource MaterialDesignRaisedButton}"
                                Background="#7B1FA2" BorderBrush="#7B1FA2" Foreground="White" Padding="15,0"
                                materialDesign:ButtonAssist.CornerRadius="18">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <materialDesign:PackIcon Kind="CardsOutline" Width="18" Height="18" Margin="0 0 6 0" VerticalAlignment="Center" Foreground="White"/>
                                <TextBlock Text="Nhập hàng loạt &amp; Excel" FontWeight="Medium" VerticalAlignment="Center" FontSize="14"/>
                            </StackPanel>
                        </Button>
                        
                        <Button x:Name="btnExportExcel" Height="36" Click="BtnExportExcel_Click" Margin="0 5 10 5"
                                Style="{DynamicResource MaterialDesignRaisedButton}"
                                Background="#0277BD" BorderBrush="#0277BD" Foreground="White" Padding="15,0"
                                materialDesign:ButtonAssist.CornerRadius="18">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <materialDesign:PackIcon Kind="FileExcel" Width="18" Height="18" Margin="0 0 6 0" VerticalAlignment="Center" Foreground="White"/>
                                <TextBlock Text="Xuất báo cáo Excel" FontWeight="Medium" VerticalAlignment="Center" FontSize="14"/>
                            </StackPanel>
                        </Button>

                        <Button x:Name="btnSave" Height="36" Click="BtnSave_Click" Margin="0 5 10 5"
                                Style="{DynamicResource MaterialDesignRaisedButton}"
                                Background="#2E7D32" BorderBrush="#2E7D32" Foreground="White" Padding="15,0"
                                materialDesign:ButtonAssist.CornerRadius="18">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <materialDesign:PackIcon Kind="ContentSave" Width="18" Height="18" Margin="0 0 6 0" VerticalAlignment="Center" Foreground="White"/>
                                <TextBlock Text="Lưu dữ liệu" FontWeight="Medium" VerticalAlignment="Center" FontSize="14"/>
                            </StackPanel>
                        </Button>

                        <Button x:Name="btnClearData" Height="36" Click="BtnClearData_Click" Margin="0 5 10 5"
                                Style="{DynamicResource MaterialDesignRaisedButton}"
                                Background="#D32F2F" BorderBrush="#D32F2F" Foreground="White" Padding="15,0"
                                materialDesign:ButtonAssist.CornerRadius="18">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <materialDesign:PackIcon Kind="Delete" Width="18" Height="18" Margin="0 0 6 0" VerticalAlignment="Center" Foreground="White"/>
                                <TextBlock Text="Xóa dữ liệu năm" FontWeight="Medium" VerticalAlignment="Center" FontSize="14"/>
                            </StackPanel>
                        </Button>
                    </WrapPanel>

                    <!-- Info Message -->
                    <TextBlock Grid.Row="1" HorizontalAlignment="Left" VerticalAlignment="Center" Text="*Chọn một công chức và click đúp vào ô để sửa dữ liệu" Foreground="Gray" FontStyle="Italic"/>

                    <!-- DataGrid -->
                    <DataGrid x:Name="dgMonthlyIncome" Grid.Row="2" BorderThickness="1" BorderBrush="#EEEEEE" Background="White"
                              AutoGenerateColumns="False" AlternatingRowBackground="#FAFAFA"
                              MinRowHeight="60"
                              FrozenColumnCount="1"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              BeginningEdit="DgMonthlyIncome_BeginningEdit"
                              CellEditEnding="DgMonthlyIncome_CellEditEnding">
                        
                        <DataGrid.Resources>
                            <converters:MathSubtractConverter x:Key="MathSubtractConverter"/>
                        <converters:CurrencyFormatConverter x:Key="CurrencyFormatConverter"/>
                            <!-- TextBlock Style for Amount -->
                            <Style x:Key="MonthAmountStyle" TargetType="TextBlock">
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="Foreground" Value="#2E7D32"/>
                                <Setter Property="TextAlignment" Value="Right"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IncomeType}" Value="Thu nhập khác">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IncomeType}" Value="Làm thêm giờ">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IncomeType}" Value="Lương">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Path=IsSelected, RelativeSource={RelativeSource AncestorType=DataGridRow}}" Value="True">
                                        <Setter Property="Foreground" Value="{Binding RelativeSource={RelativeSource AncestorType=DataGridCell}, Path=Foreground}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>

                            <!-- TextBlock Style for Note -->
                            <Style x:Key="MonthNoteStyle" TargetType="TextBlock">
                                <Setter Property="Foreground" Value="Gray"/>
                                <Setter Property="FontStyle" Value="Italic"/>
                                <Setter Property="TextWrapping" Value="Wrap"/>
                                <Setter Property="MaxWidth" Value="{Binding Path=ActualWidth, RelativeSource={RelativeSource AncestorType=DataGridCell}, Converter={StaticResource MathSubtractConverter}, ConverterParameter=15}"/>
                                <Setter Property="FontSize" Value="11"/>
                                <Setter Property="TextAlignment" Value="Right"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IncomeType}" Value="Thu nhập khác">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IncomeType}" Value="Làm thêm giờ">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IncomeType}" Value="Lương">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Path=IsSelected, RelativeSource={RelativeSource AncestorType=DataGridRow}}" Value="True">
                                        <Setter Property="Foreground" Value="#E2E8F0"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>

                            <!-- ItemsControl Style for Breakdown -->
                            <Style x:Key="MonthBreakdownStyle" TargetType="ItemsControl">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Setter Property="HorizontalAlignment" Value="Stretch"/>
                                <Setter Property="ItemTemplate">
                                    <Setter.Value>
                                        <DataTemplate>
                                            <Border CornerRadius="6" BorderThickness="1" BorderBrush="#E0E2E5" Background="#F8F9FA" Padding="8,5" Margin="0,2,0,3">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Path=IsSelected, RelativeSource={RelativeSource AncestorType=DataGridRow}}" Value="True">
                                                                <Setter Property="Background" Value="#FFFFFF"/>
                                                                <Setter Property="BorderBrush" Value="#CBD5E0"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <StackPanel>
                                                    <!-- Amount -->
                                                    <TextBlock Text="{Binding FormattedAmount}" FontWeight="Bold" FontSize="11.5" HorizontalAlignment="Right">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Foreground" Value="#1976D2"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Path=IsSelected, RelativeSource={RelativeSource AncestorType=DataGridRow}}" Value="True">
                                                                        <Setter Property="Foreground" Value="#0D47A1"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                    
                                                    <!-- Reason -->
                                                    <TextBlock Text="{Binding Reason}" FontSize="10.5" HorizontalAlignment="Right" TextWrapping="Wrap" TextAlignment="Right"
                                                               MaxWidth="{Binding Path=ActualWidth, RelativeSource={RelativeSource AncestorType=DataGridCell}, Converter={StaticResource MathSubtractConverter}, ConverterParameter=25}">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Foreground" Value="#4A5568"/>
                                                                <Setter Property="FontStyle" Value="Italic"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Path=IsSelected, RelativeSource={RelativeSource AncestorType=DataGridRow}}" Value="True">
                                                                        <Setter Property="Foreground" Value="#2D3748"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IncomeType}" Value="Thu nhập khác">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IncomeType}" Value="Làm thêm giờ">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>

                            <!-- TextBox Style for Amount Editing -->
                            <Style x:Key="MonthAmountTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                                <Setter Property="TextAlignment" Value="Right"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IncomeType}" Value="Thu nhập khác">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IncomeType}" Value="Làm thêm giờ">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>

                            <!-- TextBox Style for Note Editing -->
                            <Style x:Key="MonthNoteTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                                <Setter Property="Foreground" Value="Gray"/>
                                <Setter Property="FontStyle" Value="Italic"/>
                                <Setter Property="FontSize" Value="11"/>
                                <Setter Property="TextAlignment" Value="Right"/>
                                <Setter Property="TextWrapping" Value="Wrap"/>
                                <Setter Property="AcceptsReturn" Value="True"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IncomeType}" Value="Lương">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IncomeType}" Value="Thu nhập khác">
                                        <Setter Property="materialDesign:HintAssist.Hint" Value="Nhập: [Số tiền] - [Nội dung] (Mỗi khoản 1 dòng)"/>
                                        <Setter Property="Foreground" Value="#333333"/>
                                        <Setter Property="FontStyle" Value="Normal"/>
                                        <Setter Property="FontSize" Value="11"/>
                                        <Setter Property="MinHeight" Value="60"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IncomeType}" Value="Làm thêm giờ">
                                        <Setter Property="materialDesign:HintAssist.Hint" Value="Nhập: [Số tiền] - [Nội dung] (Mỗi khoản 1 dòng)"/>
                                        <Setter Property="Foreground" Value="#333333"/>
                                        <Setter Property="FontStyle" Value="Normal"/>
                                        <Setter Property="FontSize" Value="11"/>
                                        <Setter Property="MinHeight" Value="60"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.Resources>
                        
                        <!-- Column Header Style -->
                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="#F0F2F5"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="Padding" Value="10"/>
                                <Setter Property="BorderThickness" Value="0 0 1 1"/>
                                <Setter Property="BorderBrush" Value="#E0E0E0"/>
                                <Setter Property="HorizontalContentAlignment" Value="Center"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>
                        
                        <DataGrid.Columns>
                            <!-- Income Type (Readonly) -->
                            <DataGridTextColumn Header="Loại thu nhập" Binding="{Binding IncomeType}" Width="150" IsReadOnly="True" FontWeight="SemiBold"/>
                            
                            <!-- Month 1 -->
                            <DataGridTemplateColumn Header="Tháng 1" Width="140">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="5">
                                            <!-- Card Border for Lương -->
                                            <Border CornerRadius="6" BorderThickness="1" BorderBrush="#E0E2E5" Background="#F8F9FA" Padding="8,5" Margin="0,2,0,3">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IncomeType}" Value="Lương">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Path=IsSelected, RelativeSource={RelativeSource AncestorType=DataGridRow}}" Value="True">
                                                                <Setter Property="Background" Value="#FFFFFF"/>
                                                                <Setter Property="BorderBrush" Value="#CBD5E0"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <StackPanel>
                                                    <!-- Amount -->
                                                    <TextBlock Text="{Binding M1Amount, StringFormat='{}{0:N0} đ'}" FontWeight="Bold" FontSize="11.5" HorizontalAlignment="Right">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Foreground" Value="#1976D2"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Path=IsSelected, RelativeSource={RelativeSource AncestorType=DataGridRow}}" Value="True">
                                                                        <Setter Property="Foreground" Value="#0D47A1"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                    <!-- Note -->
                                                    <TextBlock Text="{Binding M1Note}" FontSize="10.5" HorizontalAlignment="Right" TextWrapping="Wrap" TextAlignment="Right"
                                                               MaxWidth="{Binding Path=ActualWidth, RelativeSource={RelativeSource AncestorType=DataGridCell}, Converter={StaticResource MathSubtractConverter}, ConverterParameter=25}">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Foreground" Value="#4A5568"/>
                                                                <Setter Property="FontStyle" Value="Italic"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Path=IsSelected, RelativeSource={RelativeSource AncestorType=DataGridRow}}" Value="True">
                                                                        <Setter Property="Foreground" Value="#2D3748"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding M1Note}" Value="{x:Null}">
                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding M1Note}" Value="">
                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </StackPanel>
                                            </Border>

                                            <!-- Original amount/note (only visible for Total row) -->
                                            <TextBlock Text="{Binding M1Amount, StringFormat='{}{0:N0} đ'}" Style="{StaticResource MonthAmountStyle}"/>
                                            <TextBlock Text="{Binding M1Note}" Style="{StaticResource MonthNoteStyle}"/>
                                            
                                            <!-- ItemsControl for breakdowns (only visible for Overtime and Other Income) -->
                                            <ItemsControl ItemsSource="{Binding M1Breakdown}" Style="{StaticResource MonthBreakdownStyle}"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                                <DataGridTemplateColumn.CellEditingTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="5">
                                            <TextBox Text="{Binding M1Amount, Converter={StaticResource CurrencyFormatConverter}, UpdateSourceTrigger=LostFocus}" TextChanged="AmountTextBox_TextChanged" materialDesign:HintAssist.Hint="Tiền" Style="{StaticResource MonthAmountTextBoxStyle}"/>
                                            <TextBox Text="{Binding M1Note, UpdateSourceTrigger=LostFocus}" materialDesign:HintAssist.Hint="Ghi chú" Style="{StaticResource MonthNoteTextBoxStyle}"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellEditingTemplate>
                            </DataGridTemplateColumn>

                            <!-- Month 2 -->
                            <DataGridTemplateColumn Header="Tháng 2" Width="140">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="5">
                                            <!-- Card Border for Lương -->
                                            <Border CornerRadius="6" BorderThickness="1" BorderBrush="#E0E2E5" Background="#F8F9FA" Padding="8,5" Margin="0,2,0,3">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IncomeType}" Value="Lương">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Path=IsSelected, RelativeSource={RelativeSource AncestorType=DataGridRow}}" Value="True">
                                                                <Setter Property="Background" Value="#FFFFFF"/>
                                                                <Setter Property="BorderBrush" Value="#CBD5E0"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <StackPanel>
                                                    <!-- Amount -->
                                                    <TextBlock Text="{Binding M2Amount, StringFormat='{}{0:N0} đ'}" FontWeight="Bold" FontSize="11.5" HorizontalAlignment="Right">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Foreground" Value="#1976D2"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Path=IsSelected, RelativeSource={RelativeSource AncestorType=DataGridRow}}" Value="True">
                                                                        <Setter Property="Foreground" Value="#0D47A1"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                    <!-- Note -->
