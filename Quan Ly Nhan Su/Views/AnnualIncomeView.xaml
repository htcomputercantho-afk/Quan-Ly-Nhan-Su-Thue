                                            <TextBlock Text="{Binding M2Note}" Foreground="Gray" FontStyle="Italic" TextWrapping="Wrap" MaxWidth="120" FontSize="11" TextAlignment="Right"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                                <DataGridTemplateColumn.CellEditingTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="5">
                                            <TextBox Text="{Binding M2Amount, UpdateSourceTrigger=LostFocus}" materialDesign:HintAssist.Hint="Tiền" TextAlignment="Right"/>
                                            <TextBox Text="{Binding M2Note, UpdateSourceTrigger=LostFocus}" materialDesign:HintAssist.Hint="Ghi chú" Foreground="Gray" FontStyle="Italic" FontSize="11" TextAlignment="Right"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellEditingTemplate>
                            </DataGridTemplateColumn>

                            <!-- Month 3 -->
                            <DataGridTemplateColumn Header="Tháng 3" Width="130">
                                <DataGridTemplateColumn.CellTemplate>
