<Window x:Class="TaxPersonnelManagement.Views.ChangePasswordDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Đổi mật khẩu" Height="460" Width="450"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        FontFamily="{DynamicResource MaterialDesignFont}"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        TextElement.FontSize="14" TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        UseLayoutRounding="True" SnapsToDevicePixels="True">

    <Border Background="White" CornerRadius="12" BorderThickness="1" BorderBrush="#E0E0E0">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="5" Opacity="0.2"/>
        </Border.Effect>
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0 0 0 15">
                <materialDesign:PackIcon Kind="KeyChange" Width="28" Height="28" Foreground="{DynamicResource PrimaryHueMidBrush}" VerticalAlignment="Center"/>
                <TextBlock Text="ĐỔI MẬT KHẨU" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource PrimaryHueMidBrush}" Margin="10 0 0 0" VerticalAlignment="Center"/>
            </StackPanel>
            
            <Separator Grid.Row="1" Margin="-20 0 -20 15" Background="#EEEEEE"/>

            <!-- Form -->
            <StackPanel Grid.Row="2" VerticalAlignment="Center">
                <TextBlock x:Name="txtUsernameLabel" Text="Để tiếp tục đổi mật khẩu cho tài khoản:" 
                           FontSize="13" Foreground="Gray" Margin="0 0 0 5"/>
                <TextBlock x:Name="txtUsernameDisplay" Text="admin" FontWeight="SemiBold" FontSize="15" Margin="0 0 0 15" Foreground="#1976D2"/>

                <TextBlock Style="{StaticResource ModernLabel}" Text="Mật khẩu mới" />
                <PasswordBox x:Name="pwdNewPassword" Style="{StaticResource ModernPasswordBox}" Margin="0 0 0 15" />
                             
                <TextBlock Style="{StaticResource ModernLabel}" Text="Xác nhận mật khẩu" />
                <PasswordBox x:Name="pwdConfirmPassword" Style="{StaticResource ModernPasswordBox}" Margin="0 0 0 0" />
            </StackPanel>

            <!-- Action Buttons -->
            <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0 25 0 0">
                <Button Content="Hủy" Width="80" Margin="0 0 10 0" Click="BtnCancel_Click"
                        Background="White" Foreground="#424242" BorderBrush="#B0BEC5" BorderThickness="1" materialDesign:ButtonAssist.CornerRadius="18"/>
                <Button x:Name="btnSave" Content="Lưu" Width="80" Click="BtnSave_Click"
                        Background="#1976D2" Foreground="White" BorderBrush="#1976D2" BorderThickness="1" materialDesign:ButtonAssist.CornerRadius="18"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
